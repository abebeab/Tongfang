        width: 10px;
        height: 10px;
        background: url('../../../../etc/clientlibs/it/resources/icons/xiala-2%402x.png') center/contain no-repeat; 
        position: absolute;
        top: 20px;
        right: 0px;
    }
    .rtl .footer-body.global-footer .footer-body-content .footer-navigation-body .footer-navigation-block:not(.contact-group):after{

          margin-right:50px;
      }
      .ie-browser .browser li img{
        width: 60px;
        height:60px
      }
      .ie-browser .browser li svg{
          font-size:60px;
      }
      .ie-browser .browser li:nth-last-of-type(1){
          margin-right: 0px;
      }
      .use-ie-browser{
          color: #094f9c;
          cursor: pointer;
          margin-bottom: 20px !important;
      }
      .use-ie-browser img{
          margin-top: -2px;
          margin-left: 5px;
      }

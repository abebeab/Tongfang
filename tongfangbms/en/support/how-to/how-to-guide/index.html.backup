     #header .header-wrap .header-navbar li.nav-left-item .nav-box .mask .box-ul li .second-dl > dl dd.nav-dd li div.content-div .content-wrap.ie-content .s-content.p-content{
         width: 85% !important;
         overflow: inherit !important;

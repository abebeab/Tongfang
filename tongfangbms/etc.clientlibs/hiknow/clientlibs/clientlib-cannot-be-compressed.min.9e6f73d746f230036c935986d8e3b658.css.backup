.hilook-page .search-list .advanced-filter-inner .filter-container .filter-card .filter-card-header.collapsed .triangle-indicator.active{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/hilook-icon-open-red.svg')}

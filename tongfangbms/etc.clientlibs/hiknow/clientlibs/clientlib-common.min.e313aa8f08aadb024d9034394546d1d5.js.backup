 var stopPropagation = function(e) {
   if ( e && e.stopPropagation )
    e.stopPropagation();
 else
    window.event.cancelBubble = true;
 }

  var $hardwareBox = $('#header .mobile-bottom-nav .product-hardware');
  var $softwareBox = $('#header .mobile-bottom-nav .product-software');

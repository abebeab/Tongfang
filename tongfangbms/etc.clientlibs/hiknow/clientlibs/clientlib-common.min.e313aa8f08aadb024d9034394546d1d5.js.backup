var newsroomCarousel = (function ($) {
    var newsroomCarousel = {};
    var currentDate = $(".newsrroom-newDate")
    currentDate && currentDate.length > 0 && currentDate.each(function () {
        if ( window.location.href.indexOf('/cn') > -1 && $(this).attr("data-newDate")) {
            var tmpStr = $(this).attr("data-newDate").replace(",", "")
            var tmpArr = tmpStr.split(" ")
            var tmpNum = ''
            switch (tmpArr[0]) {
                case "January":
                    tmpNum = 1
                    break;
                case "February":
                    tmpNum = 2
                    break;
                case "March":
                    tmpNum = 3
                    break;
                case "April":
                    tmpNum = 4
                    break;
                case "May":
                    tmpNum = 5
                    break;
                case "June":
                    tmpNum = 6
                    break;
                case "July":
                    tmpNum = 7
                    break;
                case "August":
                    tmpNum = 8
                    break;
                case "September":
                    tmpNum = 9
                    break;
                case "October":
                    tmpNum = 10
                    break;
                case "November":
                    tmpNum = 11
                    break;
                case "December":
                    tmpNum = 12
                    break;

                default:
                    break;
            }
            $(this).text(tmpArr[2] + "年" + tmpNum + "月" + tmpArr[1] + "日")
        } else {
            $(this).text($(this).attr("data-newDate"))

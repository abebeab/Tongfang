.rtl .notice-wrapper .notice-container .notice-footer-wrapper .notice-button:last-child{margin-right:2rem}
.site-map-content{padding:13px 6% 26px 6%;background:#fff}
.site-map-content a{color:#2a2e2e}
.site-map-content-primary{border-bottom:3px solid #eaeaea;padding-bottom:10px;padding-top:20px}
.site-map-content-primary-link{font-size:1.875rem;letter-spacing:.15px;line-height:1.75;font-weight:800;word-break:break-word;overflow:hidden;white-space:normal;margin-bottom:20px}
.site-map-content-primary .site-map-primary-content{display:flex;flex-wrap:wrap;padding-right:0;padding-left:0}
.site-map-content-secondary{padding-left:0;margin-bottom:.5rem;padding-right:1.875rem}
.site-map-content-secondary-link{font-size:1rem;letter-spacing:.1px;line-height:1.75;font-weight:800;padding-bottom:14px;word-break:break-word;overflow:hidden;white-space:normal}
.site-map-content-tertiary{font-size:.875rem;letter-spacing:.07px;line-height:1.25;padding-bottom:10px;word-break:break-word;overflow:hidden;white-space:normal}
@media only screen and (max-width:767.9px){.site-map-content{padding:0 4vw 26px 4vw}
}
@media(min-width:1025px){.site-map-wrapper{max-width:81.875rem;margin:0 auto}
}
.reset-password-content{background:#fff;box-shadow:0 2px 20px 0 rgba(200,200,200,0.5);position:relative;width:41rem;margin:0 auto}
.reset-password-content label{margin-bottom:0}
.reset-password-content-header{font-size:1.125rem;border-bottom:1px dashed #eaeaea;padding:2rem 0}
#loading-div{width:100%;height:100%;background:rgba(255,255,255,0.5);z-index:100;display:none}
.loading-div{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:30px;height:30px}
.reset-article{padding:1rem;color:#000}
.reset-child-article>header{font-size:1rem;padding:1.25rem 0 0 0;letter-spacing:0;text-align:left}
.line-input{height:2.5rem !important;padding:0 8px;border-top:0;border-left:0;border-right:0;border-bottom:1px solid #ccc;color:#333;letter-spacing:0;font-size:1.125rem;display:block;outline:0;width:100%;box-sizing:border-box}
.line-input:focus{border-bottom:3px solid #d7292f}
.error-message{color:#d7292f;display:none;font-size:.875rem}
.error-message header{margin:0;padding:0}
.error-message header p{margin:0;padding:0;font-size:.875rem}
.error-message .rules .error-div{background-position:left;background-repeat:no-repeat;padding-left:1.5rem}
.rules{background:#f5f5f5;padding:4px 0 10px 16px;width:50%}
.reset-article footer{margin-top:2rem}
.btn-confirm{height:2.5rem;min-width:160px;margin:auto;background:#d7292f;border:1px solid #d7292f;border-radius:1.875rem;font-size:1.25rem;color:#fff;letter-spacing:0;text-align:center !important;cursor:pointer;font-weight:600;margin-bottom:2rem}
.btn-confirm:focus{outline:0}
#global-message{top:40%;height:10px;width:100%;z-index:1000;text-align:center;display:none}
.message-box{display:inline-block;pointer-events:all;padding:8px 20px 8px 36px;border-radius:4px;box-shadow:0 1px 6px rgba(0,0,0,0.2);background:#fff;font-size:22px;position:absolute;transform:translate(-50%,-50%);top:50%}
.message-box-success:before{content:url("../../../../etc/clientlibs/it/resources/icons/gou.png");position:absolute;left:.625rem;top:.625rem}
.message-box-error:before{content:url("../../../../etc/clientlibs/it/resources/icons/error.png");position:absolute;left:.625rem;top:.625rem}
@media only screen and (max-width:767.9px){.reset-password-content{width:100%;box-shadow:none}
.reset-password-content-header{padding:1.25rem 0}
.rules{width:100%}
.btn-confirm{margin-bottom:1.25rem}
}
@media(min-width:768px){.reset-password-wrapper{max-width:81.875rem;margin:1rem auto}
}
.live-preview-nav{display:flex}
.live-preview-nav-item{text-align:center;cursor:pointer;font-size:.875rem;color:#666;letter-spacing:.07px}
.live-preview-nav-item-title{padding-bottom:1.125rem;border-bottom:1px solid #999;position:relative}
.live-preview-nav-item-title-point{position:absolute;background:#999;height:.5rem;width:.5rem;right:50%;bottom:0;transform:translateY(50%)}
.live-preview-nav-item-title:hover{border-bottom:1px solid #d7000f}
.live-preview-nav-item-title:hover .live-preview-nav-item-title-point{background:#d7000f}
.live-preview-nav-item-title:hover .live-preview-nav-item-title-text{color:#d7000f}
.live-preview-nav-item.active .live-preview-nav-item-title{border-bottom:1px solid #d7000f}
.live-preview-nav-item.active .live-preview-nav-item-title-point{background:#d7000f}
.live-preview-nav-item.active .live-preview-nav-item-title-text{color:#d7000f}
.live-preview-carousel-wrap{box-shadow:0 2px 14px 0 rgba(0,0,0,0.07);background:#fff;height:100%}
@media(max-width:767.98px){.live-preview-nav{display:block;padding:0}
.live-preview-nav-item-title:hover{border-bottom:1px solid #999}
.live-preview-nav-item-title:hover .live-preview-nav-item-title-point{background:#999}
.live-preview-nav-item-title:hover .live-preview-nav-item-title-text{color:#666}
.live-preview-nav-item.active .live-preview-nav-item-title{border-bottom:1px solid #999}
.live-preview-nav-item.active .live-preview-nav-item-title-point{background:#999}
.live-preview-nav-item.active .live-preview-nav-item-title-text{color:#666}
}
.live-preview-carousel{display:flex}
.live-preview-carousel-card{width:100%;padding:0 15px}
.live-preview-carousel-card-content{width:100%;background:#fff;box-shadow:0 2px 14px 0 rgba(0,0,0,0.07);border-radius:4px;text-align:left;outline:0;display:block;overflow:hidden}
.live-preview-carousel-card-content:hover{text-decoration:none}
.live-preview-carousel-card-content-img{width:100%;background-size:100% 100%;padding-top:calc(100% * 9 / 16);height:auto}
.live-preview-carousel-card-content-title{font-size:1rem;color:#333;letter-spacing:.08px;line-height:1.375rem;font-weight:600;padding-left:1rem;margin-top:1rem;height:1.375rem;white-space:normal;text-overflow:ellipsis;height:auto;margin-bottom:.5rem;padding-right:1rem}
.live-preview-carousel-card-content-desc{font-size:.875rem;color:#2a2e2e;letter-spacing:.07px;padding-left:1rem;white-space:normal;text-overflow:ellipsis;overflow:hidden;word-break:break-word;background-color:#fff;padding-right:1rem}
.live-preview-carousel-card-content-desc .live-preview-carousel-card-content{width:100%;background:#fff;box-shadow:none;border-radius:4px;padding-bottom:0rem;text-align:left;outline:0;display:block;color:#333;overflow:hidden}
.live-preview-carousel-card-content-desc .live-preview-carousel-card-content{width:100%;background:#fff;box-shadow:none;border-radius:0;padding-bottom:0;text-align:inherit;outline:0;display:block;overflow:hidden}
.live-preview-carousel-card-content-date{font-size:.875rem;color:#999;letter-spacing:.07px;padding-left:1rem;height:21px;background-color:#fff;padding-bottom:2rem}
@media(max-width:767.98px){.live-preview-carousel{display:block}
.live-preview-carousel-card-content-desc{padding-right:.625rem}
}
.live-preview-content{padding-bottom:15px}
.live-preview-content .live-preview-header{color:#333;display:flex;justify-content:space-between;padding:1.875rem 15px}
.live-preview-content .live-preview-header-title{font-size:1.5rem;letter-spacing:.12px;font-weight:800}
.live-preview-content .live-preview-header-all{font-size:.875rem;letter-spacing:.07px;line-height:2.25rem;color:#333}
.live-preview-content .live-preview-header-all span{margin-right:10px}
.live-preview-content .live-preview-list .live-preview-btn{position:absolute;top:50%;transform:translateY(-50%);background-color:rgba(242,242,242,0.4);opacity:1;z-index:10;width:2rem;height:5rem;border:0}
.live-preview-content .live-preview-list .live-preview-btn span{width:0;height:0;border-top:10px solid transparent;border-right:15px solid #fff;border-bottom:10px solid transparent;display:inline-block}
.live-preview-content .live-preview-list .live-preview-btn.slick-next{right:13px}
.live-preview-content .live-preview-list .live-preview-btn.slick-prev{left:15px}
.live-preview-content .live-preview-list .live-preview-btn.slick-next span{border-left:15px solid #fff;border-right:0}
.live-preview-content .live-preview-list .live-preview-item{display:none}
.live-preview-content .live-preview-item{margin-top:15px}
.live-preview-content .live-preview-item.active{display:block}
.live-preview-content .live-preview-btn:focus{outline:0;box-shadow:none}
@media(max-width:767.98px){.live-preview-content .live-preview-btn{position:absolute;z-index:10;top:-10px}
.live-preview-content .live-preview-btn.slick-next{right:0}
.live-preview-carousel-card{padding:0;margin-top:15px}
}
.live-preview-wrapper{max-width:81.875rem;margin:0 auto}
.live-review-filter-wrapper{display:flex;justify-content:space-between}
.live-review-filter-wrapper-inner{display:none;padding-right:0;padding-left:0;width:100%}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-filter-dropdown-type{position:relative;font-size:16px;color:#333;font-weight:400;padding-right:22px;line-height:22px}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-filter-dropdown-type:hover{color:#d7150e;cursor:pointer}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-filter-dropdown-type.active{color:#d7150e}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review--dropdown-container{position:relative;margin-right:60px}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-dropdown-list{display:none;position:absolute;top:32px;width:259px;max-height:340px;overflow-y:auto;left:0;background:#fff;padding:12px 0;box-shadow:0 5px 12px 0 rgba(0,0,0,0.16);border-top-left-radius:8px;border-bottom-left-radius:8px;z-index:999}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-dropdown-list.active{display:block}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-dropdown-list::-webkit-scrollbar{width:8px}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-dropdown-list::-webkit-scrollbar-track{width:8px;background-color:#f8f8f8}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-dropdown-list::-webkit-scrollbar-thumb{width:8px;background-color:#c9c9c9}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-dropdown-list .live-review-dropdown-primary{padding:8px 20px;font-size:14px;line-height:19px;color:#333;letter-spacing:0;font-weight:400;cursor:pointer}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-dropdown-list .live-review-dropdown-primary.only-useless{display:none}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-dropdown-list .live-review-dropdown-primary:hover{color:#666}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-dropdown-list .live-review-dropdown-primary.active{background-color:#f5f5f5}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-dropdown-list .newsroom-dropdown-title{padding:6px 20px;font-size:14px;line-height:19px;color:#666;letter-spacing:0;font-weight:400;cursor:not-allowed}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-dropdown-list .newsroom-dropdown-sub{padding:6px 36px;font-size:14px;line-height:19px;color:#333;letter-spacing:0;font-weight:400}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-dropdown-list .newsroom-dropdown-sub:hover{color:#666}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-dropdown-list .newsroom-dropdown-sub.active{background-color:#f5f5f5}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-filter-dropdown-type::after{content:'';position:absolute;right:0;top:0;display:inline-block;pointer-events:none;background:center / contain no-repeat url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-arrow-newsroom.svg');height:100%;width:10px;transition:all .1s}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-filter-dropdown-type:hover::after{background-image:url("https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-arrow-red-newsroom.svg")}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-filter-dropdown-type.active::after{background-image:url("https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-arrow-red-newsroom.svg")}
.live-review-filter-wrapper .live-review-filter-wrapper-inner .live-review-filter-dropdown-type.collpse::after{transform:rotate(180deg)}
.live-review-filter-wrapper-inner .live-review-filter-select{background:0}
.live-review-filter-wrapper-inner .live-review-filter-select .dropdown-toggle{border:1px solid #999;border-radius:16px;font-size:.875rem;color:#999;height:2rem;background:#fff;line-height:18px}
.live-review-filter-wrapper-inner .live-review-filter-select .dropdown-toggle:focus{outline:none !important}
.live-review-filter-wrapper-inner .live-review-filter-select .dropdown-toggle:after{color:#999}
.live-review-filter-wrapper-inner .live-review-filter-select .dropdown-toggle .filter-option-inner-inner{font-size:.875rem}
.live-review-filter-wrapper-inner .live-review-filter-select div.dropdown-menu{border:1px solid #999;border-radius:16px}
.live-review-filter-wrapper-inner .live-review-filter-select div.dropdown-menu .dropdown-item{font-size:.875rem;color:#333;outline:0}
.live-review-filter-wrapper-inner .live-review-filter-select div.dropdown-menu .dropdown-item.active,.live-review-filter-wrapper-inner .live-review-filter-select div.dropdown-menu .dropdown-item:active{background-color:#f3f5f7}
.live-review-filter-wrapper-inner .live-review-reset{font-size:16px;color:#094f9c;cursor:pointer}
.live-review-filter-wrapper-inner .live-review-reset:hover{text-decoration:underline}
@media(min-width:992px){.live-review-filter-wrapper-inner{display:flex}
}
.live-review-filter-wrapper-inner-mobile-btn{border:1px solid #999;border-radius:22px;height:2rem;text-align:center;max-width:186px;width:100%}
.live-review-filter-wrapper-inner-mobile-btn span{font-size:14px;color:#333;margin-left:5px;line-height:2rem}
.live-review-filter-wrapper-inner-mobile-content{position:fixed;width:100%;top:0;left:0;z-index:999;background:#fff;overflow-y:scroll;display:none;max-height:590px;overflow:hidden;padding-bottom:70px}
.live-review-filter-wrapper-inner-mobile-content .srcoll-bar-div{width:100%;max-height:501px;padding:0 .75rem;overflow-y:auto}
.live-review-filter-wrapper-inner-mobile-content .srcoll-bar-div::-webkit-scrollbar{width:6px}
.live-review-filter-wrapper-inner-mobile-content .srcoll-bar-div::-webkit-scrollbar-track{border-radius:10px;width:6px;background-color:#eee}
.live-review-filter-wrapper-inner-mobile-content .srcoll-bar-div::-webkit-scrollbar-thumb{border-radius:10px;background-color:#c1c1c1;width:6px}
.live-review-filter-wrapper-inner-mobile-content.active{display:block}
.live-review-filter-wrapper-inner-mobile-content-btn{display:flex;position:absolute;left:0;right:0;bottom:0;height:2.75rem;font-size:15px;color:#333;text-align:center;line-height:2.75rem;background:#fff;z-index:99999}
.live-review-filter-wrapper-inner-mobile-content-reset{width:50%;border-top:1px solid #eaeaea}
.live-review-filter-wrapper-inner-mobile-content-confirm{width:50%;background:#f02c38;color:#fff}
.live-review-filter-wrapper-inner-mobile-header{margin:15px 0 0;display:flex;justify-content:space-between;padding:0 10px}
.live-review-filter-wrapper-inner-mobile-header span{font-size:14px;font-weight:800;color:#333}
.live-review-filter-wrapper-inner-mobile-header-close img{height:12px;width:12px}
.live-review-filter-wrapper-inner-mobile-option-header{position:relative;border-bottom:1px solid #eaeaea;font-size:.875rem;color:#333;padding:15px 0;line-height:1.25;cursor:pointer}
.live-review-filter-wrapper-inner-mobile-option-header::after{width:12px;height:12px;position:absolute;content:"";right:0;top:50%;background-repeat:no-repeat;transform:translateY(-50%);background-image:url("https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-open-black.svg")}
.live-review-filter-wrapper-inner-mobile-option-list{display:none;background:#f5f5f5;padding:0 .75rem}
.live-review-filter-wrapper-inner-mobile-option-item{font-size:14px;color:#333;line-height:1.25;padding-top:15px;cursor:pointer;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;position:relative}
.live-review-filter-wrapper-inner-mobile-option-item:nth-last-of-type(1){padding-bottom:15px}
.live-review-filter-wrapper-inner-mobile-option-item::after{position:absolute;width:16px;height:16px;top:15px;right:0;content:" ";background-color:#fff;display:inline-block;visibility:visible;border-radius:2px;border-radius:8px;border:1px solid #a0a0a0}
.live-review-filter-wrapper-inner-mobile-option-item.selected::after{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-radio-checked.svg');background-repeat:no-repeat;background-position:center;background-size:16px 16px;border:0}
.live-review-filter-wrapper-inner-mobile-option.active .live-review-filter-wrapper-inner-mobile-option-list{display:block}
.live-review-filter-wrapper-inner-mobile-option.active .live-review-filter-wrapper-inner-mobile-option-header{border-bottom:1px solid #f5f5f5}
.live-review-filter-wrapper-inner-mobile-option.active .live-review-filter-wrapper-inner-mobile-option-header::after{background-image:url("https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-close-black.svg")}
.live-review-filter-wrapper-inner-mobile-bg{width:100%;height:100%;position:fixed;background:rgba(0,0,0,0.4);z-index:21;top:0;right:0;left:0;bottom:0;display:none}
.live-review-filter-wrapper-inner-mobile-bg.active{display:block}
@media(min-width:992px){.live-review-filter-wrapper-inner-mobile{display:none}
}
.live-review-filter-wrapper-search{border-radius:16px;padding-left:.75rem;height:2rem;display:flex;position:relative}
.live-review-filter-wrapper-search .close-search{position:absolute;right:10px;top:10px;width:12px;height:12px;cursor:pointer;display:none}
.live-review-filter-wrapper-search-ipt{font-size:16px;color:#333;border:0;outline:0;width:75px;position:relative;top:-1px;background:0}
.live-review-filter-wrapper-search.focus-active-search .live-review-filter-wrapper-search-ipt{width:245px;border-bottom:1px solid #999;transition:width .5s}
.live-review-filter-wrapper-search.focus-active-search .live-review-filter-wrapper-search-icon{display:none}
.live-review-filter-wrapper-search.focus-active-search .close-search{display:block}
.live-review-filter-wrapper-search-ipt::-webkit-input-placeholder{color:#333}
.live-review-filter-wrapper-search-ipt:-moz-placeholder{color:#333;opacity:1}
.live-review-filter-wrapper-search-ipt::-moz-placeholder{color:#333;opacity:1}
.live-review-filter-wrapper-search-ipt:-ms-input-placeholder{color:#333}
.live-review-filter-wrapper-search-ipt::-ms-input-placeholder{color:#333}
.live-review-filter-wrapper-search-ipt::placeholder{color:#333}
.focus-active-search .live-review-filter-wrapper-search-ipt::-webkit-input-placeholder{color:#999}
.focus-active-search .live-review-filter-wrapper-search-ipt:-moz-placeholder{color:#999;opacity:1}
.focus-active-search .live-review-filter-wrapper-search-ipt::-moz-placeholder{color:#999;opacity:1}
.focus-active-search .live-review-filter-wrapper-search-ipt:-ms-input-placeholder{color:#999}
.focus-active-search .live-review-filter-wrapper-search-ipt::-ms-input-placeholder{color:#999}
.focus-active-search .live-review-filter-wrapper-search-ipt::placeholder{color:#999}
.live-review-filter-wrapper-search-icon{padding-right:1rem;cursor:pointer}
.live-review-filter-wrapper-search-icon img{height:1rem;width:1rem}
.live-review-card{width:100%;height:auto;background:#fff;box-shadow:0 2px 14px 0 rgba(0,0,0,0.07);border-radius:4px;margin-bottom:1.75rem;padding-bottom:1.375rem}
.live-review-list .cursor{cursor:pointer}
.live-review-card-img-container{position:relative;padding-top:calc(100% * 9 / 16);height:auto;width:100%;overflow:hidden}
.live-review-card-img{position:absolute;transition:all .5s;background-size:100% 100%;padding-top:calc(100% * 9 / 16);height:auto;width:100%;left:0;top:0}
.live-review-card-img-container:hover .live-review-card-img{transform:scale(1.1,1.1);transition:all .5s}
.live-review-card-play{display:block;position:absolute;margin:0 auto;width:58px;height:42px;background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-video-play.svg');cursor:pointer;top:50%;left:50%;transform:translate(-50%,-50%)}
.live-review-card-play:hover{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-video-play-hover.svg')}
.live-review-card-title{font-size:1rem;color:#333;letter-spacing:.08px;line-height:1.375rem;font-weight:600;padding-left:1rem;margin-top:1rem}
.live-review-card-desc{font-size:.875rem;color:#2a2e2e;letter-spacing:.07px;padding-left:1rem;padding-right:.875rem;margin:.5rem 0}
.live-review-card-date{font-size:.875rem;color:#999;letter-spacing:.07px;padding-left:1rem}
.live-review-content{margin-top:20px;padding-bottom:20px}
.live-review-content .live-review-header{color:#333;display:flex;justify-content:space-between;padding:0 15px 20px}
.live-review-content .live-review-header.end{justify-content:end}
.live-review-content .live-review-header-title{font-size:1.5rem;letter-spacing:.12px;font-weight:800}
.live-review-content .live-review-header-all{font-size:.875rem;letter-spacing:.07px;color:#333}
.live-review-content .live-review-header-all span{margin-right:10px}
.live-review-content .live-review-list{margin-top:20px;display:flex;flex-wrap:wrap}
.live-review-content .live-review-list .no-result_div{display:none;margin:20px auto 0;text-align:center}
.live-review-content .live-review-list .no-result_div img{width:240px}
.live-review-list .modal{z-index:10000}
.live-review-list .modal-header{padding:0;border:0}
.live-review-list .modal-body{padding:0}
.live-review-list .modal-header .close{position:absolute;right:20px;top:10px;z-index:100}
.live-review-list .hide,.live-review-list.hide{display:none}
.live-review-filter-wrapper-inner .dropdown-toggle .filter-option-inner-inner{text-overflow:ellipsis;white-space:nowrap}
.live-review-filter-wrapper-inner .dropdown-menu{width:100%;font-size:.75rem}
.live-review-filter-wrapper-inner .dropdown-menu li a{padding:.25rem .75rem}
.live-review-filter-wrapper-inner .dropdown-menu li a span.text{width:100%;display:block;overflow:hidden;text-overflow:ellipsis;white-space:pre-wrap}
.live-review-filter-wrapper-inner .btn-light{background-color:#fff;border:1px solid #ced4da;border-radius:.25rem;height:2rem}

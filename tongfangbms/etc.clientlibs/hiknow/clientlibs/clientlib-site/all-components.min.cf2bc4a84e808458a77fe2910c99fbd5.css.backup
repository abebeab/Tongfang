.solutions-scenario-gallery-comp .element-grid .image{width:100%;height:136px;overflow:hidden;background-size:cover;transition:transform .4s}
.solutions-scenario-gallery-comp .element-grid>a:hover .image{transform:scale(1.1)}
.solutions-scenario-gallery-comp .element-grid .image img{width:100%;height:100%;transition:transform .4s}

.sticky-switch-wrapper{width:100%;padding:0 30px}
.sticky-switch-wrapper.sticky{position:fixed;top:0;left:0;width:100%;z-index:99}
.sticky-switch-wrapper.background-color-white{background-color:#fff;box-shadow:0 4px 16px 0 rgba(0,0,0,0.06)}
.sticky-switch-wrapper.background-color-white .tabs-wapper .tabs-section .tab-item .tab-title{color:#666;opacity:1}
.sticky-switch-wrapper.background-color-white .tabs-wapper .tabs-section .tab-item:not(.active):hover{background-color:#f5f5f5}
.sticky-switch-wrapper.background-color-white .tabs-wapper .tabs-section .tab-item:not(.active):hover .tab-title{opacity:1;color:#333}
.sticky-switch-wrapper.background-color-white .tabs-wapper .tabs-section .tab-item.active .tab-title{color:#333}
.sticky-switch-wrapper.background-color-black{background-color:#1e2020;color:#fff;box-shadow:0 4px 16px 0 rgba(0,0,0,0.25)}
.sticky-switch-wrapper.background-color-black .tab-container .prev-btn,.sticky-switch-wrapper.background-color-black .tab-container .next-btn{background-color:#1e2020}
.sticky-switch-wrapper.background-color-black .tab-container .prev-btn::after,.sticky-switch-wrapper.background-color-black .tab-container .next-btn::after{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-tab-arrow-white.svg')}
.sticky-switch-wrapper.background-color-black .tab-container .prev-btn{box-shadow:15px 0 26px 0 #1e2020}
.sticky-switch-wrapper.background-color-black .tab-container .next-btn{box-shadow:-15px 0 26px 0 #1e2020}
.sticky-switch-wrapper.background-color-black .tabs-wapper .tabs-section .tab-item{color:#fff}
.sticky-switch-wrapper.background-color-black .tabs-wapper .tabs-section .tab-item:not(.active):hover{background-color:#121414}
.sticky-switch-wrapper.background-color-black .tabs-wapper .tabs-section .tab-item:not(.active):hover .tab-title{opacity:1}
.sticky-switch-wrapper .sticky-switch-content{width:100%;max-width:1310px;margin:0 auto;text-align:center;line-height:0}
.sticky-switch-wrapper .tab-container{display:inline-block;position:relative;max-width:100%}
.sticky-switch-wrapper .tab-container .prev-btn,.sticky-switch-wrapper .tab-container .next-btn{background-color:#fff;display:block;width:44px;height:100%;position:absolute;top:0;bottom:0;margin:auto;z-index:2}
.sticky-switch-wrapper .tab-container .prev-btn::after,.sticky-switch-wrapper .tab-container .next-btn::after{content:'';display:block;width:20px;height:20px;background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-tab-arrow-black.svg');background-position:center;background-size:auto;background-repeat:no-repeat;position:absolute}
.sticky-switch-wrapper .tab-container .prev-btn{left:0;right:auto;box-shadow:15px 0 26px 0 #fff}
.sticky-switch-wrapper .tab-container .prev-btn::after{left:50%;top:50%;transform:rotate(180deg) translate(50%,50%)}
.sticky-switch-wrapper .tab-container .next-btn{right:0;left:auto;box-shadow:-15px 0 26px 0 #fff}
.sticky-switch-wrapper .tab-container .next-btn::after{top:50%;right:50%;transform:translate(50%,-50%)}
.sticky-switch-wrapper .tab-container .swiper-button-disabled{display:none}
.sticky-switch-wrapper .tab-container.icon-style{height:auto}
.sticky-switch-wrapper .tab-container.icon-style .tabs-wapper .tabs-section .tab-item{padding:16px 13px;width:206px;height:auto;justify-content:start}
.sticky-switch-wrapper .tab-container.icon-style .tabs-wapper .tabs-section .tab-item .tab-title{align-items:flex-start}
.sticky-switch-wrapper .tab-container.icon-style .tabs-wapper .tabs-section .tab-item .tab-title::after{bottom:-16px}
.sticky-switch-wrapper .tab-container.icon-style .tabs-wapper .tabs-section .tab-item .tab-icon{width:68px;height:68px;background-position:center;background-size:100%;background-repeat:no-repeat;margin-bottom:8px}
.sticky-switch-wrapper.hide-icon .tab-container.icon-style .tabs-wapper .tabs-section .tab-item{padding:0 30px;width:auto;height:67px;max-width:240px;justify-content:center}
.sticky-switch-wrapper.hide-icon .tab-container.icon-style .tabs-wapper .tabs-section .tab-item .tab-title{align-items:center}
.sticky-switch-wrapper.hide-icon .tab-container.icon-style .tabs-wapper .tabs-section .tab-item .tab-title::after{bottom:0}
.sticky-switch-wrapper.hide-icon .tab-container.icon-style .tabs-wapper .tabs-section .tab-item .tab-icon{display:none}
@media(max-width:991px){.sticky-switch-wrapper.hide-icon .tab-container.icon-style .tabs-wapper .tabs-section .tab-item{padding:0 15px}
}
.sticky-switch-wrapper .tabs-wapper{text-align:center;display:inline-block;position:relative;width:100%;overflow:hidden}
.sticky-switch-wrapper .tabs-wapper .tabs-section{box-sizing:border-box;height:100%;display:flex;white-space:nowrap;position:relative;margin-bottom:0;padding:0}
.sticky-switch-wrapper .tabs-wapper .tabs-section .tab-item{width:auto;list-style:none;font-size:14px;font-weight:600;white-space:normal;height:67px;padding:0 30px;display:inline-flex;max-width:240px;align-items:center;justify-content:center;position:relative;flex-direction:column;cursor:pointer;line-height:22px;color:#333;text-decoration:none}
.sticky-switch-wrapper .tabs-wapper .tabs-section .tab-item .tab-title{opacity:.6;flex:1;position:relative;display:flex;align-items:center}
.sticky-switch-wrapper .tabs-wapper .tabs-section .tab-item .tab-title::after{content:'';width:100%;height:4px;position:absolute;bottom:0;left:0;display:none}
.sticky-switch-wrapper .tabs-wapper .tabs-section .tab-item.selected-color-blue.active .tab-title{opacity:1}
.sticky-switch-wrapper .tabs-wapper .tabs-section .tab-item.selected-color-blue.active .tab-title::after{display:block;background-color:#3894ff}
.sticky-switch-wrapper .tabs-wapper .tabs-section .tab-item.selected-color-red.active .tab-title{opacity:1}
.sticky-switch-wrapper .tabs-wapper .tabs-section .tab-item.selected-color-red.active .tab-title::after{display:block;background-color:#d7150e}
@media(max-width:991px){.sticky-switch-wrapper{padding:0}
.sticky-switch-wrapper .tab-container{max-width:100%}
.sticky-switch-wrapper .tab-container .prev-btn,.sticky-switch-wrapper .tab-container .next-btn{display:none}
.sticky-switch-wrapper .tab-container .tabs-wapper .tabs-section .tab-item{font-size:12px;line-height:17px;max-width:150px;padding:0 15px;height:57px}
.sticky-switch-wrapper .tab-container .tabs-wapper .tabs-section .tab-item:hover{background-color:transparent !important}
.sticky-switch-wrapper .tab-container.icon-style .tabs-wapper .tabs-section .tab-item{width:140px;padding:15px 10px;height:auto}
.sticky-switch-wrapper .tab-container.icon-style .tabs-wapper .tabs-section .tab-item .tab-icon{width:40px;height:40px}
.sticky-switch-wrapper.hide-icon .tab-container.icon-style .tabs-wapper .tabs-section .tab-item{height:57px}
}
.rtl .sticky-switch-wrapper .tab-container{direction:rtl}
.rtl .sticky-switch-wrapper .tab-container .prev-btn{right:0;left:auto;box-shadow:-15px 0 26px 0 #fff}
.rtl .sticky-switch-wrapper .tab-container .prev-btn::after{transform:rotate(0) translate(-50%,-50%)}
.rtl .sticky-switch-wrapper .tab-container .next-btn{right:auto;left:0;box-shadow:-15px 0 26px 0 #fff}
.rtl .sticky-switch-wrapper .tab-container .next-btn::after{transform:rotate(0) translate(50%,-50%)}
.rtl .sticky-switch-wrapper.background-color-black .tab-container .prev-btn{box-shadow:-15px 0 26px 0 #1e2020}
.rtl .sticky-switch-wrapper.background-color-black .tab-container .next-btn{box-shadow:-15px 0 26px 0 #1e2020}

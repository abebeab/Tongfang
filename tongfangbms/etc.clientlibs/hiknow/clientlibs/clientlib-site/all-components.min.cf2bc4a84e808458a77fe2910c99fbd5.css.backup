.hiktools-list-comp .no-result-found .no-result-text .topic{color:#333;font-size:16px;font-weight:600;margin-bottom:12px}
.hiktools-list-comp .no-result-found .no-result-text .description{color:#666;font-size:14px}
.hiktools-list-comp .loading-box{background:center / contain no-repeat url('../../../../etc/clientlibs/it/resources/images/gif-loading.gif');height:26px}
@media(min-width:992px){.hiktools-list-comp{background-color:transparent}
.hiktools-list-comp .hiktools-items-container{opacity:0;padding:0;display:flex;justify-content:space-between;flex-wrap:wrap}

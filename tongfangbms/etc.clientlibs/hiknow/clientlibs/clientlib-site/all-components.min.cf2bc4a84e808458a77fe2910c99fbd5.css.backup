.firmware-update-query-comp.hiddns-query-comp{width:100%;max-width:100%;padding:0 0 30px;background-color:#fff}
.hiddns-query-comp .firmware-image{width:100%;height:55vw;max-height:450px;background-size:cover;background-repeat:no-repeat}
.firmware-update-query-comp.hiddns-query-comp .query-title{width:auto;margin-top:20px}
.hiddns-query-comp .hiddns-query-btn{width:162px;height:32px;background:#d7150e;border-radius:16px;text-align:center;color:#fff;line-height:32px;font-size:14px;border:0;outline:0}
.hiddns-query-comp .hiddns-query-btn.disable{opacity:.5}
.firmware-update-query-comp.hiddns-query-comp .query-wrapper{padding:0 15px;box-sizing:border-box}
.firmware-update-query-comp.hiddns-query-comp .result-list-wrapper{padding:0 15px;box-sizing:border-box;max-width:1310px}
.firmware-update-query-comp.hiddns-query-comp .result-list-wrapper .list-table .table-row .table-cell.table-cell-long{word-break:normal}
.firmware-update-query-comp{max-width:1370px;padding:90px 30px 0;margin:0 auto}
.firmware-update-query-toast{width:560px;height:100px;display:flex;align-items:center;justify-content:center;font-size:16px;color:#333;background:#fff;box-shadow:0 4px 12px 0 rgba(0,0,0,0.16);position:fixed;margin:0 auto;left:0;right:0;top:50%;transform:translateY(-50%)}
.firmware-update-query-toast img{width:30px;height:30px;margin-right:16px}
.firmware-update-query-pagination{margin-top:24px;display:none}
.firmware-update-query-pagination .arrow{width:32px;height:32px;border-radius:2px;border:1px solid #ddd;display:inline-block;text-align:center;font-size:18px;color:#333;cursor:pointer}
.firmware-update-query-pagination .pagination-item{width:32px;height:32px;margin:0 4px;text-align:center}
.firmware-update-query-pagination .pagination-item a{font-size:14px;color:#333;cursor:pointer;line-height:32px}
.firmware-update-query-pagination .pagination-item a.active{font-weight:700;color:#d7150e}
.firmware-update-query-comp .query-title{width:200px;font-size:24px;color:#414141;font-weight:700;margin-bottom:30px}
.firmware-update-query-comp .checkbox-wrapper{display:flex;align-items:center;justify-content:center;margin-bottom:30px}
.firmware-update-query-comp .checkbox-wrapper .checkbox-item{display:flex;align-items:center;justify-content:center}
.firmware-update-query-comp .checkbox-wrapper .checkbox-item label{margin-bottom:0;margin-left:8px;font-size:14px;color:#333}
.firmware-update-query-comp .checkbox-wrapper .checkbox-item div.radio{display:none}

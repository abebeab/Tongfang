.assets-download-nav{display:block;border-bottom:0;padding:0 15px;border:1px solid #eaeaea;background-color:#fff}
.collapse-navigation{background:#fff}
.collapse-box{background:#fff;box-shadow:0 10px 10px 0 rgba(85,85,85,0.04)}
.assets-download-nav.title{border-top:0}
.assets-download-nav ul.sub-nav{padding-left:15px}
.collapse-title{font-family:OpenSansSemibold;font-size:16px;color:#333;border:1px solid #eaeaea;border-bottom:0;padding:19px;display:flex;justify-content:space-between;align-items:center;position:relative;background-image:linear-gradient(180deg,#f5f5f5 0,#fafafa 100%);border-bottom:0}

.rtl .assets-download-nav .nav-item .sub-nav{text-align:right}
@media(max-width:991px){.assets-download-nav{margin-bottom:10px}
.collapse-navigation{border:0}
.collapse-box{margin:0 15px}
.collapse-title{display:flex;padding:15px;justify-content:space-between;align-items:center;position:relative;background-image:linear-gradient(180deg,#f5f5f5 0,#fafafa 100%)}
.assets-download-nav .nav-item .main-nav,.assets-download-nav .nav-item .sub-nav .sub-item{line-height:44px}
.assets-download-nav .nav-item .main-nav .main-link{font-size:14px}
}

.hiktools-list-comp .hiktools-list-search-container .search-container .hiktools-search:focus:valid ~ .hiktools-search-btn{display:none}
.hiktools-list-comp .hiktools-list-search-container .mobile-filter-btn{cursor:pointer;border:1px solid #ccc;border-radius:22px;flex:0 0 auto;font-size:12px;color:#666;line-height:22px;min-width:75px;padding:4px 12px 4px 34px;position:relative}
.hiktools-list-comp .hiktools-list-search-container .mobile-filter-btn::after{content:'';background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-newsroom-filter.svg');background-size:contain;background-repeat:no-repeat;background-position:center;height:100%;width:15px;position:absolute;left:10px;top:0}
.hiktools-list-comp .hiktools-list-search-container .mobile-filter-btn.has-filtered::after{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-newsroom-filter-active.svg')}
.hiktools-list-comp .hiktools-list-filter-bar{background-color:#fff;display:none;line-height:20px;font-size:14px;color:#333;padding:15px 15px 20px 15px;width:100%}
.hiktools-list-comp .hiktools-list-filter-bar.mobile-active{display:block;max-height:508px;overflow:auto;position:fixed;top:0;left:0;z-index:10002}
.hiktools-list-comp .hiktools-list-filter-bar .expand-icon{display:none}
.hiktools-list-comp .hiktools-list-filter-bar .close-icon{position:absolute;right:15px;top:15px;width:16px;z-index:1}
.hiktools-list-comp .hiktools-list-filter-bar .filter-title{font-weight:500;opacity:.9}
.hiktools-list-comp .hiktools-list-filter-bar .filter-title .colon{display:none}

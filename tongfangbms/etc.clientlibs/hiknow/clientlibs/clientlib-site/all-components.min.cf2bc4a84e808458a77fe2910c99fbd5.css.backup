.feature-gallery-comp .feature-gallery-container .feature-gallery-col .feature-gallery-item .gallery-mask,.feature-gallery-comp .feature-gallery-container .feature-gallery-col .feature-gallery-item .gallery-mask-bottom{transition:all .5s;position:absolute;z-index:-1;background-image:linear-gradient(270deg,#d7000f 0,#ee3343 100%);background-repeat:no-repeat;background-size:100% 100%;height:160px}
.feature-gallery-comp .feature-gallery-container .feature-gallery-col .feature-gallery-item .gallery-mask .gallery-mask-icon,.feature-gallery-comp .feature-gallery-container .feature-gallery-col .feature-gallery-item .gallery-mask-bottom .gallery-mask-icon{display:none;height:165px;background-repeat:no-repeat;background-size:100% 100%;position:absolute;width:250px;top:-20px;right:0;animation:none;z-index:0;background-position-x:calc(100% + 30px)}
.feature-gallery-comp .feature-gallery-container .feature-gallery-col .feature-gallery-item .gallery-mask .fade-in,.feature-gallery-comp .feature-gallery-container .feature-gallery-col .feature-gallery-item .gallery-mask-bottom .fade-in{opacity:0;animation:animate 1s ease !important}
.feature-gallery-comp .feature-gallery-container .feature-gallery-col .feature-gallery-item .gallery-mask .gallery-mask-content,.feature-gallery-comp .feature-gallery-container .feature-gallery-col .feature-gallery-item .gallery-mask-bottom .gallery-mask-content{display:none;transition:all .5s;animation:none;padding:0 20px;height:160px;position:absolute;bottom:20px}
.feature-gallery-comp .feature-gallery-container .feature-gallery-col .feature-gallery-item .gallery-mask .gallery-mask-content .mask-content-title,.feature-gallery-comp .feature-gallery-container .feature-gallery-col .feature-gallery-item .gallery-mask-bottom .gallery-mask-content .mask-content-title{font-size:16px;font-weight:600;line-height:1.375;color:#fff;letter-spacing:0;margin-bottom:13px}

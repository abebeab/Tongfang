.product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-cascader .product-selectionTools-specCascader .hik-select label.label-title.focus{font-size:12px;top:-6px;background-color:#fff}
.product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-cascader .product-selectionTools-specCascader .hik-select label.error{color:#d7150e;font-size:12px}
.product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-cascader .product-selectionTools-specCascader .filter-reset{min-width:69px;padding:0 12px;height:28px;line-height:28px;text-align:center;margin-left:24px;border:1px solid #DDD;border-radius:50px;font-family:'OpenSans-SemiBold';font-size:14px;cursor:pointer}
.product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-cascader .product-selectionTools-specCascader .filter-reset:hover{color:#d7150e;border-color:#d7150e}
.product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-cascader .product-nums{line-height:24px;font-size:16px;color:#333}
.product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-cascader .product-nums .product-nums-total{margin-right:8px}
.product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-sticky-filter-wrapper{width:27%;height:0;padding-right:30px;margin-top:40px}

.feature-gallery-comp .feature-gallery-container .feature-gallery-col .feature-gallery-item .gallery-mask .gallery-mask-content .mask-content-cta,.feature-gallery-comp .feature-gallery-container .feature-gallery-col .feature-gallery-item .gallery-mask-bottom .gallery-mask-content .mask-content-cta{margin-top:12px}

.media-wrapper-wrapper .media-wrapper-img-wrap .media-img-item.active .item-desc,.media-wrapper-wrapper .media-wrapper-img-wrap .media-img-item.active .media-wrapper-video,.media-wrapper-wrapper .media-wrapper-img-wrap .media-img-item.active .media-wrapper-img{display:block}
}

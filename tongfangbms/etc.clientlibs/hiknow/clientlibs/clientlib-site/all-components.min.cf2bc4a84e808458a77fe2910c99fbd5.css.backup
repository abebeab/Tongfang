.ir-title-comp .title::before{top:3px}
}
.ir-kpi-spotlight-comp .ir-table-comp .toggle-chart{display:inline-block;width:42px;height:20px;padding-right:18px;cursor:pointer;position:relative;background:left / 24px 20px no-repeat url("https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-chart.svg")}
.ir-kpi-spotlight-comp .ir-table-comp .toggle-chart::after{content:'';position:absolute;right:0;top:50%;transform:translateY(-50%);width:8px;height:12px;background:center / contain no-repeat url("../../../../etc/clientlibs/it/resources/icons/icon-collapse-filled.png")}
.ir-kpi-spotlight-comp .ir-table-comp .expanded-row .toggle-chart::after{transform:translateY(-50%) rotate(180deg)}
.ir-kpi-spotlight-comp .ir-table-comp .chart-row{background-color:#fff}
.ir-kpi-spotlight-comp .ir-table-comp .chart-row td{padding:10px 0}
.ir-kpi-spotlight-comp .ir-table-comp .chart-row .chart{background-color:#f8f8f8}
.ir-kpi-spotlight-comp .chart{width:100%;height:400px;border:1px solid #eaeaea}
.ir-kpi-spotlight-comp .chart .tooltip-container{display:flex;align-items:center;justify-content:space-between;font-size:12px}
.ir-kpi-spotlight-comp .chart .tooltip-container .icon-container{display:flex;align-items:center;margin-right:10px}
.ir-kpi-spotlight-comp .chart .tooltip-container .bar-icon{display:inline-block;width:8px;height:8px;flex:0 0 8px;margin-right:10px;background-color:#656d7d}
.ir-kpi-spotlight-comp .chart .tooltip-container .red-icon{background-color:#d7150e}
@media screen and (max-width:991px){.ir-kpi-spotlight-comp .chart{height:360px}
.ir-kpi-spotlight-comp .chart .tooltip-container .icon-container{margin-right:0}
.ir-kpi-spotlight-comp .chart .tooltip-container .tooltip-name{display:none}
}
.ir-table-comp .table-container{overflow-x:scroll;scrollbar-width:none;-ms-overflow-style:none}
.ir-table-comp .table-container::-webkit-scrollbar{display:none}
.ir-table-comp table{width:100%}
.ir-table-comp table thead{font-size:14px;color:rgba(0,0,0,0.85);line-height:21px;font-weight:700}
.ir-table-comp table thead tr{background-color:#f5f5f5}
.ir-table-comp table tbody{font-size:14px;color:rgba(0,0,0,0.65);line-height:22px;font-weight:400}
.ir-table-comp table tbody tr.odd-row{background-color:#f5f5f5}
.ir-table-comp table tfoot{font-size:14px;color:#666;line-height:22px;font-weight:400}
.ir-table-comp table tfoot td:last-child{text-align:left}
.ir-table-comp table tr{border-bottom:1px solid #eaeaea}
.ir-table-comp table th,.ir-table-comp table td{height:54px;min-width:76px;text-align:center}
.ir-table-comp table th:first-child,.ir-table-comp table td:first-child{max-width:330px;text-align:left;padding-left:20px;padding-right:30px}
.ir-table-comp table th:last-child,.ir-table-comp table td:last-child{padding-right:20px;min-width:96px}
@media screen and (max-width:991px){.ir-table-comp{padding-right:15px;padding-left:15px}
.ir-table-comp table th,.ir-table-comp table td{min-width:80px}
.ir-table-comp table th:first-child,.ir-table-comp table td:first-child{min-width:130px;padding-left:16px;padding-right:16px}
}

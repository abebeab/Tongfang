.features-device-right{display:inline-block;text-align:center;width:100%;height:100%}
.features-device-right .video-box{position:relative;width:100%;height:100%}
.features-device-right .video-box .mask-video{position:absolute;height:100%;width:100%;left:0;background-repeat:no-repeat;background-size:cover;background-position:center;top:0}
.features-device-right .video-box .mask-video .mask-video-inline-box{position:relative;width:100%;height:100%}
.features-device-right .video-box .mask-video .mask-video-inline-box button.mask-ytp-button{position:absolute;width:68px;height:48px;top:50%;left:50%;transform:translate(-50%,-50%);border:0;background-color:transparent;padding:0;color:inherit;text-align:inherit;font-size:100%;font-family:inherit;cursor:default;line-height:inherit}
.features-device-right .video-box .mask-video .mask-video-inline-box button.mask-ytp-button .ytp-large-play-button-bg{-webkit-transition:fill .1s cubic-bezier(0.4,0.0,1,1),fill-opacity .1s cubic-bezier(0.4,0.0,1,1);transition:fill .1s cubic-bezier(0.4,0.0,1,1),fill-opacity .1s cubic-bezier(0.4,0.0,1,1);fill:#212121;fill-opacity:.8}

.hiktools-list-comp .hiktools-list-filter-bar .filter.active{color:#d7150e}
.hiktools-list-comp .hiktools-list-filter-bar .filter.active::after{content:'';background:center / contain no-repeat url('../../../../etc/clientlibs/it/resources/icons/icon-check-red.png');display:block;height:12px;position:absolute;right:0;top:18px;width:16px}
.hiktools-list-backdrop{background-color:#000;left:0;height:100vh;opacity:.5;position:fixed;top:0;width:100vw;z-index:10001}

.form-wrapper .mult-group.left .checkbox-inline.reason-btn i{display:block;position:absolute;top:3px;left:0;width:15px;height:15px;outline:0;border:1px solid #999;background:#fff;border-radius:50%;transition:border-color .3s;-webkit-transition:border-color .3s}
.form-wrapper .mult-group.left .checkbox-inline.reason-btn input+i:after{position:absolute;content:'';top:2px;left:2px;width:9px;height:9px;border-radius:50%;background-color:#d7150e;opacity:0;transition:opacity .1s;-webkit-transition:opacity .1s}

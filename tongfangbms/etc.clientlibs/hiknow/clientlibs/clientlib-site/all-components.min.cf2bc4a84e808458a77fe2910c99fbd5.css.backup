}
.assets-download-nav ul,.assets-download-nav li{list-style-type:none;margin:0;padding:0}
.assets-download-nav .nav-item .main-nav{border-bottom:1px solid #eaeaea;line-height:52px;position:relative}
.assets-download-nav .nav-item:nth-last-child(1) .main-nav{border-bottom:0}
.assets-download-nav .nav-item .main-nav .main-link{color:#333;display:inline-block;font-size:16px;font-weight:600;letter-spacing:.08px;line-height:30px;width:100%}
.assets-download-nav .nav-item .main-nav .main-link:hover{color:#d7150e;text-decoration:none}
.assets-download-nav .nav-item .main-nav .icon-collapse{background-image:url("../../../../etc/clientlibs/it/resources/icons/icon-asset-nav-less.png");background-size:contain;background-position:center;cursor:pointer;height:18px;position:absolute;right:0;top:50%;transform:translateY(-50%);width:18px}
.assets-download-nav .nav-item .main-nav .icon-collapse.collapsed{background-image:url("../../../../etc/clientlibs/it/resources/icons/icon-asset-nav-more.png")}
.assets-download-nav .nav-item .sub-nav .sub-item{border-bottom:1px solid #e0e0e0;line-height:42px}
.assets-download-nav .nav-item .sub-nav .sub-item .sub-link{color:#333;font-size:14px;letter-spacing:.07px;line-height:30px;display:inline-block;width:100%}
.assets-download-nav .nav-item .sub-nav .sub-item .sub-link:hover{color:#d7150e;text-decoration:none}
.rtl .assets-download-nav .nav-item .main-nav{padding:5px 20px 5px 40px;text-align:right}

.blog-filter-items .blog-filter-item-description{font-size:14px;color:#666;height:60px;letter-spacing:.07px;line-height:20px;overflow:hidden;text-overflow:ellipsis;-webkit-line-clamp:3;display:-webkit-box;-webkit-box-orient:vertical}

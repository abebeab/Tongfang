.Newsletter .enquiry-form-container #accordion .enquiry-checkbox1 input[type=checkbox]:after{transform:none;content:'';top:auto;left:auto;width:1rem;height:1rem;border:1px solid #ced4da;vertical-align:baseline;border-radius:0}

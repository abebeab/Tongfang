.ir-zone-division-comp .tooltip-container{display:flex;align-items:center;justify-content:space-between;font-size:12px;position:relative;flex-grow:0;flex-shrink:0;flex-basis:calc(33.33% - 20px)}
.ir-zone-division-comp .tooltip-container .icon-container{display:flex;align-items:center}

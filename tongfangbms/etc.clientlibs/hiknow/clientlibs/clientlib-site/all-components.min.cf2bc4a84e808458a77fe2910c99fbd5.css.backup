.eo-selection-cascader-panel{display:flex;position:absolute;top:40px;left:0;width:auto;height:296px;z-index:9999;overflow:hidden;display:none;box-shadow:0 5px 15px 0 rgba(0,0,0,0.17)}
.eo-selection-cascader-panel ul{padding:0;background-color:#fff}
.eo-selection-cascader-menu{width:214px;box-sizing:border-box;color:#333;border:1px solid #666;position:relative;background-color:#fff;overflow-y:scroll}
.eo-selection-cascader-menu::-webkit-scrollbar{width:4px}
.eo-selection-cascader-menu::-webkit-scrollbar-thumb{background-color:rgba(0,0,0,0.12);border-radius:2px}
.eo-selection-cascader-menu::-webkit-scrollbar-track{background-color:rgba(0,0,0,0)}
.eo-selection-cascader-menu::-webkit-scrollbar-button{display:none}
.eo-selection-cascader-panel ul::-webkit-scrollbar-corner{background-color:rgba(0,0,0,0.12)}
.eo-selection-cascader-menu:nth-of-type(1){border-top-left-radius:4px;border-bottom-left-radius:4px}
.eo-selection-cascader-menu:nth-of-type(2){left:-1px;border-left:1px solid #eaeaea}
.eo-selection-cascader-menu:nth-of-type(3){left:-2px;border-left:1px solid #eaeaea;border-top-right-radius:4px;border-bottom-right-radius:4px}
.eo-selection-cascader-menu .menu-title{height:22px;line-height:22px;padding:0 15px;margin:16px 0 11px;font-size:14px;font-family:'OpenSansBold'}
.eo-selection-cascader-menu li{width:100%;height:32px;line-height:32px;padding:0 28px 0 15px;position:relative;font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer}
.eo-selection-cascader-menu li.checked_li{background-color:#fbe7e6}
.eo-selection-cascader-menu li.has-child:after{content:">";position:absolute;right:10px;top:0;transform:scaleY(1.8);font-size:12px;color:#606266}
.eo-selection-cascader-menu li:not(.checked_li):hover{background:#f5f5f5}
.eo-selection-checked-wrap{position:relative;display:flex;width:calc(100% - 35px);height:38px;padding:5px;pointer-events:none}
.eo-selection-checked-wrap ul{display:flex;align-items:center;width:100%;padding:0;padding-left:7px;margin:0}
.eo-selection-checked-wrap li{width:100%;line-height:18px;font-size:14px;box-sizing:border-box;list-style:none}
.eo-selection-checked-wrap li p{margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;direction:ltr}
.selection-cascader-wrap.is-show{border-color:#666}
.rtl .eo-selection-cascader-menu .menu-title{text-align:right}
.rtl .selection-cascader-wrap:after{right:auto;left:10px}
.rtl .eo-selection-checked-wrap{padding-right:12px;text-align:right;pointer-events:none}
.rtl .eo-selection-cascader-panel{right:0;left:auto}
.rtl .eo-selection-cascader-menu li{text-align:right;padding:0 15px 0 28px}
.rtl .eo-selection-cascader-menu li.has-child:after{right:auto;left:10px}
h2.h2-seo,h3.h3-seo,h4.h4-seo{display:inline;font-size:inherit;font-weight:inherit;font-family:inherit;color:inherit;line-height:1;margin:0;padding:0}
.hilook-page .product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-spec .result-grid-layout4-wrapper .product-blank-page .product-blank-title{font-family:'TStarHeavy'}
.hilook-page .product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-spec .result-grid-layout4-wrapper .product-blank-page .product-blank-tip{font-family:'TStarRegular'}
.hilook-page .product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-spec .result-grid-layout4-wrapper .layout4-wrapper .layout4-content-wrapper .btn-details-link .layout-image-text-wrapper .result_info_wrapper .tag{font-family:'TStarHeavy'}
.hilook-page .product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-spec .result-grid-layout4-wrapper .layout4-wrapper .layout4-content-wrapper .add-to-compare .compare-label{font-family:'TStarBold'}
.hilook-page .product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-spec .result-grid-layout4-wrapper .layout4-wrapper .result_info_text{font-family:'TStarBold'}
.hilook-page .product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-spec .product-selectionTools-sticky-filter-wrapper .filter-card .filter-card-header .card-link{font-family:'TStarBold'}
.product-selectionTools-comp{width:100%;background:#FFF;transition:height .1s}
.product-selectionTools-comp .product-selectionTools-filter-popup-mobile{display:none}
.product-selectionTools-comp .product-selectionTools-category-filter-popup-mobile{display:none}
.product-selectionTools-comp .product-selectionTools-header{display:flex;flex-direction:column;align-items:center;width:100%;padding:50px 0 40px;background:#f2f2f2}
.product-selectionTools-comp .product-selectionTools-header .product-selectionTools-header-title{line-height:55px;max-width:1370px;padding:0 30px;text-align:center;font-family:'OpenSansBold';font-size:40px;margin-bottom:24px}
.product-selectionTools-comp .product-selectionTools-header .product-selectionTools-header-description{line-height:24px;margin-bottom:24px;max-width:1370px;padding:0 30px;text-align:center}
.product-selectionTools-comp .product-selectionTools-header .search-input-box{width:778px;margin:0 auto;border:0;position:relative;overflow:hidden}
.product-selectionTools-comp .product-selectionTools-header .search-input-box input{width:100%;height:46px;border-radius:46px;outline:0;color:#333;font-size:16px;background:#fff;border:1px solid #d6d6d6;text-indent:24px}
.product-selectionTools-comp .product-selectionTools-header .search-input-box input:focus{background:#FFF;box-shadow:0 0 10px 0 rgba(0,0,0,0.09)}
.product-selectionTools-comp .product-selectionTools-header .search-input-box input::placeholder{color:#999}
.product-selectionTools-comp .product-selectionTools-header .search-input-box input::-webkit-input-placeholder{color:#999}
.product-selectionTools-comp .product-selectionTools-header .search-input-box input::-moz-placeholder{color:#999}
.product-selectionTools-comp .product-selectionTools-header .search-input-box input::-ms-input-placeholder{color:#999}
.product-selectionTools-comp .product-selectionTools-header .search-input-box .selectionTools-btn-search{position:absolute;top:13px;right:20px;width:20px;height:20px;border:0;outline:0;cursor:pointer}
.product-selectionTools-comp .product-selectionTools-header .search-input-box .selectionTools-btn-clear{position:absolute;display:none;top:13px;right:52px;width:20px;height:20px;color:#999;border:0;outline:0;cursor:pointer}
.product-selectionTools-comp .product-selectionTools-header .search-input-box .selectionTools-btn-clear_visible{display:block}
.product-selectionTools-comp .product-selectionTools-filter-mobile-comp{display:none}
.product-selectionTools-comp .filter-card{border:0;border-radius:0;background-color:#fff;border-bottom:1px solid #eaeaea}
.product-selectionTools-comp .filter-card:first-child .filter-card-header{padding-top:0}
.product-selectionTools-comp .filter-card .filter-card-header{display:flex;justify-content:space-between;align-items:center;background-color:#fff;margin-left:0;padding:16px 0;font-size:1rem;border:0;cursor:pointer}
.product-selectionTools-comp .filter-card .filter-card-header .card-link{font-family:OpenSansSemiBold;font-size:16px;color:#505050;letter-spacing:0;font-weight:600;max-width:270px;display:inline-block}
.product-selectionTools-comp .filter-card .filter-card-header .fold-icon{width:12px;height:12px;color:#333;flex-shrink:0}
.product-selectionTools-comp .filter-card .filter-card-header .fold-icon.active{color:#d7150e}
.product-selectionTools-comp .filter-card .filter-card-header .unfold{display:block}
.product-selectionTools-comp .filter-card .filter-card-header .fold{display:none}
.product-selectionTools-comp .filter-card .filter-card-header.collapsed .fold{display:block}
.product-selectionTools-comp .filter-card .filter-card-header.collapsed .unfold{display:none}
.product-selectionTools-comp .filter-card .filter-card-header:hover{font-weight:600}
.product-selectionTools-comp .filter-card .filter-card-header:active{font-weight:600}
.product-selectionTools-comp .filter-card .checkbox-left{list-style-type:none;padding-left:0;font-size:16px}
.product-selectionTools-comp .filter-card .checkbox-left label{flex:1;padding-left:12px;line-height:19px;font-size:14px;letter-spacing:0;font-weight:400;margin-bottom:0;color:#333;word-break:break-word;cursor:pointer}
.product-selectionTools-comp .filter-card .checkbox-left .filter-tip{background-position:center;background-size:contain;background-repeat:no-repeat;display:inline-block;min-width:15px;width:15px;height:24px;line-height:24px;margin:0 8px;color:transparent;user-select:none;position:relative}
.product-selectionTools-comp .filter-card .checkbox-left .tip-text{position:absolute;white-space:nowrap;background-color:#fff;color:#333;font-size:12px;border:1px solid rgba(0,0,0,0.11);box-shadow:0 0 7px 0 rgba(0,0,0,0.14);padding:2px 10px;left:50%;transform:translateX(-50%);bottom:calc(100% + 5px)}
.product-selectionTools-comp .filter-card .checkbox-left .tip-text::before{box-shadow:-1px 1px 3px -2px;content:'';height:8px;width:8px;position:absolute;left:calc(50% - 4px);bottom:-5px;border-left:1px solid rgba(0,0,0,0.15);border-bottom:1px solid rgba(0,0,0,0.15);background-color:#fff;transform:rotate(-45deg)}
.product-selectionTools-comp .filter-card input[type=checkbox]{position:relative;width:16px;height:14px;cursor:pointer;-moz-appearance:none;appearance:none}
.product-selectionTools-comp .filter-card input[type=radio]{width:16px;height:16px;background:#FFF;border:1px solid #ddd;cursor:pointer;-moz-appearance:none;appearance:none;position:relative;border-radius:50%;transform:translateY(3px)}
.product-selectionTools-comp .filter-card input[type=radio]:hover{border-color:#d7150e}
.product-selectionTools-comp .filter-card input[type=radio]:checked{width:16px;height:16px;background:#FFF;border:1px solid #d7150e;cursor:pointer;-moz-appearance:none;appearance:none;position:relative;border-radius:50%}
.product-selectionTools-comp .filter-card input[type=radio]:checked::after{content:" ";width:10px;height:10px;background:#d7150e;position:absolute;left:2px;top:2px;border-radius:50%}
.product-selectionTools-comp .filter-card input[type=checkbox]:after{position:absolute;width:16px;height:16px;top:0;left:0;content:" ";background-color:#fff;display:inline-block;border-radius:2px;border:1px solid #a0a0a0}
.product-selectionTools-comp .filter-card input[type=checkbox]:hover:after{border-color:#d7150e}
.product-selectionTools-comp .filter-card input[type=checkbox]:checked:after{background-color:#d7150e;background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/images/icon-check-box-checked.svg');background-size:cover;border:0}
.product-selectionTools-comp .filter-card input[type=checkbox]:checked+.checked-icon{display:block;color:#fff}
.product-selectionTools-comp .filter-card .card-body{padding:0 0 4px}
.product-selectionTools-comp .filter-card .card-body ul{margin-bottom:0}
.product-selectionTools-comp .filter-card .card-body ul li{display:flex;flex-direction:row;align-items:baseline;cursor:pointer;position:relative;margin-bottom:12px}
.product-selectionTools-comp .filter-card .card-body ul li input[type=checkbox]{flex-shrink:0}
.product-selectionTools-comp .filter-card .card-body ul li input[type=radio]{flex-shrink:0}
.product-selectionTools-comp .product-selectionTools-filter-comp{min-height:298px;padding:20px 30px;max-width:1370px;margin:0 auto;background-color:#fff;transition:height .1s}
.product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-title{width:100%;line-height:54px;margin-top:60px;font-family:'OpenSansBold';font-size:40px;margin-bottom:40px}

.ir-profile-comp .profile .topic .name{font-size:14px;color:#333;letter-spacing:0;font-weight:600;margin-bottom:11px}
.ir-profile-comp .profile .topic .position{font-size:14px;color:#666;letter-spacing:0;font-weight:400}
.ir-profile-comp .profile .topic::after{content:'';position:absolute;top:50%;right:0;height:18px;width:18px;transform:translateY(-50%);background:center / contain no-repeat url("../../../../etc/clientlibs/it/resources/icons/icon-asset-nav-less.png")}

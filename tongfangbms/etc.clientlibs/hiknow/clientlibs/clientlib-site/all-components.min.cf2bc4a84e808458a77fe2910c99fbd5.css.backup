.chat-container .chat-body .search-result-item-wrapper .search-result-item-title a{line-height:24px}
.chat-container .chat-body .search-result-item-wrapper .search-result-item-title strong{color:#d7150e}
.chat-container .chat-body .search-result-item-wrapper .search-result-item-nav-wrapper{position:static !important;font-size:12px;line-height:18px;margin-top:12px}
.chat-container .chat-body .search-result-item-wrapper .search-result-item-nav-wrapper a{font-size:12px;line-height:18px}
.chat-container .chat-body .view-more{font-size:16px;line-height:36px;width:115px;height:36px;border:1px solid #ddd;text-align:center;border-radius:50px;position:absolute;left:50%;transform:translateX(-50%);cursor:pointer;z-index:999;margin-top:19px;display:none}
.chat-container .chat-body.right-result .chat-body-left{flex:2}
.chat-container .chat-body.right-result .chat-body-right{display:block}
.chat-container .chat-body .chat-docs{width:100%;max-height:332.3px;overflow:hidden}
.chat-container .chat-body .chat-docs .chat-doc-item-img{width:80px;height:60px}
.chat-message-ai think{color:#999;font-size:16px;line-height:24px;margin-bottom:10px;display:block}
.chat-message-ai .thinking-dots{display:inline-flex;gap:12px;padding:6px 12px;border-radius:12px}
.chat-message-ai .thinking-dots span{width:12px;height:12px;background:#ddd;border-radius:50%;animation:thinking 1.4s infinite}
.chat-message-ai .thinking-dots span:nth-child(2){animation-delay:.2s}
.chat-message-ai .thinking-dots span:nth-child(3){animation-delay:.4s}
.chat-message-ai:not(.chat-message-outout) .thinking-dots{display:none}
.chat-message img[alt='md_product_image']{width:60px}
.chat-message img[alt='md_download_icon']{width:14px;height:14px}
.chat-message img[alt='md_doc_icon']{width:32px;height:32px}
@keyframes thinking{0,100%{transform:translateY(0);opacity:.4}
50%{transform:translateY(-4px);opacity:1}
}
.chat-docs{width:100%}
.chat-docs .swiper{position:relative;height:auto}
.chat-docs .swiper .recommend-header{display:flex;margin-bottom:16px}
.chat-docs .swiper .recommend-header .recommend-title{font-weight:700;font-size:16px;line-height:24px;padding-left:20px;padding-right:20px}
.chat-docs .swiper .swiper-wrapper{display:flex;position:relative;height:auto;box-sizing:border-box;padding-bottom:10px;padding-left:20px;padding-right:15px;left:-20px}
.chat-docs .swiper .swiper-slide{width:calc(50% - 4px) !important;flex-shrink:0;height:auto;background:#fff;border-radius:4px;padding:12px;border:1px dashed rgba(0,0,0,0.3);padding:15px 20px 20px 20px;box-sizing:border-box;margin-right:8px}
@media only screen and (max-width:991px){.chat-docs .swiper .swiper-slide{width:calc(80% - 4px) !important}
}
.chat-docs .swiper .swiper-slide:last-child{margin-right:0}
.chat-docs .swiper .swiper-slide .product-name{display:flex;gap:15px;border-bottom:1px dashed rgba(0,0,0,0.3);align-items:center}
.chat-docs .swiper .swiper-slide .product-name.no-files{border-bottom:0}
.chat-docs .swiper .swiper-slide .product-name a{color:#333;font-size:16px;font-weight:600}
.chat-docs .swiper .swiper-slide .product-name .product-image{width:48px;height:48px;object-fit:cover;margin-right:12px}
.chat-docs .swiper .swiper-slide .product-files{margin-top:20px}
.chat-docs .swiper .swiper-slide .product-files:nth-of-type(n+5){display:none}
.chat-docs .swiper .swiper-slide .product-files a.product-file-link{font-size:14px;font-weight:400;line-height:22px;color:#333;width:90%;align-items:center;justify-content:space-around;word-break:break-all;position:relative;display:block}
.chat-docs .swiper .swiper-slide .product-files a.product-file-link svg{margin-right:-10px;position:absolute;right:-20px;top:5px}
.chat-docs .swiper .swiper-slide .product-files a:hover{color:#d7150e;text-decoration:none}
.chat-docs .swiper .swiper-button-prev,.chat-docs .swiper .swiper-button-next{width:65px;height:120%;top:0;margin:0;z-index:2;display:flex;align-items:center;justify-content:center}
.chat-docs .swiper .swiper-button-prev.swiper-button-disabled,.chat-docs .swiper .swiper-button-next.swiper-button-disabled{display:none}
.chat-docs .swiper .swiper-button-prev::after,.chat-docs .swiper .swiper-button-next::after{display:none}
.chat-docs .swiper .swiper-button-prev i,.chat-docs .swiper .swiper-button-next i{width:32px;height:32px;border:2px solid #eaeaea;border-radius:50%;display:flex;align-items:center;justify-content:center;background-color:#fff}
.chat-docs .swiper .swiper-button-prev i:hover,.chat-docs .swiper .swiper-button-next i:hover{background-color:#f2f2f2}
.chat-docs .swiper .swiper-button-prev i::after,.chat-docs .swiper .swiper-button-next i::after{content:'';width:8px;height:8px;border-style:solid;border-width:2px 2px 0 0;border-color:#333}
.chat-docs .swiper .swiper-button-prev{left:0;background:linear-gradient(90deg,#fff 80%,rgba(255,255,255,0) 100%)}
.chat-docs .swiper .swiper-button-prev i::after{transform:rotate(-135deg);margin-left:3px}
.chat-docs .swiper .swiper-button-next{right:0;background:linear-gradient(-90deg,#fff 80%,rgba(255,255,255,0) 100%)}
.chat-docs .swiper .swiper-button-next i::after{transform:rotate(45deg);margin-right:3px}
.chat-container #layout-pagination-wrapper{padding:0}
.chat-container #layout-pagination-wrapper span{padding:0 15px;color:#333;font-size:14px !important}
.chat-container #layout-pagination-wrapper span:hover{color:#d7150e}
.chat-container #layout-pagination-wrapper .current{color:#d7150e}
.chat-container #layout-pagination-wrapper .prev,.chat-container #layout-pagination-wrapper .next{border-radius:4px !important;display:inline-block;border:1px solid #ddd;font-size:18px !important;line-height:28px !important;height:31px;text-align:center;width:31px;float:none !important;font-weight:400 !important;padding:0 !important}
.chat-container #layout-pagination-wrapper .prev{margin-right:8px}
.chat-container #layout-pagination-wrapper .next{margin-left:8px}
.chat-container #layout-pagination-wrapper li:not(.disabled) .next:hover,.chat-container #layout-pagination-wrapper li:not(.disabled) .prev:hover{background-color:transparent;color:#d7150e !important}
.chat-container .chat-body .html-wrapper .search-result-item-wrapper .search-result-item-image{width:300px;height:168px;margin-right:40px}
.chat-container .chat-body .html-wrapper .search-result-item-wrapper .search-result-item-title{font-size:16px;font-weight:700}
.chat-container .chat-body .html-wrapper .search-result-item-wrapper .search-result-item-content .search-result-item-desc{font-size:14px;line-height:24px;margin-top:20px;-webkit-line-clamp:3}
.chat-container .chat-body .html-wrapper .search-result-item-wrapper .search-result-item-content{margin:32px 0}
@media only screen and (max-width:1440px){.chat-container .chat-body .html-wrapper .search-result-item-wrapper .search-result-item-title{font-size:14px;line-height:22px}
}
.specification-container{position:relative;margin:15px 0}
.specification-header{display:flex;align-items:center;cursor:pointer;user-select:none;justify-content:center;transform:translateY(-30px)}
.specification-header h2{margin:0;flex:1}
.specification-arrow{transition:transform .3s;color:#094f9c;font-size:16px;font-weight:bold;display:flex;justify-content:center;align-items:center}
.specification-arrow svg{width:10px;height:6px;margin-left:10px;position:relative;top:2px}
.specification-arrow svg.hide{transform:rotate(180deg)}
.specification-content{padding:10px 0}
.specification-content h2,.specification-content h3{display:none}
.specification-content h2:nth-of-type(1),.specification-content h3:nth-of-type(1){display:block}
.specification-content table{border-radius:4px;width:100%;position:relative;display:none;height:auto;transition:height .5s ease-in-out}
.specification-content table.show-table{height:120px;overflow:hidden;position:relative;border-collapse:collapse}
.specification-content table.show-table::after{content:'';position:absolute;bottom:0;left:0;width:100%;background:linear-gradient(to top,rgba(255,255,255,0.8) 0,rgba(255,255,255,0) 100%)}
.specification-content table:nth-of-type(1){display:block}
.specification-content table::after{content:'';position:absolute;width:1px;height:100%;background-color:#eaeaea;left:300px;top:0}
.specification-content table tbody{display:block;width:100%;border:1px solid #eaeaea}
.specification-content table tbody tr{display:flex;padding:12px 20px;position:relative}
.specification-content table tbody tr:nth-child(odd){background-color:#f5f5f5}
.specification-content table tbody tr:nth-child(even){background-color:#fff}
.specification-content table tbody tr td{display:block;width:calc(100% - 300px);padding:12px 20px;word-break:break-all}
.specification-content table tbody tr td:nth-of-type(1){width:300px}
.form-wrapper .form-container .form-group .upload-title{font-weight:400;font-size:14px;line-height:22px;margin-bottom:12px}
.form-wrapper .form-container .form-group .upload-title.required::after{content:"*";color:#d7150e}
.form-wrapper .form-container .form-group .upload-title.required::before{content:""}
.form-wrapper .form-container .form-group .file-section{padding-top:4px}
.form-wrapper .form-container .form-group .file-section .upload-file{display:flex;align-items:center;color:#666}
.form-wrapper .form-container .form-group .file-section .upload-file .upload-btn{background:#fff;border:1px solid #ced4da;border-radius:4px;padding:9px 34px;font-size:14px;line-height:22px;cursor:pointer;margin-right:16px}
.form-wrapper .form-container .form-group .file-section .upload-file .upload-btn span{display:inline-block;position:relative;padding-left:24px}
.form-wrapper .form-container .form-group .file-section .upload-file .upload-btn span::before{content:'';position:absolute;height:16px;width:16px;top:3px;left:0;background:center / contain no-repeat url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-upload.svg')}
.form-wrapper .form-container .form-group .file-section .upload-file .file-description{max-width:530px;font-size:12px;letter-spacing:0;line-height:17px}
.form-wrapper .form-container .form-group .file-section .file-display{list-style:none;margin:12px 0 0 0;padding:0}
.form-wrapper .form-container .form-group .file-section .file-display .file-item{width:100%;max-width:382px;position:relative;padding:0 8px;font-size:12px;color:#000;letter-spacing:0;line-height:24px}
.form-wrapper .form-container .form-group .file-section .file-display .file-item .file-name{margin-left:16px}
.form-wrapper .form-container .form-group .file-section .file-display .file-item .password-file-name{padding-right:24px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.form-wrapper .form-container .form-group .file-section .file-display .file-item .file-icon{position:absolute;width:24px;height:24px;background-size:12px 12px;background-repeat:no-repeat;background-position:center;left:0}
.form-wrapper .form-container .form-group .file-section .file-display .file-item .file-icon-default{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-default.svg')}
.form-wrapper .form-container .form-group .file-section .file-display .file-item .file-icon-word{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-word.svg')}
.form-wrapper .form-container .form-group .file-section .file-display .file-item .file-icon-image{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-image.svg')}
.form-wrapper .form-container .form-group .file-section .file-display .file-item .file-icon-excel{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-excel.svg')}
.form-wrapper .form-container .form-group .file-section .file-display .file-item .file-icon-pdf{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-pdf.svg')}
.form-wrapper .form-container .form-group .file-section .file-display .file-item:hover{background-color:#f5f5f5;color:#1585ff}
.form-wrapper .form-container .form-group .file-section .file-display .remove-btn{cursor:pointer;position:absolute;width:24px;height:24px;background-size:12px 12px;background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-close-3.svg');background-repeat:no-repeat;background-position:center;top:0;right:4px}
@media only screen and (max-width:991px){.form-wrapper .form-container .form-group .file-section .upload-file{display:block}
.form-wrapper .form-container .form-group .file-section{padding-top:0}
.form-wrapper .form-container .form-group .file-section .upload-file .upload-btn{text-align:center;padding:13px 0;margin-right:0;margin-bottom:12px}
.form-wrapper .form-container .form-group .file-section .upload-file .upload-btn span{padding-left:33px}
.form-wrapper .form-container .form-group .file-section .upload-file .upload-btn span::before{height:24px;width:24px;top:-1px}
.form-wrapper .form-container .form-group .file-section .upload-file .file-description{max-width:none}
.form-wrapper .form-container .form-group .file-section .file-display{margin-top:10px}
.form-wrapper .form-container .form-group .file-section .file-display .file-item{max-width:none}
}
.password-reset-form{background-color:#fff}
.password-reset-form .form-wrapper .form-container .form-group.half{padding:0}
.password-reset-form .form-wrapper .group-distributor{display:none;justify-content:space-between}
.password-reset-form .form-wrapper .group-distributor .other-distributor{display:none}
.password-reset-form .form-wrapper .group-distributor.other-field-active label{display:block}
.password-reset-form .form-wrapper .group-distributor .dropdown-wrapper{width:100%}
.password-reset-form .form-wrapper .group-distributor.other-field-active .dropdown-wrapper{display:inline-block;width:calc(50% - 21px);margin-right:4px}
.password-reset-form .form-wrapper .group-distributor.other-field-active .other-distributor{width:calc(50% - 21px);display:inline-block;height:40px;vertical-align:middle;font-size:14px}
.password-reset-form .form-wrapper .form-container .form-group .textarea-section{position:relative;margin-bottom:.5rem}
.password-reset-form .form-wrapper .form-container .form-group.group-specificIssue-type{display:none}
.password-reset-form .form-wrapper .form-container .form-group.group-specificIssue-type.active{display:block}
.password-reset-form .form-wrapper .checkbox-group .checkbox-inline.privacy-policy{padding-left:0}
.password-reset-form .form-wrapper .serial-number-field{position:relative}
.password-reset-form .form-wrapper .serial-number-field .how-to-query{position:absolute;font-size:12px;color:#007aff;line-height:17px;right:0;top:4px;text-decoration:underline}
.password-reset-form .form-wrapper .serial-number-tooltip{position:absolute;display:none;width:100%;background:#fff;border:1px solid #eaeaea;box-shadow:0 0 9px 0 rgba(0,0,0,0.06);padding:12px;bottom:calc(100% + 8px);left:0;font-size:12px;color:#333;letter-spacing:-0.14px;line-height:18px;z-index:1}
.password-reset-form .form-wrapper .serial-number-tooltip::before{content:'';position:absolute;border-top:1px solid #eaeaea;border-left:1px solid #eaeaea;width:8px;height:8px;bottom:-5px;transform:rotate(-135deg);left:8%;background-color:#fff}
.password-reset-form .form-wrapper .model-number-field{position:relative}
.password-reset-form .form-wrapper .model-number-field .placeholder-tips{display:none;position:absolute;top:50%;left:12px;transform:translateY(-50%);font-weight:400;font-size:14px;line-height:22px;color:#999}
.password-reset-form .form-wrapper .date-time-field{position:relative}
.password-reset-form .form-wrapper .date-time-field .placeholder-tips{display:none;position:absolute;top:50%;left:12px;transform:translateY(-50%);font-weight:400;font-size:14px;line-height:22px;color:#999}
.password-reset-dialog{position:fixed;top:0;bottom:0;left:0;right:0;width:100%;height:100%;background:rgba(0,0,0,.4);z-index:999;display:none}
.password-reset-dialog.active{display:block}
.password-reset-dialog .password-reset-tip{position:absolute;top:50%;left:50%;width:600px;height:290px;padding:32px 32px 20px;background:#FFF;transform:translate(-50%,-50%)}
.password-reset-dialog .password-reset-tip .close-btn{cursor:pointer;position:absolute;height:18px;width:18px;background:center / contain no-repeat url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/close-defaults-big-1.svg');top:16px;right:18px}
.password-reset-dialog .password-reset-tip .tip-content{width:100%;height:100%;display:flex;flex-direction:column;justify-content:space-around}
.password-reset-dialog .password-reset-tip .tip-content .tip-content-text{line-height:22px;font-size:14px}
.password-reset-dialog .password-reset-tip .tip-content .tip-content-text a{color:#0a509c}
.password-reset-dialog .password-reset-tip .tip-content .tip-content-text a:hover{color:#0a509c}
@media only screen and (max-width:991px){.password-reset-form .form-wrapper .form-container .form-group.half{flex:0 0 100%}
.password-reset-form .form-wrapper .form-container .form-group.half{padding:0}
.password-reset-form .form-wrapper .serial-number-tooltip{max-width:390px}
.password-reset-form .form-wrapper .hik-outlined-select .hik-select-selection ul li .hik-select-tooltip-icon.question{display:none}
.password-reset-form .form-wrapper .group-distributor.other-field-active .dropdown-wrapper{width:100%}
.password-reset-form .form-wrapper .group-distributor.other-field-active .other-distributor{margin-top:24px;width:100%}
.password-reset-dialog .password-reset-tip{width:345px;height:375px;padding:29px 15px 20px}
.password-reset-dialog .password-reset-tip .close-btn{top:14px;right:14px}
}
.cq-Editable-dom--container .image-cardTooltip-comp{height:1080px}
.cq-Editable-dom--container .image-cardTooltip-comp .image-cardTooltip-wrapper{height:1080px}
.image-cardTooltip-comp{position:relative;width:100%;height:300vh}
.image-cardTooltip-comp .image-cardTooltip-wrapper{position:sticky;top:0;width:100%;height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:flex-start}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content{height:648px;padding:0 150px;margin:0 auto;white-space:nowrap}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item{display:inline-block;width:513px;height:100%;margin-right:40px;vertical-align:top;border-radius:20px;overflow:hidden}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link{display:block;position:relative;width:100%;height:100%;color:#FFF;cursor:default;text-decoration:none}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link.existLink{cursor:pointer}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link .image-cardTooltip-container{position:relative;width:100%;height:100%;background-size:100% 100%}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link .image-cardTooltip-container.active{filter:blur(8px)}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link .image-cardTooltip-container.active .image-cardTooltip-container-title{display:none}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link .image-cardTooltip-container .container-background{width:100%;height:100%;object-fit:cover}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link .image-cardTooltip-container .title-bg{position:absolute;bottom:0;left:0;width:100%;height:25%;background:linear-gradient(to bottom,rgba(0,0,0,0),rgba(0,0,0,0.4))}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link .image-cardTooltip-container .image-cardTooltip-container-title{position:absolute;bottom:33px;left:32px;width:calc(100% - 64px);line-height:44px;font-size:32px;font-family:OpenSansBold;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link .image-cardTooltip-info{position:absolute;top:0;left:0;width:100%;height:100%;padding:40px 60px 70px;background:rgba(0,0,0,0.4);opacity:0;white-space:normal}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link .image-cardTooltip-info.active{opacity:0;animation:fadeIn .6s ease-in-out forwards}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link .image-cardTooltip-info .image-cardTooltip-info-title{line-height:44px;font-size:32px;font-family:OpenSansBold}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link .image-cardTooltip-info .image-cardTooltip-info-spitLine{width:100%;height:1px;border-bottom:1px dashed rgba(255,255,255,0.3);margin:32px 0}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link .image-cardTooltip-info .image-cardTooltip-info-subTitle{line-height:24px;font-size:20px;font-weight:700}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link .image-cardTooltip-info .image-cardTooltip-info-description{line-height:24px;margin-top:24px;font-size:16px;color:rgba(255,255,255,0.8);word-wrap:break-word}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link .image-cardTooltip-info .image-cardTooltip-arrow{position:absolute;bottom:24px;right:24px;width:40px;height:40px;border-radius:50%;background:url("https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-imageCardTooltip-arrow.svg") no-repeat;background-size:100% 100%;cursor:pointer}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item .image-cardTooltip-link .image-cardTooltip-info .image-cardTooltip-arrow.active{background:url("https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-imageCardTooltip-activeArrow.svg") no-repeat}
.image-cardTooltip-comp .image-cardTooltip-wrapper .image-cardTooltip-content .image-cardTooltip-item:last-child{margin-right:0}
.rtl .image-cardTooltip-comp{direction:rtl}

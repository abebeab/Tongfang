.solutions-scenario-gallery-comp .scenario-card .link .bg-box{width:100%;height:100%;background:center / cover no-repeat;transition:all .3s}
.solutions-scenario-gallery-comp .scenario-card .link .detail{position:absolute;bottom:0;left:0;right:0;min-height:40%;background-image:linear-gradient(180deg,rgba(0,0,0,0) 0,rgba(0,0,0,0.7) 100%);padding:22px 24px;display:flex;flex-direction:column;justify-content:flex-end}

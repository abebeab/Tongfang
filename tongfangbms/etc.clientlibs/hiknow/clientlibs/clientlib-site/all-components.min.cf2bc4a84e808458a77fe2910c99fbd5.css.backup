.cpp-container{width:100%;display:flex}
.cpp-container .cpp-image-layout{flex-grow:0;flex-shrink:0;padding:.625rem}
.cpp-container .cpp-image-layout img{width:204px}
.cpp-container .cpp-info-layout{flex-grow:1;flex-shrink:1}

@media(min-width:992px){.hiktools-list-comp .hiktools-list-search-container{display:block;padding:4px 25px 22px 25px}
.hiktools-list-comp .hiktools-list-search-container .search-container{margin:0 auto;max-width:750px;padding-right:50px}
.hiktools-list-comp .hiktools-list-search-container .search-container .hiktools-search{background-color:#fff;height:44px}
.hiktools-list-comp .hiktools-list-search-container .search-container .hiktools-search-btn{background-color:#d7150e;background-image:url('../../../../etc/clientlibs/it/resources/icons/icon-search-white.png');background-size:22px;right:0;width:52px}

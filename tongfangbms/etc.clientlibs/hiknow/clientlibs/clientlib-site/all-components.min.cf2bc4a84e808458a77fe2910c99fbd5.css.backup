.ir-annual-download-comp .quarters-container{margin:0;padding:0}
.ir-annual-download-comp .quarter{cursor:pointer;list-style:none}
.ir-annual-download-comp .quarter .topic{padding:16px 0;font-size:16px;color:#333;letter-spacing:0;font-weight:600;position:relative;border-bottom:1px solid #eaeaea}
.ir-annual-download-comp .quarter .topic::after{content:'';position:absolute;top:50%;right:0;height:18px;width:18px;transform:translateY(-50%);background:center / contain no-repeat url("../../../../etc/clientlibs/it/resources/icons/icon-asset-nav-less.png")}
.ir-annual-download-comp .quarter .topic[aria-expanded="false"]::after{background-image:url("../../../../etc/clientlibs/it/resources/icons/icon-asset-nav-more.png")}
.ir-annual-download-comp .quarter .content-section .ir-download-comp{padding-top:36px}
.ir-annual-download-comp .quarter .ir-download-comp .item:nth-child(odd):nth-last-child(2),.ir-annual-download-comp .quarter .ir-download-comp .item:nth-last-child(1){margin-bottom:4px}
@media screen and (max-width:991px){.ir-annual-download-comp{padding:0 15px}
.ir-annual-download-comp .year-selector{width:100%;margin-bottom:15px}
.ir-annual-download-comp.quarter-report .year-selector{margin-bottom:0}
.ir-annual-download-comp .quarter .topic{font-size:14px}
.ir-annual-download-comp .quarter .content-section .ir-download-comp{padding-top:15px}
.ir-annual-download-comp .quarter .ir-download-comp .item:nth-child(odd):nth-last-child(2){margin-bottom:10px}
.ir-annual-download-comp .quarter .ir-download-comp .item:nth-last-child(1){margin-bottom:0}
.ir-annual-download-comp .ir-download-comp{padding:0}

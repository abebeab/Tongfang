.solutions-scenario-gallery-comp .element-grid .description{margin-top:20px}
.solutions-scenario-gallery-comp .element-grid{flex-basis:calc(20% - 20px);margin-bottom:25px}
.solutions-scenario-gallery-comp .element-grid:nth-last-child(-n+5){margin-bottom:0}
.solutions-scenario-gallery-comp .element-grid>a{display:block;width:100%;height:100%;text-decoration:none}
.solutions-scenario-gallery-comp .element-grid>a .image-box{width:100%;height:136px;overflow:hidden}

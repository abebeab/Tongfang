.hiktools-list-comp .hiktools-list-filter-bar .filter:hover{color:#d7150e}
.hiktools-list-comp .hiktools-list-filter-bar .filter.active{font-weight:600}
.hiktools-list-comp .hiktools-list-filter-bar .filter.active::after{display:none}

.user{visibility:hidden;max-width:1310px;margin:0 auto;overflow:hidden}
@media screen and (max-width:1370px){.user{margin-left:30px;margin-right:30px}
}
@media(max-width:991px){.user{margin-left:15px;margin-right:15px}
}
.user .user-slick{width:calc(100% + 22px);padding-top:20px;padding-bottom:20px}
@media(max-width:991px){.user .user-slick{width:100%;padding-top:10px;padding-bottom:10px}
}
.user .user-slick ul{margin-bottom:0}
.user .user-slick .slick-list{padding-bottom:24px}
@media(max-width:991px){.user .user-slick .slick-list{padding-bottom:0}
}
.user .user-slick .slick-list .slick-track{display:flex}
.user .user-slick .slick-list .slick-track .slick-slide{width:325px;height:auto}
.user .user-slick .slick-list .slick-track .slick-slide div{height:100%}
.user .user-slick .slick-list .slick-track .slick-slide div *{height:auto}
.user .user-slick .slick-list .slick-track .slick-slide div .user-box{width:33.33%;padding-right:24px;height:100%}
@media(max-width:991px){.user .user-slick .slick-list .slick-track .slick-slide div .user-box{padding-right:10px}
}
.user .user-slick .slick-list .slick-track .slick-slide div .user-box .user-box-in{border:1px solid #eaeaea;box-shadow:0 2px 20px 0 rgba(0,0,0,0.07);padding:20px 24px;background:top center / contain no-repeat url(https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/double-quote.svg);background-color:#fff;background-size:25px 23px;background-position:right 23px top 12px;height:100%}
@media(max-width:991px){.user .user-slick .slick-list .slick-track .slick-slide div .user-box .user-box-in{padding:20px}
}
.user .user-slick .slick-list .slick-track .slick-slide div .user-box .user-box-in .user-box-top{display:flex;margin-bottom:20px}
.user .user-slick .slick-list .slick-track .slick-slide div .user-box .user-box-in .user-box-top img{width:48px;height:48px;border-radius:24px;margin-right:20px}
.user .user-slick .slick-list .slick-track .slick-slide div .user-box .user-box-in .user-box-top .user-box-mark{flex:1}
.user .user-slick .slick-list .slick-track .slick-slide div .user-box .user-box-in .user-box-top .user-box-mark .name{font-family:OpenSansSemiBold;font-size:16px;color:#333;letter-spacing:0;font-weight:600;padding-bottom:5px}
@media(max-width:991px){.user .user-slick .slick-list .slick-track .slick-slide div .user-box .user-box-in .user-box-top .user-box-mark .name{font-size:14px}
}
.user .user-slick .slick-list .slick-track .slick-slide div .user-box .user-box-in .user-box-top .user-box-mark .description{font-family:OpenSans;font-size:14px;color:#999;letter-spacing:0;font-weight:400}
@media(max-width:991px){.user .user-slick .slick-list .slick-track .slick-slide div .user-box .user-box-in .user-box-top .user-box-mark .description{font-size:12px}
}
.user .user-slick .slick-list .slick-track .slick-slide div .user-box .user-box-in .user-box-top .decration{width:26px}
.user .user-slick .slick-list .slick-track .slick-slide div .user-box .user-box-in .user-box-bottom{font-size:16px;color:#333;letter-spacing:0;line-height:28px;font-weight:400}
@media(max-width:991px){.user .user-slick .slick-list .slick-track .slick-slide div .user-box .user-box-in .user-box-bottom{font-size:14px;line-height:24px}
}
.user .user-slick .slick-list .slick-track .slick-slide div .user-box .user-box-in .user-box-bottom p{margin:0}
.user .user-slick .slick-dots{padding-left:0;display:flex;justify-content:center}
.user .user-slick .slick-dots li{list-style:none;padding:0 4px 0 4px;line-height:4px}
.user .user-slick .slick-dots li.slick-active button{background:#d7150e;opacity:1}
.user .user-slick .slick-dots li button{border:0;height:4px;opacity:.15;background:#000;display:inline-block;line-height:4px;width:60px;outline:0;color:transparent}
.user .user-slick .slick-dots li button:hover{background:#d7150e}
.hik-multiple-select{position:relative;display:inline-block;width:100%;font-size:.875rem;min-height:40px}
.hik-multiple-select .hik-multiple-input{display:flex;align-items:center;padding:.375rem .75rem;border:1px solid #ced4da;border-radius:4px;width:100%;height:40px;transition:.15s ease-out;cursor:pointer}
.hik-multiple-select .hik-multiple-input .dropdown-arrow{width:30px;height:40px;cursor:pointer;margin:0}
.hik-multiple-select .hik-multiple-input .dropdown-arrow::after{content:'';position:absolute;top:45%;right:.75rem;border-left:6px solid transparent;border-right:6px solid transparent;border-top:8px solid #505050;display:inline-block;border-bottom:0;transition:all .15s ease-in}
.hik-multiple-select .hik-multiple-input.active{border-color:#333}
.hik-multiple-select .hik-multiple-input.active .hik-multiple-selector .placeholder{opacity:1}
.hik-multiple-select .hik-multiple-input.active label{top:0;transform:translateY(-50%) scale(0.75) !important}
.hik-multiple-select .hik-multiple-input.active .dropdown-arrow::after{border-bottom:8px solid #505050;border-top:0}
.hik-multiple-select .hik-multiple-input label{color:#999 !important;font-size:14px !important;position:absolute;left:0;top:50%;transform:translateY(-50%);background-color:white;padding:0 .3rem;margin:0 .5rem;transition:.3s ease-out;transform-origin:left top;pointer-events:none}
.hik-multiple-select .hik-multiple-input .hik-multiple-selector{position:relative;display:flex;flex:auto;flex-wrap:wrap;max-width:100%;width:100%}
.hik-multiple-select .hik-multiple-input .hik-multiple-selector .hik-multiple-selected-option{border:1px solid #eaeaea;max-width:100%;padding:0 8px;display:flex;align-items:center;margin:0 2px;background-color:#f5f5f5}
.hik-multiple-select .hik-multiple-input .hik-multiple-selector .hik-multiple-selected-option input{border:0}
.hik-multiple-select .hik-multiple-input .hik-multiple-selector .hik-multiple-selected-option.hidden-option{opacity:0;height:0;overflow-y:hidden;pointer-events:none;position:absolute}
.hik-multiple-select .hik-multiple-input .hik-multiple-selector .hik-multiple-selected-option.ellipsis-label{display:flex;align-items:center;order:9999}
.hik-multiple-select .hik-multiple-input .hik-multiple-selector .hik-multiple-selected-option span{cursor:auto}
.hik-multiple-select .hik-multiple-input .hik-multiple-selector .hik-multiple-selected-option span.hik-option-text-ellipsis{text-overflow:ellipsis;overflow:hidden;white-space:nowrap}
.hik-multiple-select .hik-multiple-input .hik-multiple-selector .hik-multiple-selected-option span.hik-option-close{max-width:100%;background-image:url(../../../../etc/clientlibs/it/resources/icons/icon-close.png);background-size:60%;background-repeat:no-repeat;height:1rem;width:1rem;background-position:50% 50%;margin-left:2px;cursor:pointer}
.hik-multiple-select .hik-multiple-input .hik-multiple-selector .placeholder{color:#999;opacity:0;transition:.1s ease-out;padding:.35rem;padding-left:0;margin:0}
.hik-multiple-select .hik-multiple-selection{display:flex;position:relative;width:100%}
.hik-multiple-select .hik-multiple-selection ul{position:absolute;width:100%;max-height:250px;left:0;top:0;padding:4px 0;margin-top:4px;display:none;border-radius:4px;z-index:2;border:1px solid #666;box-shadow:0 5px 15px 0 rgba(0,0,0,0.17);overflow-y:auto;background:#fff;transition:max-height .25s ease-in}
.hik-multiple-select .hik-multiple-selection ul li{list-style:none;border-top-width:0;border-bottom-width:0;background:#fff;padding:4px .75rem;display:flex;cursor:pointer;margin-bottom:2px}
.hik-multiple-select .hik-multiple-selection ul li.active{background:#f5f5f5}
.hik-multiple-select .hik-multiple-selection ul li.active input[type=checkbox]::after{border-color:#d7150e !important}
.hik-multiple-select .hik-multiple-selection ul li:hover{background:#f5f5f5}
.hik-multiple-select .hik-multiple-selection ul li:hover input[type=checkbox]::after{border-color:#d7150e !important}
.hik-multiple-select .hik-multiple-selection ul li.selected{background:#fbe7e6}
.hik-multiple-select .hik-multiple-selection ul li span{cursor:pointer;background:0}
.hik-multiple-select .hik-multiple-selection ul li span:hover{background:0}
.hik-multiple-select .hik-multiple-selection ul li :hover{background-color:#f5f5f5}
.hik-multiple-select .hik-multiple-input.active+.hik-multiple-selection ul{display:block}
.hik-multiple-select ::-webkit-scrollbar{width:10px}
.hik-multiple-select ::-webkit-scrollbar-track{border-radius:0;width:6px;background-color:#f5f5f5}
.hik-multiple-select ::-webkit-scrollbar-thumb{border-radius:0;background-color:#ccc;width:6px}
.hik-outlined-select{display:flex;flex-direction:column;font-size:14px}
.hik-outlined-select.business-type{position:relative}
.hik-outlined-select .hik-select-input{position:relative;width:100%}
.hik-outlined-select .hik-select-input input{padding-right:24px !important;overflow:hidden;text-overflow:ellipsis}
.hik-outlined-select .hik-select-input .placeholder{position:absolute;color:#999;opacity:0;transition:.1s ease-out;padding:.375rem .75rem;transform:translateY(-50%);top:50%}
.hik-outlined-select .hik-select-input .hidden-input{opacity:0;position:absolute;height:0;width:0;padding:0 !important;border:0}
.hik-outlined-select .hik-select-input::after{content:'';position:absolute;top:40%;right:.75rem;border-left:6px solid transparent;border-right:6px solid transparent;border-top:8px solid #505050;display:inline-block;border-bottom:0;transition:all .15s ease-in}
.hik-outlined-select.active .hik-select-input.hasVal .placeholder{opacity:0}
.hik-outlined-select.active .hik-select-input .placeholder{opacity:1}
.hik-outlined-select.active .hik-select-input::after{border-bottom:8px solid #505050;border-top:0}
.hik-outlined-select.active .hik-select-selection ul{max-height:250px;border:1px solid gray;overflow-y:auto;transition:max-height .25s ease-in}
.hik-outlined-select .hik-select-selection{position:relative;width:100%}
.hik-outlined-select .hik-select-selection ul{max-height:0;transition:max-height .3s ease-out;z-index:2;background-color:white;width:100%;position:absolute;margin:4px 0 0 0;padding:0;border-radius:5px;max-height:0;overflow:hidden}
.hik-outlined-select .hik-select-selection ul li{padding:5px 10px;font-size:14px;cursor:pointer;list-style:none;position:relative}
.hik-outlined-select .hik-select-selection ul li:hover{background:#f5f5f5}
.hik-outlined-select .hik-select-selection ul li.active{background:#fbe7e6}
.hik-outlined-select .hik-select-selection ul li.selected{background:#fbe7e6}
.hik-outlined-select .hik-select-selection ul li:nth-of-type(1){margin-top:8px}
.hik-outlined-select .hik-select-selection ul li.has-tip{padding-right:41px}
.hik-outlined-select .hik-select-selection ul li .hik-select-tooltip-icon{cursor:pointer;width:16px;height:16px;right:25px;top:50%;transform:translateY(-50%);position:absolute;background:center / contain no-repeat url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-tooltip-info.svg')}
.hik-outlined-select .hik-select-selection ul li .hik-select-tooltip-icon.question{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-tooltip-question.svg')}
.hik-outlined-select .tooltip-container{z-index:10;padding:12px;width:266px;right:16px;transform:translateX(100%) translateY(-50%);font-size:12px;color:#666;letter-spacing:-0.14px;font-weight:400;position:absolute;background:#fff;border:1px solid #eaeaea;box-shadow:0 0 9px 0 rgba(0,0,0,0.11)}
.hik-outlined-select .tooltip-container.show-tooltip-on-top{right:0;transform:translateY(-100%)}
.hik-outlined-select .tooltip-container.show-tooltip-on-top::before{top:auto;bottom:-14px;left:auto;right:35px;transform:translateY(0) rotate(-90deg)}
.hik-outlined-select .tooltip-container::before{content:'';position:absolute;left:-14px;top:50%;width:16px;height:16px;background:center / contain no-repeat url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-triangle-shadow.svg');transform:translateY(-50%)}
.hik-outlined-select ::-webkit-scrollbar{width:10px}
.hik-outlined-select ::-webkit-scrollbar-track{border-radius:0;width:6px;background-color:#f5f5f5}
.hik-outlined-select ::-webkit-scrollbar-thumb{border-radius:0;background-color:#ccc;width:6px}
.hik-outlined-select .hik-select-input input:read-only{cursor:pointer}
.outlined{position:relative}
.outlined label:nth-of-type(1){font-size:14px !important;position:absolute !important;margin:0 .5rem !important;padding:0 .2rem !important;top:50%;transform:translateY(-50%);background-color:#fff;left:0;transform-origin:left top;transition:.3s ease-out;color:#999 !important;line-height:18px;font-weight:400;pointer-events:none;font-size:.875rem;display:flex;align-items:center}
.outlined label:nth-of-type(1)::before{content:none}
.outlined label:nth-of-type(1).required::before{content:""}
.outlined label:nth-of-type(1).required::after{content:"*";padding-left:2px;color:#d7150e}
.outlined input{font-size:.875rem;height:40px;font-size:14px !important;width:100%;border:1px solid #ced4da;border-radius:4px;padding:.375rem 1.5rem .375rem .75rem !important;margin:0 !important;outline:0;color:#333;text-overflow:ellipsis}
.outlined input::placeholder{opacity:0}
.outlined input:focus{box-shadow:none;border:1px solid #ced4da}
.outlined input[aria-invalid="true"]{border-color:#d7150e !important}
.outlined input[type=checkbox]{padding:0 !important;margin:4px 12px 4px 0 !important;width:1rem;height:1rem;-webkit-appearance:initial;appearance:initial;outline:0;float:left;border:none !important;cursor:pointer;background:none !important;border-radius:0 !important}
.outlined input[type=checkbox]:after{position:absolute;transform:none !important;content:'';top:auto !important;left:auto !important;width:1rem;height:1rem;border:1px solid #ced4da !important;vertical-align:baseline;border-radius:0 !important}
.outlined input[type=checkbox]:hover::after{border-color:#d7150e !important}
.outlined input[type=checkbox]:checked{background-image:url(../../../../etc/clientlibs/it/resources/icons/icon-checkbox-checked.png) !important;background-size:cover !important}
.outlined input[type=checkbox]:checked::after{border-radius:0 !important;border-color:#d7150e !important}
.outlined textarea{font-size:14px;color:#333}
.outlined textarea[aria-invalid="true"]{border-color:#d7150e !important}
.outlined.outlined-textarea{max-height:none}
.outlined.outlined-textarea label:nth-of-type(1){top:15%}
.outlined.shrink{opacity:1}
.outlined.shrink label:nth-of-type(1){top:0;transform:translateY(-50%) scale(0.75) !important}
.outlined.shrink input{border-color:#666}
.outlined.shrink .selected-option.selected-init{opacity:1}
.outlined.hasVal label:nth-of-type(1){color:#999 !important;top:0;transform:translateY(-50%) scale(0.75) !important}
.outlined.err{position:relative}
.outlined.err label:nth-of-type(1).err-lbl{color:#d7150e !important}
.outlined.err input{border-color:#d7150e}
.outlined .error{top:auto !important;position:absolute !important;font-size:12px;color:#d7150e;font-style:italic !important;display:block}
.outlined .hint{position:absolute;color:#999;display:none;transition:.1s ease-out;padding:.375rem .75rem;transform:translateY(-50%);top:50%;line-height:19px;font-size:14px;color:#999;letter-spacing:-0.17px;font-weight:400}
.outlined .hint.active{display:block}
.login-required-comp-cn .login-required-bg-cn{background:rgba(0,0,0,0.4);position:fixed;bottom:0;left:0;top:0;right:0;z-index:10000}
.login-required-comp-cn .login-required-content-cn{background:#fff;box-shadow:0 4px 12px 0 rgba(0,0,0,0.2);bottom:50%;max-width:435px;width:100%;position:fixed;right:50%;transform:translate(50%,50%);z-index:10001}
.login-required-comp-cn .login-required-content-cn .close-icon{cursor:pointer;background-image:url('../../../../etc/clientlibs/it/resources/icons/text-grid-close.png');background-size:contain;background-repeat:no-repeat;height:20px;position:absolute;top:12px;right:12px;width:20px}
.login-required-comp-cn .login-required-content-cn .login-content-cn{padding:40px 0;text-align:center;color:#222}
.login-required-comp-cn .login-required-content-cn .login-content-cn .icon-img{max-width:200px;margin-bottom:30px}
.login-required-comp-cn .login-required-content-cn .login-content-cn .title{margin-bottom:16px;font-size:16px;font-weight:600;display:flex;justify-content:center}
.login-required-comp-cn .login-required-content-cn .login-content-cn .title img{margin-right:12px}
.login-required-comp-cn .login-required-content-cn .login-content-cn .description{margin-bottom:34px;font-size:14px;font-weight:400}
.login-required-comp-cn .login-required-content-cn .login-content-cn .login{border-radius:100px;display:inline-block;min-width:88px;height:36px;line-height:20px;padding:7px 20px;background-color:#d7150e;color:#fff;cursor:pointer}
.login-required-comp-cn .overflow-hidden{overflow:hidden}
@media only screen and (max-width:991px){.login-required-comp-cn .login-required-content-cn{width:calc(100% - 30px);max-width:none}
.login-required-comp-cn .login-required-content-cn .login-content-cn{padding:35px 0}
.login-required-comp-cn .login-required-content-cn .login-content-cn .title{margin-bottom:12px}
.login-required-comp-cn .login-required-content-cn .login-content-cn .description{margin-bottom:25px}
.login-required-comp-cn .login-required-content-cn .login-content-cn .login{font-size:14px;height:32px;line-height:14px;padding:9px 23px}
}
.offline-stores-comp{max-width:1370px;margin:0 auto;padding:50px 30px 20px;background:#fff}
.offline-stores-comp .offline-stores-title{font-size:34px;color:#333;text-align:center;line-height:45px;font-weight:700;margin-bottom:40px}
.offline-stores-comp .offline-stores-container{display:flex;height:640px;flex-direction:row-reverse;border:1px solid #eaeaea}
.offline-stores-comp .offline-stores-container .map-container{flex:1;width:100%}
.offline-stores-comp .offline-stores-container .map-container .offline-stores-map{height:100%}
.offline-stores-comp .offline-stores-container .map-container .offline-stores-map .amap-icon img{cursor:default}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container{z-index:2;flex:0 0 38%;padding:30px 0;box-shadow:18px 0 15px 0 rgba(0,0,0,0.03)}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .select-container{display:flex;padding-left:30px;padding-right:34px;padding-bottom:12px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .select-container .dropdown-wrapper{width:50%}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .select-container .dropdown-wrapper .dropdown.options::-webkit-scrollbar{width:6px;background-color:transparent}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .select-container .dropdown-wrapper .dropdown.options::-webkit-scrollbar-track{background-color:transparent}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .select-container .dropdown-wrapper .dropdown.options::-webkit-scrollbar-thumb{border-radius:4px;background-color:#ddd;width:6px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .select-container .dropdown-wrapper .selector-label{margin-bottom:4px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .select-container .dropdown-wrapper .selector-label.remove-top-border{border-radius:.375rem;border:1px solid #666;box-shadow:none}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .select-container .dropdown-wrapper .dropdown.options.remove-top-border{border-radius:.375rem;border:1px solid #666}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .select-container .province{margin-right:20px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .select-container .city.notShow{display:none}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container{overflow-y:auto;height:calc(100% - 55px)}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container::-webkit-scrollbar{width:8px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container::-webkit-scrollbar-track{background-color:transparent}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container::-webkit-scrollbar-thumb{border-radius:4px;background-color:#ededed;width:8px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item{padding:14px 24px 14px 29px;border:1px solid transparent;cursor:pointer}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item.active{border:1px solid #999}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-name{line-height:26px;font-size:20px;color:#333;letter-spacing:0;font-weight:700;padding-bottom:20px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info{line-height:21px;font-size:16px;color:#333;letter-spacing:0;font-weight:400;padding-bottom:16px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info-container{display:flex}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info-container a.offline-stores-path{font-size:14px;color:#333;letter-spacing:0;line-height:20px;font-weight:400;text-decoration:none;position:relative;background:#f5f5f5;padding:8px 30px 8px 16px;margin-right:20px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info-container a.offline-stores-path::after{content:'';position:absolute;right:16px;top:0;width:6px;background:center / contain no-repeat url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-amap-arrow.svg');height:100%}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info-container .offline-stores-qrcode-container{position:relative}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info-container .offline-stores-qrcode-container .qrcode-tip{position:relative;background:#f5f5f5;padding:8px 16px 8px 40px;font-size:14px;color:#333;letter-spacing:0;line-height:20px;font-weight:400}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info-container .offline-stores-qrcode-container .qrcode-tip::before{content:'';position:absolute;left:16px;top:0;width:16px;height:100%;background:center / contain no-repeat url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-amap-qrcod.svg')}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info-container .offline-stores-qrcode-container .qrcode-tip:hover{background:#ededed}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info-container .offline-stores-qrcode-container .qrcode-img{display:none;position:absolute;top:-145px;padding:8px;background-color:#fff;background-size:97px 98px;background-position:center;background-repeat:no-repeat;border:1px solid #eaeaea;box-shadow:0 0 12px 0 rgba(0,0,0,0.11)}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info-container .offline-stores-qrcode-container .qrcode-img::after{content:'';position:absolute;left:17px;bottom:-11px;width:10px;height:12px;background:center / contain no-repeat url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-amap-corner-1.svg')}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info-container .offline-stores-qrcode-container .qrcode-img.active{display:block}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info-container .offline-stores-qrcode-container .qrcode-img img{width:120px;height:120px}
@media screen and (max-width:991px){.offline-stores-comp{margin:0 auto;padding:20px 0 10px}
.offline-stores-comp .offline-stores-title{font-size:24px;margin-bottom:20px;padding:0 15px}
.offline-stores-comp .offline-stores-container{display:block;height:auto;border:0}
.offline-stores-comp .offline-stores-container .map-container{height:320px;padding:0 15px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container{box-shadow:none;padding:20px 0 0}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .select-container{display:block;padding:0 15px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .select-container .dropdown-wrapper{width:100%}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .select-container .province,.offline-stores-comp .offline-stores-container .offline-stores-detail-container .select-container .city{margin-right:0;padding-bottom:8px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container{height:auto}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item{padding:12px 15px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item:hover{cursor:pointer;border:0}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item.active{border:1px solid #999}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-name{line-height:21px;font-size:16px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info{line-height:19px;font-size:14px;padding-bottom:12px}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info-container a.offline-stores-path{margin-right:0}
.offline-stores-comp .offline-stores-container .offline-stores-detail-container .offline-stores-items-container .offline-stores-item .offline-stores-info-container .offline-stores-qrcode-container{display:none}
}
.case-caoursel-wapper{width:100%;margin:0 auto;margin-bottom:20px}
.case-caoursel-wapper.case-caoursel-gray{background-color:#f3f3f3}
.case-caoursel-wapper.case-caoursel-white{background-color:#fff}
.case-caoursel-wapper .case-content{max-width:1310px;margin:0 auto;overflow:hidden}
.case-caoursel-wapper .case-content .title{font-family:"OpenSansBold","Microsoft YaHei","Helvetica Neue","PingFang SC","Hiragino Sans GB","WenQuanYi Micro Hei",sans-serif;font-size:40px;color:#333;text-align:center;font-weight:700;padding-top:50px;padding-bottom:20px;margin-bottom:0}
.case-caoursel-wapper .case-content .rte-content{width:50%;margin:0 auto;font-family:OpenSans;font-size:16px;color:#333;line-height:28px;font-weight:400;padding:20px 0}
.case-caoursel-wapper .case-content .rte-content p{margin:0}
.case-caoursel-wapper .case-content .led-list-content{width:100%;margin:40px auto;margin-bottom:50px;position:relative;overflow:hidden}
.case-caoursel-wapper .case-content .led-list-content .case-caourselswiper{margin:0;padding:0;list-style:none;white-space:nowrap}
.case-caoursel-wapper .case-content .led-list-content.center-style .case-caourselswiper{justify-content:center}
.case-caoursel-wapper .case-content .led-list-content .case-caourselswiper .swiper-slide{margin:0;padding:0;display:inline-block;width:420px;text-align:center;background-color:#333}
.case-caoursel-wapper .case-content .led-list-content .case-caourselswiper .swiper-slide .video-btn{z-index:9;display:block;width:58px;height:42px;position:absolute;top:50%;left:50%;cursor:pointer;transform:translate(-50%,-50%);background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-video-play.svg')}
.case-caoursel-wapper .case-content .led-list-content .case-caourselswiper .swiper-slide .video-btn:hover{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-video-play-hover.svg')}
.case-caoursel-wapper .plyr__control.plyr__control--overlaid svg{display:none}
.case-caoursel-wapper .plyr__control.plyr__control--overlaid{background-color:transparent;border-radius:0;width:58px;height:42px;background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-video-play.svg');background-size:center;box-shadow:none}
.case-caoursel-wapper .plyr__control.plyr__control--overlaid:hover{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-video-play-hover.svg');background-color:transparent}
.card-item.hik-video-wrapper #video-player-container .plyr__controls{display:none}
.case-caoursel-wapper .case-caourselswiper .plyr__control.plyr__control--overlaid{display:none}
.case-caoursel-wapper .case-content .led-list-content .case-caourselswiper .swiper-slide .card-item{height:100%;background-size:cover;background-position:center;background-repeat:no-repeat;padding-bottom:56.25%;background-size:cover;cursor:pointer}
.case-caoursel-wapper .case-content .led-list-content .case-caourselswiper .swiper-slide .card-item.card-image:hover{opacity:.6}
.case-caoursel-wapper .case-preview-content{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background-color:#000000c2;z-index:10}
.case-caoursel-wapper .case-preview-content .big-swiper{width:60%;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);margin:0 auto;overflow:hidden}
.case-caoursel-wapper .case-preview-content .big-swiper .swiper-slide{background-size:cover;background-repeat:no-repeat;background-position:center;padding-bottom:56.25%;background-color:#fff}
.case-caoursel-wapper .case-preview-content .big-swiper .close-btn{z-index:11;position:absolute;top:0;right:0;padding:13px;background-position:center;background-repeat:no-repeat;background-color:rgba(0,0,0,0.4);width:50px;height:50px;background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-close-white.svg')}
.case-caoursel-wapper .swiper-button-next::after,.case-caoursel-wapper .swiper-button-prev::after,.case-caoursel-wapper .swiper-button-next2::after,.case-caoursel-wapper .swiper-button-prev2::after{display:none}
.case-caoursel-wapper .swiper-button-next,.case-caoursel-wapper .swiper-button-prev,.case-caoursel-wapper .swiper-button-next2,.case-caoursel-wapper .swiper-button-prev2{position:absolute;content:'';width:40px;height:40px;border-radius:50%;background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-carousel-slide.svg');background-size:100%;top:50%}
.case-caoursel-wapper .swiper-button-next:focus,.case-caoursel-wapper .swiper-button-prev:focus,.case-caoursel-wapper .swiper-button-next2:focus,.case-caoursel-wapper .swiper-button-prev2:focus{outline:0}
.case-caoursel-wapper .swiper-button-next:hover,.case-caoursel-wapper .swiper-button-prev:hover,.case-caoursel-wapper .swiper-button-next2:hover,.case-caoursel-wapper .swiper-button-prev2:hover{background-color:#fff}
.case-caoursel-wapper .case-preview-content .swiper-button-next2{right:calc(20% - 88px)}
.case-caoursel-wapper .case-preview-content .swiper-button-prev2{transform:rotate(180deg);left:calc(20% - 88px)}
.case-caoursel-wapper .led-list-content .swiper-button-next{right:20px}
.case-caoursel-wapper .led-list-content .swiper-button-prev{transform:rotate(180deg);left:20px}
.case-caoursel-wapper .swiper-button-next.swiper-button-disabled,.case-caoursel-wapper .swiper-button-prev.swiper-button-disabled,.case-caoursel-wapper .swiper-button-next2.swiper-button-disabled,.case-caoursel-wapper .swiper-button-prev2.swiper-button-disabled{display:none}
.card-item #video-player-container,.swiper-slide.hik-video-wrapper #video-player-container{position:absolute;width:100%;top:0;left:0}
@media only screen and (max-width:1370px) and (min-width:992px){.case-caoursel-wapper{padding:0 30px}
}
@media only screen and (max-width:992px){.case-caoursel-wapper{padding:10px 15px;margin:0}
.case-caoursel-wapper .case-content .led-list-content.center-style .case-caourselswiper{justify-content:unset}
.case-caoursel-wapper .led-list-content{width:calc(100% - 60px) !important}
.case-caoursel-wapper .swiper-button-next,.case-caoursel-wapper .swiper-button-prev,.case-caoursel-wapper .swiper-button-next2,.case-caoursel-wapper .swiper-button-prev2{display:none !important}
.case-caoursel-wapper .case-content .led-list-content{width:100% !important;margin:0 auto;margin-top:20px}
.case-caoursel-wapper .case-preview-content .big-swiper{width:100%}
.case-caoursel-wapper .case-content .title{font-size:24px;color:#454545;font-weight:700;padding-top:10px;padding-bottom:10px}
.case-caoursel-wapper .case-content .rte-content{width:100%;font-size:14px;padding:10px 0}
}
.doc-certificate-comp{max-width:1370px;min-height:258px;padding:20px 30px;margin:0 auto}
.doc-certificate-comp .doc-search-content{display:flex;justify-content:center;align-items:center}
.doc-certificate-comp .doc-search-content .search-input-wrap label{display:none;position:absolute;padding:0 8px;top:-10px;left:16px;background-color:#fff;margin-bottom:0;font-size:12px;color:#999;line-height:18px;font-weight:400}
.doc-certificate-comp .doc-search-content .search-input-wrap.error-input label{display:block;color:#d7150e}
.doc-certificate-comp .doc-search-content .search-input-wrap.focused label{display:block}
.doc-certificate-comp .search-input-wrap{position:relative}
.doc-certificate-comp .doc-search-input{width:600px;height:56px;border:1px solid rgba(206,212,218,1);border-radius:4px;font-size:16px;padding:12px;outline:0}
.doc-certificate-comp .doc-search-input::placeholder{color:#999}
.doc-certificate-comp .focused .doc-search-input{border:1px solid rgba(102,102,102,1)}
.doc-certificate-comp .error-input .doc-search-input{border:1px solid #d7150e}
.doc-certificate-comp .doc-search-content .error-message{font-size:12px;height:22px;color:#d7150e;font-style:normal;font-weight:400;position:absolute;display:none;margin:4px 0}
.doc-certificate-comp .doc-search-content .error-input .error-message{display:block}
.doc-certificate-comp .product-model-list{padding:0;margin:0}
.doc-certificate-comp .search-btn{display:block;width:162px;height:36px;background:#d7150e;border:0;border-radius:18px;font-size:16px;color:#fff;text-align:center;line-height:14px;font-weight:400;margin:44px auto}
.doc-certificate-comp .search-btn:hover{background:#c1120b}
.doc-certificate-comp .search-btn:focus{outline:0}
.doc-certificate-comp .search-result .result-top{padding:24px 0;padding-top:20px;border-bottom:1px solid rgba(234,234,234,1);margin-bottom:30px;font-family:"OpenSansSemibold","Microsoft YaHei","Helvetica Neue","PingFang SC","Hiragino Sans GB","WenQuanYi Micro Hei",sans-serif;font-size:16px;color:#333}
.doc-certificate-comp .search-result .product-model-item{display:none;margin-bottom:10px}
.doc-certificate-comp .search-result .product-model-item.lazy-show{display:block}
.doc-certificate-comp .search-result .product-model-item-name{position:relative;line-height:50px;background-color:#f5f5f5;padding:0 24px;font-family:"OpenSansSemibold","Microsoft YaHei","Helvetica Neue","PingFang SC","Hiragino Sans GB","WenQuanYi Micro Hei",sans-serif;font-size:16px;color:#333}
.doc-certificate-comp .search-result .product-model-item-name .item-state{display:inline-block;width:16px;height:16px;margin-right:16px;background-image:url("../../../../etc/clientlibs/it/resources/icons/icon-asset-nav-more.png")}
.doc-certificate-comp .search-result .product-model-item.active .product-model-item-name .item-state{background-image:url("../../../../etc/clientlibs/it/resources/icons/icon-asset-nav-less.png")}
.doc-certificate-comp .search-result .product-model-item-name::after{position:absolute;left:0;top:50%;width:16px;height:16px;background-color:#d7150e}
.doc-certificate-comp .search-result .product-model-item .doc-certificate-list{display:none;padding:10px 0;padding-bottom:0}
.doc-certificate-comp .search-result .doc-certificate-list .doc-name-item{line-height:42px;font-weight:400}
.doc-certificate-comp .search-result .doc-certificate-list .doc-name-item a{display:block;line-height:42px;padding:0 56px;color:#666;font-weight:400;position:relative}
.doc-certificate-comp .search-result .doc-certificate-list .doc-name-item a:hover{color:#666;text-decoration:none}
.doc-certificate-comp .search-result .doc-certificate-list .doc-name-item .download-icon{display:inline-block;width:18px;height:16px;position:absolute;right:16px;top:50%;transform:translateY(-50%);background:center / contain no-repeat url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-firmware-download-red.svg')}
.doc-certificate-comp .search-result .product-model-item.active .doc-certificate-list{display:block}
.doc-certificate-comp li{list-style:none}
.doc-certificate-comp .no-result{display:flex;flex-direction:column;align-items:center}
.doc-certificate-comp .no-result img{width:332px}
.doc-certificate-comp .no-result .no-result-text{font-family:"OpenSansBold","Microsoft YaHei","Helvetica Neue","PingFang SC","Hiragino Sans GB","WenQuanYi Micro Hei",sans-serif;font-size:16px;color:#333;text-align:center;font-weight:700}
.doc-certificate-comp .loading-box{background:center / contain no-repeat url('../../../../etc/clientlibs/it/resources/images/gif-loading.gif');height:26px}
@media only screen and (max-width:991px){.doc-certificate-comp{padding:10px 15px;margin:0;min-height:246px}
.doc-certificate-comp .doc-search-content{display:block}
.doc-certificate-comp .doc-search-input{width:100%}
.doc-certificate-comp .search-input-wrap{margin-left:0}
.doc-certificate-comp .search-input-wrap.error-input{padding-bottom:20px}
.doc-certificate-comp .search-btn{font-size:14px;height:40px;width:80%;border-radius:20px;margin:20px auto}
.doc-certificate-comp .no-result img{width:300px}
.doc-certificate-comp .search-result .result-top{padding-top:20px;padding-bottom:12px;font-size:14px;margin-bottom:16px}
.doc-certificate-comp .search-result .product-model-item-name{line-height:42px;padding:0 16px;font-size:14px}
.doc-certificate-comp .search-result .product-model-item-name .item-state{margin-right:10px}
.doc-certificate-comp .search-result .doc-certificate-list .doc-name-item{font-size:14px;line-height:34px}
.doc-certificate-comp .search-result .doc-certificate-list .doc-name-item a{padding:0 42px}
.doc-certificate-comp .search-result .product-model-item .doc-certificate-list{padding-top:8px}
}
.contact-us-top{background:#f5f5f5;padding:0 30px}
.contact-us-list{padding:0 30px;display:none}
.contact-us-list.active{display:block}
.contact-us-box{max-width:1310px;height:182px;display:flex;justify-content:space-between;align-items:center;margin:0 auto}
.contact-us-title,.contact-us-item-title{font-family:OpenSansBold;font-size:32px;color:#333;font-weight:700}
.contact-us-scheme-comp .hik-outlined-select{width:398px}
.contact-us-scheme-comp .outlined.shrink label:nth-of-type(1){background-color:#f5f5f5}
.contact-us-scheme-comp .hik-select-selection .at-action{color:#333}
.contact-us-item{display:flex;max-width:1310px;padding:40px 0;margin:0 auto;border-bottom:1px solid rgba(234,234,234,1)}
.contact-us-list .contact-us-item:last-child{border-bottom:0}
.contact-us-item-title{width:30%;flex:0 0 30%}
.contact-us-item-content{flex:1;margin-left:7%}
.contact-us-item-content.info-column{display:flex}
.contact-us-item-content.info-column .item-content-info{flex:1}
.contact-us-item-content.info-column .item-content-info:first-child{margin-right:24px}
.item-content-info{font-family:OpenSans;font-size:16px;color:#333;line-height:28px;font-weight:400}
.item-content-info b{font-family:OpenSansSemibold;font-size:16px;color:#333;line-height:28px;font-weight:600}
.item-content-info .linkArrow{display:inline-block;font-family:OpenSansSemiBold;font-size:16px;color:#094f9c;line-height:24px;font-weight:600;padding-top:8px}
.item-content-info .contactTitle{display:inline-block;font-family:OpenSansBold;font-size:20px;color:#666;font-weight:700;padding-bottom:4px}
.item-content-info .linkArrow a::after{display:inline-block;content:"";background-image:url(https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-right-arrow.svg);background-position:center;background-repeat:no-repeat;background-size:cover;width:15px;height:10px;margin-left:8px}
.item-content-info h3{font-family:OpenSansBold;font-size:20px;color:#333;font-weight:700;margin-bottom:12px}
.item-content-info p{margin-bottom:0}
.item-content-info a{color:#094f9c}
.item-content-info.active{color:#094f9c}
.info-fontBold{font-family:OpenSansSemibold;font-weight:600}
.info-fontWeight{font-family:OpenSansBold;font-size:20px;color:#666;font-weight:700}
@media(max-width:991px){.contact-us-top{padding:0}
.contact-us-list{padding:0 15px}
.contact-us-box{display:block;padding:20px 15px;height:119px}
.contact-us-title,.contact-us-item-title{font-size:20px}
.contact-us-title{margin-bottom:12px}
.contact-us-scheme-comp .hik-outlined-select{width:100%}
.contact-us-item{display:block;padding:20px 0}
.contact-us-item-title{width:100%;margin:0 0 15px 0}
.item-content-info{font-size:14px;line-height:22px}
.item-content-info b{font-size:14px;line-height:22px}
.item-content-info h3{font-size:16px;font-weight:600;margin-bottom:10px}
.item-content-info .linkArrow{font-size:14px;line-height:22px;padding-top:10px}
.item-content-info .linkArrow::after{width:11px;height:8px}
.contact-us-item-content{margin-left:0}
.contact-us-item-content.info-column .item-content-info:first-child{margin-bottom:15px;margin-right:0}
.contact-us-item-content.info-column{display:block}
.item-content-info .contactTitle{font-family:OpenSansSemiBold;font-size:16px;color:#333;font-weight:600;padding-bottom:2px}
.info-fontWeight{font-family:OpenSansSemiBold;font-size:16px;color:#333;font-weight:600;margin-top:15px}
}
.rtl .contact-us-box{flex-direction:row-reverse}
.rtl .contact-us-scheme-comp .hik-outlined-select .hik-select-input::after{left:.75rem;right:auto}
.rtl .contact-us-scheme-comp .hik-outlined-select .hik-select-input input{text-align:right}
.rtl .contact-us-scheme-comp .outlined label:nth-of-type(1){right:0;left:auto}
.rtl .contact-us-scheme-comp .hik-select-selection ul li{text-align:right}
.rtl .contact-us-item{flex-direction:row-reverse}
.rtl .contact-us-item-title{margin-right:0;text-align:right}
.rtl .contact-us-item-content{text-align:right;margin-right:7%;margin-left:0}
.rtl .item-content-info .linkArrow a::after{display:none}
.rtl .item-content-info .linkArrow a::before{display:inline-block;content:"";transform:rotate(180deg);background-image:url(https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-right-arrow.svg);background-position:center;background-repeat:no-repeat;background-size:cover;width:15px;height:10px;margin-right:8px}
.rtl .contact-us-item-content.info-column{flex-direction:row-reverse}
.rtl .contact-us-item-content.info-column .item-content-info:first-child{margin-right:0}
@media(max-width:991px){.rtl .contact-us-title{text-align:right}
.rtl .item-content-info{margin-right:0}
.rtl .contact-us-item-content{margin-right:0}
.rtl .contact-us-item-content.info-column .item-content-info:first-child{margin-right:0}
}
.addon-list{background-color:#fff;padding-top:40px;padding-bottom:20px}
.addon-list .addon-search-wrapper{width:59.38%;max-width:778px;height:46px;margin:0 auto;background:#fff;border-radius:46px;border:0;position:relative}
.addon-list .addon-search-wrapper .addon-search-input{width:100%;height:100%;border-radius:46px;padding:0 20px;outline:0;font-size:16px;color:#505050;background:#fff;border:1px solid #ddd}
.addon-list .addon-search-wrapper .addon-search-btn{display:block;width:22px;height:22px;position:absolute;top:12px;right:20px;background-position:center;background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/search-icon.svg');background-repeat:no-repeat;cursor:pointer;background-size:20px;border-radius:23px}
.addon-list .addon-search-wrapper .addon-search-input::-webkit-input-placeholder{color:#999}
.addon-list .addon-search-wrapper .addon-search-input:-moz-placeholder{color:#999}
.addon-list .addon-search-wrapper .addon-search-input::-moz-placeholder{color:#999}
.addon-list .addon-search-wrapper .addon-search-input:-ms-input-placeholder{color:#999}
.addon-list .no-results{max-width:1370px;padding-left:30px;padding-right:30px;margin:0 auto;margin-top:45px;display:flex;flex-direction:column;justify-content:center;align-items:center}
.addon-list .no-results.hidden{display:none}
.addon-list .no-results img{width:332px}
.addon-list .no-results p{font-size:20px;font-weight:700}
.addon-list .addon-wrapper{max-width:1370px;padding-left:30px;padding-right:30px;margin:0 auto;margin-top:45px}
.addon-list .addon-wrapper .addon-header{font-size:20px;margin-bottom:20px;font-weight:600}
.addon-list .addon-wrapper .addon-header .close-mob-list{display:none}
.addon-list .addon-wrapper .addon-content{display:flex;flex-direction:row;justify-content:flex-start}
.addon-list .addon-wrapper .addon-content .mob-list-down{display:none}
.addon-list .addon-wrapper .addon-content .left-wrap{max-height:100vh}
@media(min-width:992px){.addon-list .addon-wrapper .addon-content.sticky{flex-direction:row-reverse;padding-left:327px}
.addon-list .addon-wrapper .addon-content.sticky .left-wrap{position:fixed;top:0}
}
.addon-list .addon-wrapper .addon-left{flex-grow:0;margin-right:40px;max-height:calc(100vh - 50px);overflow-y:auto;overflow-x:hidden}
.addon-list .addon-wrapper .addon-left::-webkit-scrollbar{display:none}
.addon-list .addon-wrapper .addon-left .addon-filter{margin:0;padding:0}
.addon-list .addon-wrapper .addon-left .addon-filter .addon-filter-item{width:287px;min-height:52px;list-style:none;padding:10px 20px;font-size:14px;display:flex;align-items:flex-start;cursor:pointer}
.addon-list .addon-wrapper .addon-left .addon-filter .addon-filter-item a{color:#333;text-decoration:none}
.addon-list .addon-wrapper .addon-left .addon-filter .addon-filter-item img{width:30px;margin-right:16px}
.addon-list .addon-wrapper .addon-left .addon-filter .addon-filter-item .item-title{display:inline-flex;line-height:22px;min-height:32px;align-items:center}
.addon-list .addon-wrapper .addon-left .addon-filter .addon-filter-item:hover{background-color:#f5f5f5}
.addon-list .addon-wrapper .addon-left .addon-filter .addon-filter-item.active{color:#d7150e;background-color:#f5f5f5}
.addon-list .addon-wrapper .addon-left .addon-filter .addon-filter-item.hidden{display:none}
.addon-list .addon-wrapper .addon-right{width:100%;padding-top:60px}
.addon-list .addon-wrapper .addon-right .addon-item .addon-title{font-size:20px;margin-bottom:16px;font-weight:600}
.addon-list .addon-wrapper .addon-right .addon-item .addon-introduction{font-size:14px;margin-bottom:20px}
.addon-list .addon-wrapper .addon-right .addon-item .addon-release-note{padding-top:20px;padding-bottom:20px;border-top:1px solid #eaeaea;border-bottom:1px solid #eaeaea}
.addon-list .addon-wrapper .addon-right .addon-item .addon-release-note .release-title{font-size:16px;margin-bottom:16px;font-weight:600}
.addon-list .addon-wrapper .addon-right .addon-item .addon-release-note .release-desc-wrap{font-size:14px;max-height:124px;overflow:hidden}
.addon-list .addon-wrapper .addon-right .addon-item .addon-release-note .release-desc{position:relative}

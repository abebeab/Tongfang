.hiktools-list-comp .hiktools-list-search-container .search-container .hiktools-search-btn,.hiktools-list-comp .hiktools-list-search-container .search-container .search-clear-btn{cursor:pointer;background-size:contain;background-repeat:no-repeat;background-position:center;height:100%;width:16px;outline:0;position:absolute;right:12px;top:0}
.hiktools-list-comp .hiktools-list-search-container .search-container .hiktools-search-btn{background-image:url('../../../../etc/clientlibs/it/resources/icons/sousuo%402x.png');display:block}
.hiktools-list-comp .hiktools-list-search-container .search-container .search-clear-btn{background-image:url('../../../../etc/clientlibs/it/resources/icons/icon-clear.png');display:none}

.Newsletter .enquiry-form-container #accordion .multi-select-wrapper.industry-select .hik-multiple-selection ul{display:flex;flex-wrap:wrap;border:0;box-shadow:none;transition:none;position:unset;z-index:0;margin:0;padding:0}

.hiktools-list-comp .hiktools-items-container .description{max-height:60px;-webkit-line-clamp:3}
}
.new-media{width:100%}
.new-media .media-wrapper{width:100%;background-size:cover;background-repeat:no-repeat;background-position:center}
.new-media .media-wrapper .media-content{max-width:1370px;height:100%;float:none !important;display:flex;flex-direction:column;padding:0 30px;box-sizing:border-box}
.new-media .media-wrapper .media-title{width:100%;font-size:34px;color:#333;text-align:center;position:relative;padding-top:50px;font-weight:900}
.new-media .media-wrapper .media-title:after{content:"";position:absolute;width:117px;height:3px;background:#333;bottom:-10px;left:50%;transform:translateX(-50%)}
.new-media .media-wrapper .media-info{width:100%;padding:58px 0 20px 0;display:flex;flex-direction:row}
.new-media .media-wrapper .media-image{width:50%;flex-grow:1;max-height:22.85rem;max-width:40rem;flex-shrink:1;overflow:hidden}
.new-media .media-wrapper .features-device-right{width:50%;flex-grow:1;max-height:22.85rem;height:22.85rem;max-width:40rem;flex-shrink:1;overflow:hidden}
.new-media .media-wrapper .media-image img{width:100%;height:100%;object-fit:cover}
.new-media .media-wrapper .media-description{width:50%;padding-left:92px;flex-grow:1;flex-shrink:1;font-size:16px;color:#333;line-height:24px;font-weight:400;justify-content:center;align-items:center}
@media only screen and (min-width:1373px){.new-media .media-wrapper .media-content{max-width:1370px}
.new-media .media-wrapper .media-info{flex-direction:row;padding:58px 0 20px 0}
.new-media .media-wrapper .media-title{font-size:34px;font-weight:900;padding-top:50px}
.new-media .media-wrapper .media-title:after{width:117px;height:3px}
.new-media .media-wrapper .media-image{width:50%}
.new-media .media-wrapper .media-description{width:50%;padding:0 0 0 92px;font-size:16px;line-height:24px}
}
@media only screen and (max-width:768px){.new-media .media-wrapper .media-content{width:100%}
.new-media .media-wrapper .media-info{flex-direction:column;padding:30px 16px 20px 16px}
.new-media .media-wrapper .media-title{font-size:24px;font-weight:600;padding-top:30px}
.new-media .media-wrapper .media-title:after{width:60px;height:2px}
.new-media .media-wrapper .media-image{width:100%}
.new-media .media-wrapper .features-device-right{width:100%}
.new-media .media-wrapper .media-description{width:100%;padding:12px 0;font-size:14px;line-height:22px}
}
.new-media .plyr__control:not(.plyr__control--overlaid){padding:5px}
.new-media .plyr .plyr__volume[hidden],.new-media .plyr .plyr__volume [hidden]{display:block !important}
.new-media .plyr__controls .plyr__controls__item{margin-left:0}
.new-media .plyr__controls .plyr__controls__item.plyr__volume{padding-right:0}
.new-media .plyr .plyr__controls__item.plyr__volume{flex:0 0 auto}
.new-media .plyr--video .plyr__control.plyr__tab-focus,.new-media .plyr--video .plyr__control:hover,.new-media .plyr--video .plyr__control[aria-expanded=true]{background-color:transparent;box-shadow:none}
.new-media .plyr--video .plyr__control.plyr__control--overlaid{background-color:rgba(0,0,0,.6)}
.new-media .plyr__video-embed,.new-media .plyr__video-wrapper--fixed-ratio{padding-bottom:56.25% !important}
.plyr--video .plyr__control.plyr__control--overlaid{z-index:4 !important}
.plyr__poster{z-index:-1 !important}
.plyr--stopped.plyr__poster-enabled .plyr__poster{background-position:center;background-size:cover;z-index:3 !important}
.feature-gallery-comp{max-width:85.625rem;margin:0 auto}

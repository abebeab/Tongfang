.solutions-scenario-gallery-comp .scenario-card.three-card-type.no-margin{margin-right:0}
.solutions-scenario-gallery-comp .scenario-card.two-card-type{margin-right:24px;flex-grow:0;flex-shrink:0;flex-basis:calc(50% - 12px);height:390px;margin-bottom:24px}
.solutions-scenario-gallery-comp .scenario-card.two-card-type.no-margin{margin-right:0}
.solutions-scenario-gallery-comp .scenario-card.one-card-type{flex:0 0 100%;height:390px;margin-bottom:24px}
.solutions-scenario-gallery-comp .scenario-card.one-card-type.no-margin{margin-right:0}

.ir-annual-report-comp{display:flex;align-items:center;padding-top:24px;padding-bottom:24px}
.ir-annual-report-comp .img-container{width:145px;height:188px;display:flex;align-items:center;justify-content:center;overflow:hidden;margin-right:50px;background:#d8d8d8}

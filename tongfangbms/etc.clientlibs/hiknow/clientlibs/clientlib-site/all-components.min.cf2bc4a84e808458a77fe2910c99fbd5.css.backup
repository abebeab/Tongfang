.live-window-content .live-video-play{width:80%}
.live-window-content .live-video-play-wrapper{width:100%;padding-top:calc(100% * 9 / 16);position:relative;margin:1.25rem 0;overflow:hidden}
.live-window-content .live-video-play-wrapper .plyr{width:100%;height:100%;position:absolute;top:0;outline:0}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls{background:linear-gradient(-180deg,rgba(0,0,0,0) 0,#000 100%)}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls button:hover,.live-window-content .live-video-play-wrapper .plyr .plyr__controls button:focus{background:0}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls.plyr__tab-focus{box-shadow:none !important;background:none !important}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls .plyr__volume{max-width:32px !important}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls .plyr__volume button:hover{background:0}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls .plyr__volume[hidden]{display:flex !important}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls .plyr__volume button[hidden]{display:block !important}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls .plyr__volume .plyr__volume-input{position:absolute;padding-bottom:12px;height:118px;width:32px;bottom:25px;display:none}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls .plyr__volume .plyr__volume-input::before{content:"";background:rgba(0,0,0,0.6);border-radius:4px;position:absolute;top:0;display:block;width:32px;height:106px}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls .plyr__volume .plyr__volume-input.active{display:block}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls .plyr__volume .plyr__volume-input input[type=range]{color:#fff;width:79px;transform:rotate(-90deg);bottom:-52px;left:-28.5px;cursor:pointer}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls .plyr__volume .plyr__volume-vlaue{position:absolute;bottom:121px;left:50%;transform:translateX(-50%);font-size:13px;opacity:.8;color:#fff;display:none}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls .plyr__volume .plyr__volume-vlaue.active{display:block}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls .plyr__progress__container .plyr__progress input{color:#d7150e;cursor:pointer}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls .plyr__progress__container .plyr__progress span.plyr__tooltip{background:rgba(0,0,0,0.6);color:#fff}
.live-window-content .live-video-play-wrapper .plyr .plyr__controls .plyr__progress__container .plyr__progress span.plyr__tooltip::before{border-top:4px solid rgba(0,0,0,0.6)}

.product-showcase-wrapper .showcase-page{position:relative;height:auto;display:flex;justify-content:center;overflow:hidden}
.product-showcase-wrapper .showcase-page .showcase-button{position:static;width:48px;height:48px;border-radius:100px;margin:54px 10px 0;background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-showcase-slide-on.svg');background-size:100%;box-shadow:none}
.product-showcase-wrapper .showcase-page .showcase-button.swiper-button-disabled{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-showcase-slide.svg')}
.product-showcase-wrapper .showcase-page .showcase-button::after{display:none}

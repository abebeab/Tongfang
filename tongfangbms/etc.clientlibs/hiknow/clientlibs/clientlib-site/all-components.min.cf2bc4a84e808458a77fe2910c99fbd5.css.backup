.rte.fixed-width-container,.rte.fixed-width-12c,.rte.fixed-width-10c,.rte.fixed-width-8c,.rte.fixed-width-6c{width:100% !important;margin:0 auto !important;float:none !important;clear:both !important}
.aem-Grid>.rte.aem-GridColumn.fixed-width-container,.aem-Grid>.rte.aem-GridColumn.fixed-width-12c,.aem-Grid>.rte.aem-GridColumn.fixed-width-10c,.aem-Grid>.rte.aem-GridColumn.fixed-width-8c,.aem-Grid>.rte.aem-GridColumn.fixed-width-6c{clear:both !important}
.rte.fixed-width-container{max-width:1310px !important}
.rte.fixed-width-12c{max-width:1310px !important}
.rte.fixed-width-10c{max-width:calc(1310px * 10 / 12) !important}
.rte.fixed-width-8c{max-width:calc(1310px * 8 / 12) !important}
.rte.fixed-width-6c{max-width:calc(1310px * 6 / 12) !important}
@media only screen and (max-width:1370px) and (min-width:992px){.rte.fixed-width-container{width:calc(100% - 60px) !important;max-width:calc(100% - 60px) !important}
.rte.fixed-width-12c{padding-left:0;padding-right:0;width:calc(100% - 60px) !important;max-width:calc(100% - 60px) !important}
.rte.fixed-width-10c{width:calc((100% - 60px) * 10 / 12) !important;max-width:calc((100% - 60px) * 10 / 12) !important}
.rte.fixed-width-8c{width:calc((100% - 60px) * 8 / 12) !important;max-width:calc((100% - 60px) * 8 / 12) !important}
.rte.fixed-width-6c{width:calc((100% - 60px) * 6 / 12) !important;max-width:calc((100% - 60px) * 6 / 12) !important}
}
@media only screen and (max-width:1370px) and (min-width:992px){.newsroom-news-detail-page .rte,.newsroom-blog-detail-page .rte,.newsroom-story-detail-page .rte{width:100% !important;padding:0 30px}
.newsroom-news-detail-page .rte.fixed-width-container,.newsroom-blog-detail-page .rte.fixed-width-container,.newsroom-story-detail-page .rte.fixed-width-container{max-width:1310px !important}
.newsroom-news-detail-page .rte.fixed-width-12c,.newsroom-blog-detail-page .rte.fixed-width-12c,.newsroom-story-detail-page .rte.fixed-width-12c{max-width:1370px !important}
.newsroom-news-detail-page .rte.fixed-width-10c,.newsroom-blog-detail-page .rte.fixed-width-10c,.newsroom-story-detail-page .rte.fixed-width-10c{max-width:calc(1310px * 10 / 12 + 60px) !important}
.newsroom-news-detail-page .rte.fixed-width-8c,.newsroom-blog-detail-page .rte.fixed-width-8c,.newsroom-story-detail-page .rte.fixed-width-8c{max-width:calc(1310px * 8 / 12) !important;padding:0}
.newsroom-news-detail-page .rte.fixed-width-6c,.newsroom-blog-detail-page .rte.fixed-width-6c,.newsroom-story-detail-page .rte.fixed-width-6c{max-width:calc(1310px * 6 / 12) !important;padding:0}
}
@media only screen and (min-width:992px){.rte.fixed-width-container.rte-width-80{width:80% !important;max-width:1310px}
}
@media only screen and (max-width:991px){.rte.fixed-width-container,.rte.fixed-width-12c,.rte.fixed-width-10c,.rte.fixed-width-8c,.rte.fixed-width-6c{width:100% !important;max-width:100% !important;padding-left:15px;padding-right:15px}
}
@media(min-width:1966px){.rte{max-width:1310px;margin:0 auto !important;float:none !important}
}

.filter-search-wrapper .filter-search-input-wrapper .associative-search-container .associative-search-item{color:#333;font-size:14px;font-weight:400;line-height:19px;letter-spacing:0;padding:8px 20px;word-break:break-all}
.filter-search-wrapper .filter-search-input-wrapper .associative-search-container .associative-search-item:hover{background:#f5f5f5;cursor:pointer}
.filter-search-wrapper .filter-search-input-wrapper .associative-search-container .associative-search-item strong{color:#333;font-size:14px;font-weight:600;line-height:19px;letter-spacing:0}
.filter-search-wrapper .filter-search-input-wrapper .associative-search-container .associative-search-item:last-child{margin-bottom:0}
.filter-search-wrapper .filter-search-input-wrapper .filter-search-input-main{width:59.38%;max-width:778px;height:46px;margin:0 auto;background:#fff;border-radius:46px;border:0;position:relative}
.rtl .filter-search-wrapper .filter-search-input-wrapper .filter-search-input-main{direction:rtl}
.filter-search-wrapper .filter-search-input-wrapper .filter-search-input-main .filter-search-input{width:100%;height:100%;border-radius:46px;padding:0 20px;outline:0;font-size:16px;color:#505050;background:#fff;border:1px solid rgba(221,221,221,1)}
.filter-search-wrapper .filter-search-input-wrapper .filter-search-input-main .filter-search-input::-webkit-input-placeholder{color:#999}

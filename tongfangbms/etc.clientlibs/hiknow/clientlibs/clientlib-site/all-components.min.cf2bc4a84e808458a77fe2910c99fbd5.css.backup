#copy-link-toast{position:fixed;padding:0 30px;left:50%;transform:translateX(-50%);line-height:40px;text-align:center;height:40px;background:#fff;color:#333;top:120px;box-shadow:1px 5px 5px #ccc;border-radius:15px;font-size:12px;white-space:nowrap;z-index:999}
#copy-link-toast img{margin-right:5px;width:16px}
.social-share{position:relative}
.aem-Grid.aem-Grid--default--12>.social-share.aem-GridColumn.aem-GridColumn--offset--default--1,.aem-Grid.aem-Grid--default--12>.social-share.aem-GridColumn.aem-GridColumn--offset--default--0,.aem-Grid.aem-Grid--default--12>.social-share.aem-GridColumn.aem-GridColumn--offset--default--2{margin-left:auto}
.aem-Grid>.social-share.aem-GridColumn.aem-GridColumn--default--none{clear:both !important}
.cq-Editable-dom--container .social-share{height:100px;position:relative}
.social-share--left .cmp-socail-share{display:flex;justify-content:left}
.social-share--middle .cmp-socail-share{display:flex;justify-content:center}
.social-share--right .cmp-socail-share{display:flex;justify-content:flex-end}
.social-share--right .cmp-socail-share .share{right:0}
.social-share--middle .cmp-socail-share .share{left:50%;top:50%;transform:translate(-50%,0)}
.cmp-socail-share{font-size:.875rem;line-height:1.5;display:flex;position:relative;z-index:1}
.cmp-socail-share .share-default{width:6.4rem;border-radius:1rem;display:inline-block;border:1px solid #999;color:#666;text-align:center}
.cmp-socail-share .share-default .share-button-wrap{padding-left:.8125rem;padding-right:.875rem;padding-top:.1875rem;padding-bottom:.1875rem;cursor:pointer;display:block;line-height:21px;vertical-align:middle}
.cmp-socail-share .share-default .share-button-wrap .share-button{width:1rem;margin-right:.5rem;margin-top:-0.1875rem;height:auto}
.cmp-socail-share .share{width:10rem;height:auto;border-radius:1.25rem;top:0rem;border:1px solid #505050;display:none;position:absolute;background-color:#fff}
.cmp-socail-share .share .share-button{color:#505050;text-align:center}
.cmp-socail-share .share .share-button-wrap{display:inline-block;width:78%;border-bottom:1px solid #999;vertical-align:sub;position:relative;margin-bottom:.3125rem}
.cmp-socail-share .share .share-button-wrap .share-txt{margin-left:-1.875rem}
.cmp-socail-share .share .share-button-wrap .share-button-img{width:1rem;top:.25rem;height:auto;position:absolute;left:0}
.cmp-socail-share .share .share-button-wrap .close-btn{cursor:pointer;position:absolute;width:20px;right:-0.375rem}
.cmp-socail-share .share .socail-share-list{padding-left:.75rem;padding-right:.75rem;list-style:none;margin:0;color:#666}
.cmp-socail-share .share .socail-share-list li{padding-top:.3125rem;padding-right:.3125rem;padding-bottom:.3125rem;padding-left:.4375rem}
.cmp-socail-share .share .socail-share-list .share-img-default{font-size:.875rem;color:#505050;text-decoration:none;font-family:OpenSans-SemiBold}
.cmp-socail-share .share .socail-share-list .share-img-hover{display:none;font-family:OpenSans-SemiBold;text-decoration:none}
.cmp-socail-share .share .socail-share-list .share-img{width:1.25rem;height:1.25rem;margin-right:.625rem;margin-top:-0.4375rem}
.cmp-socail-share .share .socail-share-list li:hover .share-img-default{display:none}
.cmp-socail-share .share .socail-share-list li:hover .share-img-hover{display:inline-block;color:#d7000f}
.cmp-socail-share .share .socail-share-list li.copy-link{border-top:1px solid #999;margin-bottom:5px;cursor:pointer}
.cmp-socail-share .share .socail-share-list li.copy-link .share-img-default{color:#989898}
.cmp-socail-share .open{display:inline-block}
.cmp-socail-share .close{font-size:14px;visibility:hidden}
.rtl .cmp-socail-share .share-default{direction:rtl}
.rtl .cmp-socail-share .share .share-button-wrap .share-button-img{left:auto;right:0}
.rtl .cmp-socail-share .share .share-button-wrap .share-txt{float:right;padding-right:25px;font-family:OpenSans-SemiBold}
.rtl .cmp-socail-share .share .share-button-wrap .close-btn{cursor:pointer;position:absolute;left:-0.375rem;right:auto}
.rtl .cmp-socail-share .share .socail-share-list{padding-left:.75rem;padding-right:.75rem;list-style:none;margin:0;color:#666;padding-right:10px}
.rtl .cmp-socail-share .share .socail-share-list li{padding-right:0;padding-left:0}
.rtl .cmp-socail-share .share .socail-share-list li:hover .share-img-hover{width:100%;float:right;padding:0 10px .5rem 0}
.rtl .cmp-socail-share .share .socail-share-list li:hover .share-img-hover span,.rtl .cmp-socail-share .share .socail-share-list .share-img-default span{float:right;padding-right:10px}
.rtl .cmp-socail-share .share .socail-share-list .share-img{float:right;margin-top:0}
.rtl .cmp-socail-share .share .socail-share-list .share-img-default{float:right;padding:0 10px .5rem 0}
.rtl .cmp-socail-share .share .share-button{padding-top:5px}
.rtl .cmp-socail-share .share-default .share-button-wrap .share-button{margin-left:.5rem;margin-right:0}
.product-categories{max-width:1370px;margin:0 auto !important;padding:0 30px;float:none !important;width:100% !important}
.product-wrapper{padding-top:20px}
.product-wrapper .product-categories-comp{display:flex;flex-wrap:wrap}
.product-wrapper .product-categories-comp .products{flex-grow:0;flex-shrink:0;flex-basis:calc(33.33% - 16.67px);margin-right:25px;margin-bottom:25px;text-align:center;cursor:pointer;height:310px;background-color:#fff}
.product-wrapper .product-categories-comp .products:not(.new-style){border:1px solid rgba(234,234,234,1);box-shadow:0 2px 16px 0 rgba(0,0,0,0.06);border-radius:10px}
.product-wrapper .product-categories-comp .products.new-style{overflow:hidden}
.product-wrapper .product-categories-comp .products:hover{box-shadow:0 0 25px 0 rgba(0,0,0,0.16)}
.product-wrapper .no-desc-products .products{min-height:241px;height:auto}
.product-wrapper .product-categories-comp .products a:hover{text-decoration:none}
.product-wrapper .product-categories-comp .products:nth-child(3n){margin-right:0}
.product-wrapper .product-categories-comp .products .product-container{padding:20px 22px;height:100%}
.product-wrapper .product-categories-comp .products.new-style .product-container{padding:0;position:relative}
.product-wrapper .product-categories-comp .products .product-container .product-image{display:inline-block;width:206px;height:140px;background-position:center;background-repeat:no-repeat;background-size:contain}
.product-wrapper .product-categories-comp .products .product-container .product-image .product-categories-bg{display:none}
.product-wrapper .product-categories-comp .products.new-style .product-container .product-image{width:100%;height:100%;background-size:cover;position:relative;overflow:hidden}
.product-wrapper .product-categories-comp .products.new-style .product-container:hover .product-image{transition:all .5s;transform:scale(1.1)}
.product-wrapper .product-categories-comp .products .product-container .product-item{height:auto;overflow:hidden}
.product-wrapper .product-categories-comp .products.new-style .product-container .product-item{overflow:visible}
.product-wrapper .product-categories-comp .products.new-style .product-container .product-item{position:absolute;padding:20px 20px;bottom:0;left:0;color:#fff;width:100%;box-sizing:border-box}
.product-wrapper .product-categories-comp .products.new-style .product-container:hover .product-item{transition:.5s;bottom:30px}
.product-wrapper .product-categories-comp .products .product-container .product-title{line-height:24px;font-size:16px;color:#333;font-weight:600;margin-top:27px}
.product-wrapper .product-categories-comp .products.new-style .product-container .product-title{font-size:20px;color:#fff;text-align:left}
.product-wrapper .no-desc-products .products .product-container .product-title{max-height:48px;display:-webkit-box;-webkit-box-orient:vertical;-webkit-line-clamp:2;overflow:hidden}
.product-wrapper .product-categories-comp .products .product-container .product-desc{text-align:left;margin-top:10px;font-size:14px;color:#666;line-height:22px;max-height:76px;text-overflow:-o-ellipsis-lastline;overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:3;line-clamp:3;-webkit-box-orient:vertical}
.product-wrapper .product-categories-comp .products.new-style .product-container .product-desc{color:#fff;height:44px;-webkit-line-clamp:2;line-clamp:2}
.product-wrapper .product-categories-comp .products .product-container .product-detial{display:none}
.product-wrapper .product-categories-comp .products.new-style .product-container .product-detial{position:absolute;border-bottom:-28px;text-align:left;font-size:14px;color:#fff;font-weight:400;line-height:28px;margin-top:5px;display:none}
.product-wrapper .product-categories-comp .products.new-style .product-container .product-image .product-categories-bg{display:block;position:absolute;left:0;width:100%;height:100%;-webkit-transform:translate(0,65%);-moz-transform:translate(0,65%);transform:translate(0,65%)}
.product-wrapper .product-categories-comp .products.new-style .product-container:hover .product-categories-bg{transition:.5s;transform:translate(0,0)}
.product-wrapper .product-categories-comp .products.new-style .product-container:hover .product-detial{transition:all .5s;display:block}
.product-wrapper .product-categories-comp .products.new-style .product-container .product-detial span{display:inline-block;width:10px;height:10px;margin-left:3px;background:url('../../../../etc/clientlibs/it/resources/icons/icon-arrow-right-red.png') no-repeat center;transition:all .5s}
.product-wrapper .product-categories-comp .products.new-style .product-container .product-detial:hover span{transform:translate(40%,0)}
.product-wrapper .no-desc-products .products .product-container .product-desc{max-height:66px;display:-webkit-box;-webkit-box-orient:vertical;-webkit-line-clamp:3;overflow:hidden}
.rtl .product-wrapper .product-categories-comp{direction:rtl}
.rtl .product-wrapper .product-categories-comp .products{margin-right:0;margin-left:25px}
.rtl .product-wrapper .product-categories-comp .products:nth-child(3n){margin-left:0}
.rtl .product-wrapper .product-categories-comp .products .product-container .product-desc{text-align:right}
.text.aem-GridColumn:not(.aem-GridColumn--default--none){max-width:1370px !important;width:100%;margin:0 auto;padding:0 30px;box-sizing:border-box;float:none !important}
.blog-detail-author-wrapper .text.aem-GridColumn:not(.aem-GridColumn--default--none){padding:0}
@media(max-width:1370px){.text.aem-GridColumn:not(.aem-GridColumn--default--none){width:100% !important;margin:0 auto;box-sizing:border-box}
}
@media(max-width:991px){.text.aem-GridColumn:not(.aem-GridColumn--default--none){padding:0 15px}
.product-categories{padding:0 15px}
.product-wrapper{padding-top:10px}
.product-wrapper .product-categories-comp{display:block}
.product-wrapper .no-desc-products{display:flex}
.product-wrapper .product-categories-comp .products{width:100%;margin-bottom:10px;min-height:130px;height:auto}
.product-wrapper .product-categories-comp .products.new-style{height:240px}

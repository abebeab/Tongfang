.hiktools-list-comp{background-color:#fff;padding-bottom:20px}
.hiktools-list-comp ul,.hiktools-list-comp li{list-style:none;margin:0;padding:0}
.hiktools-list-comp .hiktools-items-container{opacity:0;padding:0 15px;margin-bottom:20px}
.hiktools-list-comp .hiktools-items-container.show{opacity:1}
.hiktools-list-comp .hiktools-items-container .hiktools-item{background-color:#fff;box-shadow:0 6px 15px 0 rgba(0,0,0,0.06);border-radius:8px;display:none;margin-bottom:10px;position:relative}
.hiktools-list-comp .hiktools-items-container .hiktools-item.active{display:block}
.hiktools-list-comp .hiktools-items-container .hiktools-item.not-in-scope{display:none}
.hiktools-list-comp .hiktools-items-container .hiktools-item .link{cursor:pointer;display:block;width:100%;height:100%;padding:16px 15px}
.hiktools-list-comp .hiktools-items-container .hiktools-item .link:hover{text-decoration:none}
.hiktools-list-comp .hiktools-items-container .hiktools-item .download-btn{background:center / contain no-repeat url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-firmware-download-red.svg');cursor:pointer;display:inline-block;height:15px;width:18px;position:absolute;right:16px;top:18px}
.hiktools-list-comp .hiktools-items-container .detail-section{display:flex;margin-bottom:16px}

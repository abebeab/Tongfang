.ir-download-comp{padding-top:16px;padding-bottom:16px}
.ir-download-comp .download-list{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap}
.ir-download-comp .item{height:86px;text-decoration:none;width:calc((100% - 20px) / 2);display:flex;align-items:center;justify-content:space-between;padding:18px 20px;margin-bottom:20px;background-image:linear-gradient(180deg,#f5f5f5 0,#fafafa 100%)}
.ir-download-comp .item:hover{background:#f2f2f2}
.ir-download-comp .content{flex:1}
.ir-download-comp .file-icon{width:35px;margin-right:12px}
.ir-download-comp .filename{font-size:16px;color:#333;letter-spacing:0}
.ir-download-comp .date{font-size:14px;color:#999;letter-spacing:0;margin-top:8px}
.ir-download-comp .download-icon{width:24px;height:20px;background:center / contain no-repeat url(https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-download-line.svg)}

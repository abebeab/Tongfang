.text-over-image-comp.rtl .content-container .text-container .text-cta{padding-right:0}
.text-over-image-comp.rtl .content-container .text-container .text-cta::after{transform:rotateY(180deg)}
@media(max-width:991px){.text-over-image-comp.rtl .content-container .text-container .text-cta{padding-right:0;background-position:left center}
}
.all-in-one-comp{min-height:500px}
.all-in-one-comp ul{list-style:none;margin:0;padding:0}
.all-in-one-comp .search-section-wrapper{text-align:center;background-position:center;background-repeat:no-repeat;background-size:cover;padding:66px 0 80px 0}
.all-in-one-comp .search-section-wrapper .map-section-title{color:#fff;font-size:32px;font-weight:600;line-height:43px;letter-spacing:.16px;margin-bottom:40px;width:100%}
.all-in-one-comp .search-section-wrapper .map-search-section{display:inline-block;max-width:770px;position:relative;width:100%}
.all-in-one-comp .search-section-wrapper .map-search-section .map-search-box{background:#fff;border-radius:22px;border:1px solid #ccc;display:flex;overflow:hidden;position:relative;z-index:2}
.all-in-one-comp .search-section-wrapper .map-search-section .map-search-box.options-expand{border-bottom-color:#fff;border-radius:22px 22px 0 0}
.all-in-one-comp .search-section-wrapper .map-search-section .map-search-box .map-search-input{border:0;flex:1 1 auto;font-size:16px;padding:11px 25px;outline:0}
.all-in-one-comp .search-section-wrapper .map-search-section .map-search-box .map-search-input::-ms-clear{display:none}
.all-in-one-comp .search-section-wrapper .map-search-section .map-search-box .map-search-btn{background-color:#fff;background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-search-2.svg');background-position:center;background-repeat:no-repeat;background-size:22px;border:0;width:50px}
.all-in-one-comp .search-section-wrapper .map-search-section .map-search-box .map-search-btn:hover{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-search-2-hover.svg')}
.all-in-one-comp .search-section-wrapper .map-search-section .map-search-box .map-search-btn:focus,.all-in-one-comp .search-section-wrapper .map-search-section .map-search-box .map-search-btn:active{border:0;outline:0}
.all-in-one-comp .search-section-wrapper .map-search-section .map-search-box .map-search-btn:hover{background-image:url("https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-search-2-hover.svg")}
.all-in-one-comp .search-section-wrapper .map-search-section .map-search-box .search-empty{cursor:pointer;background-image:url('../../../../etc/clientlibs/it/resources/icons/icon-clear.png');background-position:center;background-repeat:no-repeat;background-size:contain;width:16px;height:100%;outline:0;position:absolute;right:60px;top:0;display:none}
.all-in-one-comp .search-section-wrapper .map-search-section .map-search-box .map-search-input:focus:valid ~ .search-empty{display:block}
.all-in-one-comp .search-section-wrapper .map-search-section .search-options-container{border-bottom:1px solid #ccc;border-left:1px solid #ccc;border-right:1px solid #ccc;border-radius:0 0 22px 22px;box-shadow:0 0 16px 0 rgba(0,0,0,0.09);display:none;position:absolute;left:0;top:100%;text-align:left;overflow:hidden;width:100%;z-index:1}
.all-in-one-comp .search-section-wrapper .map-search-section .search-options-container.active{display:block}
.all-in-one-comp .search-section-wrapper .map-search-section .search-options{background:#fff;max-height:280px;padding:4px 0;overflow:auto}
.all-in-one-comp .search-section-wrapper .map-search-section .search-options::-webkit-scrollbar{background-color:#fff;height:6px;width:6px}
.all-in-one-comp .search-section-wrapper .map-search-section .search-options::-webkit-scrollbar-thumb{background-color:#ddd;border-radius:4px}
.all-in-one-comp .search-section-wrapper .map-search-section .search-option{letter-spacing:0;padding:6px 18px}
.all-in-one-comp .search-section-wrapper .map-search-section .search-option.active{background-color:#fbe7e6}
.all-in-one-comp .search-section-wrapper .map-search-section .search-option .main-text{color:#333;font-size:16px;line-height:22px}
.all-in-one-comp .search-section-wrapper .map-search-section .search-option .sub-text{color:#505050;font-size:14px;line-height:20px}
.all-in-one-comp .search-section-wrapper .map-search-section .search-option .result-submatch{color:#d7150e}
.all-in-one-comp .no-result{display:none;text-align:center}
.all-in-one-comp .no-result img{width:330px;max-width:100%}
.all-in-one-comp .no-result .no-result-text{color:#666;font-size:16px;line-height:24px}
.all-in-one-comp .no-result.outer{padding:50px 30px}
.all-in-one-comp .no-result.inner{padding:40px 14px 20px 14px}
.all-in-one-comp .detail-map-container{display:none;margin:0 auto;max-width:1370px;padding:0 30px;position:relative;transform:translateY(-26px)}
.all-in-one-comp .detail-map-container .content-container{background-color:#fff;border-radius:10px;display:flex;flex-direction:row-reverse;overflow:hidden}
.all-in-one-comp .detail-container{height:calc(100vh - 200px);overflow:auto;flex:0 0 40%;text-align:center}
.all-in-one-comp .detail-container::-webkit-scrollbar{background-color:#fff;height:6px;width:6px}
.all-in-one-comp .detail-container::-webkit-scrollbar-thumb{background-color:#ddd;border-radius:4px}
.all-in-one-comp .detail-container .category-filters{text-align:center;margin:0 16px}
.all-in-one-comp .detail-container .category-filters .filter-item{cursor:pointer;display:none;border-bottom:2px solid #fff;padding:15px 0 10px 0;font-size:16px;color:#333;line-height:22px;letter-spacing:0;margin:0 5%}
.all-in-one-comp .detail-container .category-filters .filter-item.enable{display:inline-block}
.all-in-one-comp .detail-container .category-filters .filter-item.active,.all-in-one-comp .detail-container .category-filters .filter-item:hover{color:#d7150e;font-weight:600;border-bottom-color:#d7150e}
.all-in-one-comp .detail-container .detail-results{padding:0 16px 16px 16px}
.all-in-one-comp .detail-container .detail-result{cursor:pointer;line-height:20px;padding:0 14px;position:relative;text-align:left}
.all-in-one-comp .detail-container .detail-result:hover{background:#f5f5f5}
.all-in-one-comp .detail-container .detail-result:not(:first-child) .info-container{border-top:1px solid #eaeaea}
.all-in-one-comp .detail-container .detail-result:last-child .info-container{border-bottom:1px solid #eaeaea}
.all-in-one-comp .detail-container .detail-result .info-container{min-height:160px;padding:20px 110px 20px 0}
.all-in-one-comp .detail-container .detail-result .info:nth-child(n+5){display:none}
.all-in-one-comp .detail-container .detail-result.expand-detail .info:nth-child(n+5){display:block}
.all-in-one-comp .detail-container .detail-result .info{color:#666;font-size:14px;letter-spacing:0;margin-bottom:10px}
.all-in-one-comp .detail-container .detail-result .info.logo-box{border:1px solid #eaeaea;background-color:#fff;background-size:contain;background-position:center;background-repeat:no-repeat;position:absolute;right:12px;top:20px;height:90px;width:90px}
.all-in-one-comp .detail-container .detail-result .info.place-name{color:#333;font-weight:600}
.all-in-one-comp .detail-container .detail-result .info.location,.all-in-one-comp .detail-container .detail-result .info.open-time,.all-in-one-comp .detail-container .detail-result .info.website,.all-in-one-comp .detail-container .detail-result .info.phone,.all-in-one-comp .detail-container .detail-result .info.email,.all-in-one-comp .detail-container .detail-result .info.share-section{position:relative;padding-left:32px}
.all-in-one-comp .detail-container .detail-result .info.location::before,.all-in-one-comp .detail-container .detail-result .info.open-time::before,.all-in-one-comp .detail-container .detail-result .info.website::before,.all-in-one-comp .detail-container .detail-result .info.phone::before,.all-in-one-comp .detail-container .detail-result .info.email::before,.all-in-one-comp .detail-container .detail-result .info.share-section::before{content:'';background-size:contain;background-position:center;background-repeat:no-repeat;position:absolute;left:0;top:2px;height:16px;width:16px}
.all-in-one-comp .detail-container .detail-result .info.open-time .time{white-space:pre-line}
.all-in-one-comp .detail-container .detail-result .info.location::before{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-location.svg')}
.all-in-one-comp .detail-container .detail-result .info.open-time::before{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-time_2.svg')}
.all-in-one-comp .detail-container .detail-result .info.website::before{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-website.svg')}
.all-in-one-comp .detail-container .detail-result .info.phone::before{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-phone.svg')}
.all-in-one-comp .detail-container .detail-result .info.email::before{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-email.svg')}
.all-in-one-comp .detail-container .detail-result .info.share-section::before{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-share_2.svg');top:6px}
.all-in-one-comp .detail-container .detail-result .info.website a{color:#1585ff}
.all-in-one-comp .detail-container .detail-result .info.website a:hover{color:#1585ff;text-decoration:underline}
.all-in-one-comp .detail-container .detail-result .info.share-section .item{background-size:contain;background-position:center;background-repeat:no-repeat;cursor:pointer;display:inline-block;margin-right:10px;height:28px;width:28px}
.all-in-one-comp .detail-container .detail-result .info.share-section .item.facebook-share{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-facebook_2.svg')}
.all-in-one-comp .detail-container .detail-result .info.share-section .item.twitter-share{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-twitter_2.svg')}
.all-in-one-comp .detail-container .detail-result .info.share-section .item.linkedin-share{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-linkedin_2.svg')}
.all-in-one-comp .detail-container .detail-result .info.share-section .item.youtube-share{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-youtube_2.svg')}
.all-in-one-comp .detail-container .detail-result .info.img-section{width:calc(100% - 40px);position:relative}
.all-in-one-comp .detail-container .detail-result .info.img-section .img-box{background-size:cover;background-position:center;background-repeat:no-repeat;width:100%;padding-bottom:calc(100% * 1 / 2)}
.all-in-one-comp .detail-container .detail-result .info.direction{color:#333;font-weight:600;margin-bottom:0}
.all-in-one-comp .detail-container .detail-result .info.direction a{display:inline-block;position:relative;color:#333}
.all-in-one-comp .detail-container .detail-result .info.direction a:hover{text-decoration:none}
.all-in-one-comp .detail-container .detail-result .info.direction a::after{content:'';border-left:1px solid #d7150e;border-top:1px solid #d7150e;position:absolute;top:8px;right:-10px;transform:rotate(135deg);height:6px;width:6px}
.all-in-one-comp .detail-container .detail-result .action-btn{color:#666;font-size:14px;line-height:16px;position:absolute;bottom:14px;right:23px}
.all-in-one-comp .detail-container .detail-result .action-btn::after{content:'';border-left:1px solid #666;border-top:1px solid #666;position:absolute;right:-10px;height:5px;width:5px}
.all-in-one-comp .detail-container .detail-result .action-btn:hover{color:#d7150e}
.all-in-one-comp .detail-container .detail-result .action-btn:hover::after{border-color:#d7150e}
.all-in-one-comp .detail-container .detail-result .action-btn.more::after{top:5px;transform:rotate(-135deg)}
.all-in-one-comp .detail-container .detail-result .action-btn.less{display:none;bottom:20px}
.all-in-one-comp .detail-container .detail-result .action-btn.less::after{top:8px;transform:rotate(45deg)}
.all-in-one-comp .detail-container .detail-result.expand-detail .action-btn.more{display:none}
.all-in-one-comp .detail-container .detail-result.expand-detail .action-btn.less{display:block}
.all-in-one-comp .detail-container .view-more-btn{border:1px solid #ddd;border-radius:16px;cursor:pointer;color:#333;font-size:14px;display:inline-block;margin-bottom:16px;margin-top:12px;padding:4px 16px}
.all-in-one-comp .map-container{flex:0 0 60%}
.all-in-one-comp .map-container .map-box{width:100%;height:calc(100vh - 200px)}
@media(max-width:991px){.all-in-one-comp .search-section-wrapper{padding:46px 15px}
.all-in-one-comp .search-section-wrapper .map-section-title{font-size:20px;line-height:27px;letter-spacing:.1px;margin-bottom:20px}
.all-in-one-comp .search-section-wrapper .map-search-section .map-search-box .map-search-input{font-size:14px;padding:10px 25px}
.all-in-one-comp .search-section-wrapper .map-search-section .search-options{max-height:250px}
.all-in-one-comp .search-section-wrapper .map-search-section .search-option .main-text{font-size:14px;line-height:19px}
.all-in-one-comp .search-section-wrapper .map-search-section .search-option .sub-text{font-size:12px;line-height:17px}
.all-in-one-comp .detail-map-container{padding:0;transform:translateY(0)}
.all-in-one-comp .detail-map-container .content-container{border-radius:0;display:block}
.all-in-one-comp .detail-container{height:auto}
.all-in-one-comp .detail-container .filter-section{overflow:hidden;width:100%;position:relative;height:50px}
.all-in-one-comp .detail-container .category-filters{overflow-x:scroll;white-space:nowrap;margin:0}
.all-in-one-comp .detail-container .category-filters .filter-item{cursor:pointer;margin:0 15px}
.all-in-one-comp .detail-container .detail-results{padding:0 15px}
.all-in-one-comp .detail-container .detail-result{padding:0}
.all-in-one-comp .detail-container .detail-result:hover{background:transparent}
.all-in-one-comp .detail-container .detail-result .info-container{padding:20px 93px 20px 0}
.all-in-one-comp .detail-container .detail-result .info.logo-box{right:0}
.all-in-one-comp .detail-container .detail-result .info.location,.all-in-one-comp .detail-container .detail-result .info.open-time,.all-in-one-comp .detail-container .detail-result .info.website,.all-in-one-comp .detail-container .detail-result .info.phone,.all-in-one-comp .detail-container .detail-result .info.email,.all-in-one-comp .detail-container .detail-result .info.share-section{padding-left:28px}
.all-in-one-comp .detail-container .detail-result .info.img-section{width:calc(100% + 90px);max-width:450px}
.all-in-one-comp .map-container .map-box{height:40vh}
}
.new-filter-search-wrapper{display:flex;flex-direction:row;background:#fff;padding:14px 24px;border-bottom:1px solid #eaeaea}
.new-filter-search-wrapper .filter-search-label{font-size:14px;color:#333;letter-spacing:0;font-weight:400;line-height:20px;margin-top:5px;margin-right:16px}
.new-filter-search-wrapper .filter-search-group{display:flex;flex-direction:row;overflow:hidden;position:relative;height:32px;border:1px solid #ddd;border-radius:15px;min-width:345px;margin-right:12px}
.new-filter-search-wrapper .filter-search-group:focus{border:1px solid #ddd}
.new-filter-search-wrapper .filter-search-group:hover{border:1px solid #ddd}
.new-filter-search-wrapper .filter-search-group .filter-search-input{border:0;flex:1 1 auto;padding:6px 12px;outline:0;font-size:14px;letter-spacing:0;font-weight:400}
.new-filter-search-wrapper .filter-search-group .filter-search-input::-moz-placeholder{color:#999}
.new-filter-search-wrapper .filter-search-group .filter-search-input:-ms-input-placeholder{color:#999}
.new-filter-search-wrapper .filter-search-group .filter-search-input::-webkit-input-placeholder{color:#999}
.new-filter-search-wrapper .filter-search-group .filter-search-input::-ms-clear{display:none}
.new-filter-search-wrapper .filter-search-group .filter-search-button{background-color:transparent;background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/filter-search.svg');background-position:center;background-size:contain;background-repeat:no-repeat;height:100%;width:12px;position:absolute;right:15px;top:0;z-index:10;border:0;display:block}
.new-filter-search-wrapper .filter-search-group .filter-search-button:focus,.new-filter-search-wrapper .filter-search-group .filter-search-button:active{border:0;outline:0}
.new-filter-search-wrapper .filter-search-reset{display:inline-block;padding:0 25px;border:1px solid #ddd;border-radius:15px;background-color:transparent;color:#333;outline:0;font-size:1rem;flex-grow:0;flex-shrink:0;margin-left:10px;box-shadow:0 0 12px 0 rgb(0 0 0 / 16%)}
.new-filter-search-wrapper .filter-search-reset:hover{background-color:#d7150e;color:#fff}
.new-filter-search-wrapper .filter-search-more{cursor:pointer;border:1px solid #ccc;border-radius:22px;flex:0 0 auto;font-size:12px;color:#737373;line-height:22px;font-weight:400;min-width:75px;padding:4px 8px 4px 28px;position:relative;background-color:#fff;display:none}
.new-filter-search-wrapper .filter-search-more::after{content:'';background-image:url('../../../../etc/clientlibs/it/resources/icons/icon-filter_1.png');background-size:contain;background-repeat:no-repeat;background-position:center;height:100%;width:13px;position:absolute;left:10px;top:0}
.new-filter-search-wrapper .filter-search-more.active::after{background-image:url('../../../../etc/clientlibs/it/resources/icons/icon-filter-red_1.png')}
@media only screen and (max-width:768px){.new-filter-search-wrapper{width:100%;padding:15px 15px 13px}
.new-filter-search-wrapper .filter-search-label{display:none}
.new-filter-search-wrapper .filter-search-group{flex:1 1 auto;min-width:unset}
.new-filter-search-wrapper .filter-search-more{display:block}
}
.new-filter-search-wrapper .filter-search-reset:hover{background-color:#00a7e2}
.new-filter-search-wrapper .filter-search-more.active::after{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/hilook-icon-newsroom-filter-active.svg')}
.new-filter-search-wrapper .filter-search-more.active::after{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-newsroom-filter.svg')}
.form-wrapper.employee-story-wrapper header{margin-bottom:16px}
.form-wrapper.employee-story-wrapper textarea.form-control{box-sizing:border-box;padding-bottom:22px}
.form-wrapper.employee-story-wrapper .form-container .form-group .char-counter{margin-top:16px;display:block !important}
.form-wrapper.employee-story-wrapper .form-container .form-group{position:relative}
.form-wrapper.employee-story-wrapper .form-container .form-group label{height:auto;min-height:22px}
.form-wrapper.employee-story-wrapper .form-container .input-box-wrapper.verification{margin-top:8px}
@media only screen and (max-width:992px){.form-wrapper.employee-story-wrapper .form-container hr{margin-top:10px;margin-bottom:12px}
.form-wrapper.employee-story-wrapper .form-container .form-group.verification img{width:155px}
.form-wrapper.employee-story-wrapper .form-container .input-box-wrapper.verification{margin-top:12px}
.form-wrapper.employee-story-wrapper .form-container .form-group.verification input{height:2.375rem}
.form-wrapper.employee-story-wrapper .form-container .form-group{margin-bottom:1rem}
.form-wrapper.employee-story-wrapper .form-container .form-group .required{font-size:14px}
.form-wrapper.employee-story-wrapper .form-container .form-group .form-control{font-size:14px}
.form-wrapper.employee-story-wrapper .form-container .form-group,.form-wrapper.employee-story-wrapper .form-container .form-group.half{margin-bottom:14px}

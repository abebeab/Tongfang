.faq-list-comp{padding-bottom:20px}
.faq-list-comp .faq-list-search-container{padding:4px 25px 22px 25px}
.faq-list-comp .faq-list-search-container .search-container{border:1px solid #ddd;border-radius:22px;font-size:0;flex:1 1 auto;overflow:hidden;margin:0 auto;max-width:750px;padding-right:50px;position:relative;outline:0}
.faq-list-comp .faq-list-search-container .search-container .faq-search{border:0;background-color:#fff;height:44px;width:100%;color:#333;font-size:14px;line-height:22px;outline:0;padding:4px 25px}
.faq-list-comp .faq-list-search-container .search-container .faq-search::-ms-clear,.faq-list-comp .faq-list-search-container .search-container .faq-search::-ms-reveal{display:none}
.faq-list-comp .faq-list-search-container .search-container .faq-search::-webkit-search-cancel-button{-webkit-appearance:none}
.faq-list-comp .faq-list-search-container .search-container .faq-search::placeholder{color:#ccc}
.faq-list-comp .faq-list-search-container .search-container .faq-search::-webkit-input-placeholder{color:#ccc}
.faq-list-comp .faq-list-search-container .search-container .faq-search::-moz-placeholder{color:#ccc}
.faq-list-comp .faq-list-search-container .search-container .faq-search:-ms-input-placeholder{color:#ccc}
.faq-list-comp .faq-list-search-container .search-container .faq-search-btn,.faq-list-comp .faq-list-search-container .search-container .search-clear-btn{cursor:pointer;background-size:contain;background-repeat:no-repeat;background-position:center;height:100%;outline:0;position:absolute;top:0}
.faq-list-comp .faq-list-search-container .search-container .faq-search-btn{background-color:#d7150e;background-image:url('../../../../etc/clientlibs/it/resources/icons/icon-search-white.png');background-size:22px;right:0;width:52px}
.faq-list-comp .faq-list-search-container .search-container .search-clear-btn{width:16px;right:12px;background-image:url('../../../../etc/clientlibs/it/resources/icons/icon-clear.png');display:none}
.faq-list-comp .mobile-filter-btn{display:none}
.faq-list-comp .faq-list-search-container .mobile-filter-btn{margin-left:10px}
.faq-list-comp .faq-list-search-container-filter .mobile-filter-btn{width:75px}
.faq-list-comp .faq-list-search-container-filter{display:none;padding:15px}
.faq-list-comp .faq-list-filter-bar{display:flex;background-color:#fff;line-height:17px;font-size:12px;position:relative;padding:20px 24px 12px 24px;margin-bottom:10px;color:#333}
.faq-list-comp .faq-list-filter-bar .expand-icon{border-top:1px solid #333;border-right:1px solid #333;cursor:pointer;display:block;height:8px;position:absolute;right:24px;top:26px;transform:rotate(-45deg);width:8px}
.faq-list-comp .faq-list-filter-bar .expand-icon.hide{display:none}
.faq-list-comp .faq-list-filter-bar .close-icon{display:none}
.faq-list-comp .faq-list-filter-bar .filter-title{opacity:.9;padding-right:30px}
.faq-list-comp .faq-list-filter-bar .filter-title .colon{display:inline}
.faq-list-comp .faq-list-filter-bar .option-section{flex:1;max-height:none}
.faq-list-comp .faq-list-filter-bar .filter{cursor:pointer;display:inline-block;margin-bottom:8px;margin-right:20px}
.faq-list-comp .faq-list-filter-bar .filter:hover{color:#d7150e}
.faq-list-comp .faq-list-filter-bar .filter.active{color:#d7150e;font-weight:600}
.faq-list-comp .faq-list-filter-bar.close-state .expand-icon{top:21px;transform:rotate(135deg)}
.faq-list-comp .faq-list-filter-bar.close-state .option-section{max-height:24px;overflow:hidden}
.faq-list-backdrop{background-color:#000;left:0;right:0;opacity:.5;position:fixed;top:0;bottom:0;z-index:1060}
body.faq-backdrop-open{overflow:hidden}
@media(max-width:991px){.faq-list-comp{background:#fff}
.faq-list-comp .faq-list-search-container{display:flex;padding:15px}
.faq-list-comp .faq-list-search-container .search-container{padding-right:30px}
.faq-list-comp .faq-list-search-container .search-container .faq-search{background-color:transparent;height:30px;padding:4px 10px}
.faq-list-comp .faq-list-search-container .search-container .faq-search-btn{background-size:contain;background-color:transparent;width:16px;right:12px;background-image:url('../../../../etc/clientlibs/it/resources/icons/sousuo%402x.png')}
.faq-list-comp .faq-list-search-container .search-container .faq-search:focus:valid ~ .search-clear-btn{display:block}
.faq-list-comp .faq-list-search-container .search-container .faq-search:focus:valid ~ .faq-search-btn{display:none}
.faq-list-comp .mobile-filter-btn{cursor:pointer;border:1px solid #ccc;border-radius:22px;flex:0 0 auto;font-size:12px;color:#666;line-height:22px;min-width:75px;padding:4px 12px 4px 34px;position:relative;display:block}
.faq-list-comp .mobile-filter-btn::after{content:'';background-image:url('../../../../etc/clientlibs/it/resources/icons/icon-filter_1.png');background-size:contain;background-repeat:no-repeat;background-position:center;height:100%;width:15px;position:absolute;left:10px;top:0}
.faq-list-comp .mobile-filter-btn.has-filtered::after{background-image:url('../../../../etc/clientlibs/it/resources/icons/icon-filter-red_1.png')}
.faq-list-comp .faq-list-filter-bar{display:none;line-height:20px;font-size:14px;padding:15px 15px 20px 15px;width:100%;margin-bottom:0}
.faq-list-comp .faq-list-filter-bar.mobile-active{display:block;max-height:508px;overflow:auto;position:fixed;top:0;left:0;z-index:1061}
.faq-list-comp .faq-list-filter-bar .expand-icon{display:none}
.faq-list-comp .faq-list-filter-bar .close-icon{display:block;position:absolute;right:15px;top:15px;width:16px;z-index:1}
.faq-list-comp .faq-list-filter-bar .filter-title{padding-right:0;font-weight:600;font-size:15px;margin-bottom:10px}
.faq-list-comp .faq-list-filter-bar .filter-title .colon{display:none}
.faq-list-comp .faq-list-filter-bar .filter{border-bottom:1px solid #eaeaea;position:relative;padding:15px 18px 15px 0;margin:0;display:block}
.faq-list-comp .faq-list-filter-bar .filter.active{font-weight:400}
.faq-list-comp .faq-list-filter-bar .filter.active::after{content:'';background:center / contain no-repeat url('../../../../etc/clientlibs/it/resources/icons/icon-check-red.png');display:block;height:12px;position:absolute;right:0;top:18px;width:16px}
.faq-list-comp .faq-list-filter-bar.close-state .expand-icon{display:none}
.faq-list-comp .faq-list-filter-bar.close-state .option-section{max-height:none}
}
.faq-list-comp ol,.faq-list-comp ul,.faq-list-comp li{margin:0;padding:0}
.faq-list-comp ul li{list-style-type:none;position:relative}
.faq-list-comp .description.hiknow-rte ul{margin-left:10px}
.faq-list-comp .description.hiknow-rte ol{margin-left:15px}
.faq-list-comp .description.hiknow-rte ul li::before{position:absolute;left:-10px;top:10px;content:"";display:inline-block;width:4px;height:4px;background-color:#333;border-radius:50%;margin-right:5px}
.faq-list-comp ol li{list-style-type:decimal}
.faq-list-comp .faq-list-container ul li.faq-item{list-style:none}
.faq-list-comp .faq-list-container{background-color:#fff;padding:20px 30px}
.faq-list-comp .faq-items-container{min-height:400px}
.faq-list-comp .faq-items-container.minheight-noactive{min-height:0}
.faq-list-comp .faq-item{border-bottom:1px solid #eaeaea;margin-bottom:20px;padding-bottom:4px;padding-left:32px;position:relative}
.faq-list-comp .faq-item.not-in-scope{display:none}
.faq-list-comp .faq-item .topic{line-height:22px;font-size:16px;color:#333;letter-spacing:0;font-weight:600;padding-bottom:16px;cursor:pointer}
.faq-list-comp .faq-item .topic::before{content:'';position:absolute;left:0;height:18px;width:18px;top:2px;background:center / contain no-repeat url("../../../../etc/clientlibs/it/resources/icons/icon-asset-nav-less.png")}
.faq-list-comp .faq-item .topic[aria-expanded="false"]::before{background-image:url("../../../../etc/clientlibs/it/resources/icons/icon-asset-nav-more.png")}
.faq-list-comp .faq-item .content-section{font-size:14px;color:#505050;letter-spacing:0;line-height:24px}
.faq-list-comp .faq-item .content-section img{max-width:100%}
.faq-list-comp .faq-item .content-section .description{margin-bottom:16px}
.faq-list-comp .faq-item .content-section .assets-list{padding-top:2px}
.faq-list-comp .faq-item .content-section .asset{display:inline-block;color:#1585ff;font-size:14px;line-height:20px;margin-bottom:10px;position:relative;padding-left:30px;background-size:18px 18px;background-position:1px 1px;background-repeat:no-repeat;cursor:pointer}
.faq-list-comp .faq-item .content-section .asset:hover{text-decoration:underline}
.faq-list-comp .no-result-found{background-color:#fff;display:none;padding:8% 0;text-align:center}
.faq-list-comp .no-result-found img{width:349px}
.faq-list-comp .no-result-found .no-result-text .topic{color:#333;font-size:16px;font-weight:600;margin-bottom:12px}
.faq-list-comp .no-result-found .no-result-text .description{color:#666;font-size:14px}
.faq-list-comp .loading-box{background:center / contain no-repeat url('../../../../etc/clientlibs/it/resources/images/gif-loading.gif');height:26px}
.faq-list-comp .faq-list-desktop-pagination{align-items:center;justify-content:center;margin-top:20px;display:none}
.faq-list-comp .faq-list-desktop-pagination.active{display:flex}
.faq-list-comp .faq-list-desktop-pagination .pagination-section a{cursor:pointer;color:#333;display:inline-block;font-size:14px;line-height:20px;margin-right:20px;padding:0 5px}
.faq-list-comp .faq-list-desktop-pagination .pagination-section a.jp-previous,.faq-list-comp .faq-list-desktop-pagination .pagination-section a.jp-next{border-radius:4px;border:1px solid #ddd;font-size:18px;line-height:28px;height:31px;text-align:center;width:31px}
.faq-list-comp .faq-list-desktop-pagination .pagination-section a.jp-next{margin-right:12px}
.faq-list-comp .faq-list-desktop-pagination .pagination-section a.jp-previous::after{content:'<'}
.faq-list-comp .faq-list-desktop-pagination .pagination-section a.jp-next::after{content:'>'}
.faq-list-comp .faq-list-desktop-pagination .pagination-section a:hover{color:#d7150e;text-decoration:none}
.faq-list-comp .faq-list-desktop-pagination .pagination-section a.jp-current,.faq-list-comp .faq-list-desktop-pagination .pagination-section a.jp-current:hover{color:#d7150e;font-weight:700}
.faq-list-comp .faq-list-desktop-pagination .pagination-section a.jp-disabled,.faq-list-comp .faq-list-desktop-pagination .pagination-section a.jp-disabled:hover{color:#bbb}
.faq-list-comp .faq-list-desktop-pagination .pagination-section a.jp-current,.faq-list-comp .faq-list-desktop-pagination .pagination-section a.jp-current:hover,.faq-list-comp .faq-list-desktop-pagination .pagination-section a.jp-disabled,.faq-list-comp .faq-list-desktop-pagination .pagination-section a.jp-disabled:hover{cursor:default}
.faq-list-comp .faq-list-desktop-pagination .pagination-section span{display:inline-block;color:#ccc;font-size:14px;font-weight:600;margin-right:20px;position:relative;top:-2px}
.faq-list-comp .faq-list-desktop-pagination .item-num-for-page{min-width:80px}
.faq-list-comp .faq-list-desktop-pagination .item-num-for-page .dropdown{background-color:transparent;height:32px}
.faq-list-comp .faq-list-desktop-pagination .item-num-for-page .dropdown .dropdown-toggle{border:1px solid #ddd;border-radius:4px;background-color:transparent;font-size:0;height:auto;padding:5px 30px 5px 8px;position:relative}
.faq-list-comp .faq-list-desktop-pagination .item-num-for-page .dropdown .dropdown-toggle:focus,.faq-list-comp .faq-list-desktop-pagination .item-num-for-page .dropdown .dropdown-toggle:active{outline:none !important;box-shadow:none}
.faq-list-comp .faq-list-desktop-pagination .item-num-for-page .dropdown .dropdown-toggle::after{border:0;border-top:1px solid #333;border-right:1px solid #333;position:absolute;height:7px;right:14px;top:12px;width:7px;transform:rotate(135deg)}
.faq-list-comp .faq-list-desktop-pagination .item-num-for-page .dropdown .dropdown-toggle .filter-option .filter-option-inner-inner{color:#333;font-size:14px;line-height:20px}
.faq-list-comp .faq-list-desktop-pagination .item-num-for-page .dropdown div.dropdown-menu{background-color:rgba(255,255,255,0.65);box-shadow:0 5px 8px 0 rgba(0,0,0,0.18);border-color:#ddd;border-top:0;border-radius:0 0 5px 5px;padding:0;margin-top:-1px}
.faq-list-comp .faq-list-desktop-pagination .item-num-for-page .dropdown div.dropdown-menu[x-placement*="top-start"]{border-radius:5px 5px 0 0;box-shadow:0 -5px 8px 0 rgba(0,0,0,0.18);border-top:1px solid #ddd;border-bottom:0;margin-top:1px;margin-bottom:0}
.faq-list-comp .faq-list-desktop-pagination .item-num-for-page .dropdown div.dropdown-menu .dropdown-item{color:#333;font-size:14px;line-height:24px;padding:2px 8px;white-space:normal}
.faq-list-comp .faq-list-desktop-pagination .item-num-for-page .dropdown div.dropdown-menu .dropdown-item.active{background-color:rgba(254,246,246,0.65);color:#333}
.faq-list-comp .faq-list-desktop-pagination .item-num-for-page .dropdown div.dropdown-menu .dropdown-item:not(.active):hover{background-color:rgba(243,245,247,0.65);color:#333}
.faq-list-comp .faq-list-desktop-pagination .item-num-for-page .dropdown.show .dropdown-toggle{background-color:rgba(255,255,255,0.65);border-radius:0;box-shadow:0 0 8px 0 rgba(0,0,0,0.18)}
.faq-list-comp .faq-list-desktop-pagination .item-num-for-page .dropdown.show .dropdown-toggle::after{top:15px;transform:rotate(-45deg)}
@media(max-width:991px){.faq-list-comp .faq-list-desktop-pagination.active{display:none}
.faq-list-comp .faq-list-container{padding:5px 15px}
.faq-list-comp .faq-items-container{min-height:0}
.faq-list-comp .faq-item{margin-bottom:16px;padding-left:0;display:none}
.faq-list-comp .faq-item.mobile-active{display:block}
.faq-list-comp .faq-item .topic{padding-bottom:12px;padding-left:30px}
.faq-list-comp .faq-item .description{margin-bottom:8px}
.faq-list-comp .faq-item .assets-list{padding-top:0}
.faq-list-comp .faq-item .asset{margin-bottom:8px}
.faq-list-comp .faq-list-search-container-filter{display:block}
}
.quick-access-wrapper{width:100%;background-color:transparent;background-repeat:no-repeat;background-size:cover;background-position:center}
.quick-access-wrapper .quick-access-content-container{min-height:192px;display:flex;max-width:1620px;padding:0 30px;justify-content:center;margin:0 auto}
.quick-access-wrapper .quick-access-menu{max-width:258px;flex:1;padding:0 15px}
.quick-access-wrapper .quick-access-menu .quick-access__bg-img{height:110px;width:110px;margin-bottom:10px;margin-left:auto;margin-right:auto;background-repeat:no-repeat;background-size:contain;background-position:center;transition:all .25s ease-in-out}
.quick-access-wrapper .quick-access-menu .quick-access-menu-link{display:inline-block;padding-bottom:20px;padding-top:30px;width:100%;text-align:center}
.quick-access-wrapper .quick-access-menu .quick-access-menu-link:hover{text-decoration:none}
.quick-access-wrapper .quick-access-menu .quick-access-menu-link:hover .quick-access__bg-img{transform:scale(1.1)}

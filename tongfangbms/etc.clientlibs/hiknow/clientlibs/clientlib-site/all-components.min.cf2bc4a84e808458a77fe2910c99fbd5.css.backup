.hiktools-list-comp .hiktools-list-filter-bar .expand-icon{border-top:1px solid #333;border-right:1px solid #333;cursor:pointer;display:block;height:8px;position:absolute;right:24px;top:26px;transform:rotate(-45deg);width:8px}
.hiktools-list-comp .hiktools-list-filter-bar .expand-icon.hide{display:none}
.hiktools-list-comp .hiktools-list-filter-bar .close-icon{display:none}

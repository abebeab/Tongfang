.Newsletter .enquiry-form-container #accordion .multi-select-wrapper.industry-select{margin:0;line-height:0;display:none}
.Newsletter .enquiry-form-container #accordion .multi-select-wrapper.industry-select .hik-multiple-select{min-height:0}

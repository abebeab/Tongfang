.product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-wrapper{scrollbar-color:transparent transparent;overflow:scroll;transition:height .1s}
.product-selectionTools-comp .product-selectionTools-filter-comp .product-selectionTools-filter-spec{display:flex;width:100%;flex-direction:row-reverse;transition:height .1s}

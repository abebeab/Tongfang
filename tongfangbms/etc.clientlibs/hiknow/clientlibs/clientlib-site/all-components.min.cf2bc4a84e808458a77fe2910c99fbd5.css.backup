html,body{background-color:#f8f8f8}
.blog-author-wapper{line-height:1.15;max-width:81.875rem;margin:0 auto;padding:10px 0}
@media(min-width:992px){.blog-author-wapper{display:flex;padding:20px 0}
}
@media(min-width:992px){.blog-author-left{margin-right:10px;flex-grow:0;flex-shrink:0;flex-basis:calc(69% - 10px)}
}
@media(min-width:992px){.blog-author-right{flex:0 0 31%}
}
.two-cols-form .hidden{display:none}
.two-cols-form-wrapper{max-width:81.875rem;margin:0 auto}
@media(min-width:992px){.two-cols-form-wrapper{display:flex}
}
.two-cols-form-left{margin-bottom:10px}
@media(min-width:992px){.two-cols-form-left{flex:0 0 55%}
}
.two-cols-form-right{margin-bottom:10px}
@media(min-width:992px){.two-cols-form-right{flex:0 0 45%}
}
.two-cols-form-right .required::before{content:"*";color:#d7150e}
.two-cols-form .form-wrapper{margin-top:20px;padding:0 15px}
.two-cols-form .form-wrapper ul,.two-cols-form .form-wrapper li{list-style-type:none !important;margin:0;padding:0}
.two-cols-form .form-wrapper .two-cols-form-field{margin-bottom:15px}
@media(min-width:992px){.two-cols-form .form-wrapper .two-cols-form-field{display:flex;margin-bottom:18px}
}
.two-cols-form .form-wrapper .two-cols-form-field .input-box{flex:1}
.two-cols-form .form-wrapper .two-cols-form-field label{color:#000;flex:0 0 145px;font-size:16px;line-height:22px;margin-right:10px;margin-bottom:8px;text-align:right}
@media(min-width:992px){.two-cols-form .form-wrapper .two-cols-form-field label{font-size:14px;line-height:38px;margin-bottom:0;margin-right:25px}
}
.two-cols-form .form-wrapper .two-cols-form-field.radio-field .radio-item,.two-cols-form .form-wrapper .two-cols-form-field.check-field .check-box-item{margin-bottom:5px}
.two-cols-form .form-wrapper .two-cols-form-field.radio-field label,.two-cols-form .form-wrapper .two-cols-form-field.check-field label{line-height:23px}
.two-cols-form .form-wrapper .two-cols-form-field.radio-field .radio-item label,.two-cols-form .form-wrapper .two-cols-form-field.check-field .check-box-item label{margin-bottom:0;font-size:14px}
.two-cols-form .form-wrapper .two-cols-form-field.radio-field .radio-item label::before,.two-cols-form .form-wrapper .two-cols-form-field.check-field .check-box-item label::before{box-shadow:none !important;border-color:#999 !important}
.two-cols-form .form-wrapper .two-cols-form-field.radio-field .other-text input,.two-cols-form .form-wrapper .two-cols-form-field.check-field .other-text input{width:50%;min-width:200px}
.two-cols-form .form-wrapper .two-cols-form-field.radio-field .radio-item .custom-control-input:checked ~ .custom-control-label::before,.two-cols-form .form-wrapper .two-cols-form-field.check-field .check-box-item .custom-control-input:checked ~ .custom-control-label::before{background-color:#999;box-shadow:none !important}
.two-cols-form .custom-radio .custom-control-input:checked ~ .custom-control-label::after{background-image:none;background-color:white;width:6px;height:6px;border-radius:50%;top:9px;left:-19px}
.two-cols-form .custom-checkbox .custom-control-input:checked ~ .custom-control-label::after{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/two-column-form-check.svg');background-size:contain;width:10px;height:10px;left:-21px;top:7px}
.two-cols-form .form-wrapper .two-cols-form-field input,.two-cols-form .form-wrapper .two-cols-form-field textarea{border:1px solid #999;border-radius:4px;color:#333;outline:0}
.two-cols-form .form-wrapper .two-cols-form-field input:focus,.two-cols-form .form-wrapper .two-cols-form-field textarea:focus{box-shadow:none}
.two-cols-form .form-wrapper .two-cols-form-field input::-webkit-input-placeholder,.two-cols-form .form-wrapper .two-cols-form-field textarea::-webkit-input-placeholder{color:#999;font-size:14px}
.two-cols-form .form-wrapper .two-cols-form-field input:-moz-placeholder,.two-cols-form .form-wrapper .two-cols-form-field textarea:-moz-placeholder{color:#999;font-size:14px;opacity:1}
.two-cols-form .form-wrapper .two-cols-form-field input::-moz-placeholder,.two-cols-form .form-wrapper .two-cols-form-field textarea::-moz-placeholder{color:#999;font-size:14px;opacity:1}
.two-cols-form .form-wrapper .two-cols-form-field input:-ms-input-placeholder,.two-cols-form .form-wrapper .two-cols-form-field textarea:-ms-input-placeholder{color:#999;font-size:14px}
.two-cols-form .form-wrapper .two-cols-form-field input::-ms-input-placeholder,.two-cols-form .form-wrapper .two-cols-form-field textarea::-ms-input-placeholder{color:#999;font-size:14px}
.two-cols-form .form-wrapper .two-cols-form-field input::placeholder,.two-cols-form .form-wrapper .two-cols-form-field textarea::placeholder{color:#999;font-size:14px}
.two-cols-form .form-wrapper .two-cols-form-field input[type=number]{-moz-appearance:textfield}
.two-cols-form .form-wrapper .two-cols-form-field input[type=number]::-webkit-inner-spin-button,.two-cols-form .form-wrapper .two-cols-form-field input[type=number]::-webkit-outer-spin-button{-webkit-appearance:none;margin:0}
.two-cols-form .form-wrapper .two-cols-form-field .error.help-block{left:0;color:#d7000f;font-size:12px;font-style:normal;margin-bottom:0}
.two-cols-form .form-wrapper .select-region-wrapper .dropdown-wrapper{position:relative}
.two-cols-form .form-wrapper .select-region-wrapper .dropdown-wrapper .region-selector-label.remove-top-border input{border-bottom-right-radius:0;border-bottom-left-radius:0;border-bottom:0}
.two-cols-form .form-wrapper .select-region-wrapper .dropdown-wrapper .region-selector-label:after{content:'';position:absolute;top:40%;right:6px;border-left:8px solid transparent;border-right:8px solid transparent;border-top:9px solid #999;display:inline-block;border-bottom:0;transition:all .15s ease-in}
.two-cols-form .form-wrapper .select-region-wrapper .dropdown-wrapper .region-selector-label.remove-top-border:after{border-bottom:9px solid #999;border-top:0;margin-left:22px;margin-bottom:3px;transition:all .15s ease-in}
.two-cols-form .form-wrapper .select-region-wrapper .dropdown-wrapper .dropdown.region-options{list-style-type:none;border:1px solid #999;border-radius:6px;padding:0;position:absolute;width:100%;display:none;background-color:#fff;z-index:1;max-height:250px;overflow-y:auto}
.two-cols-form .form-wrapper .select-region-wrapper .dropdown-wrapper .dropdown.region-options.remove-top-border{border-top-right-radius:0;border-top-left-radius:0}
.two-cols-form .form-wrapper .select-region-wrapper .dropdown-wrapper .dropdown.region-options li{border-bottom:1px solid #999;font-size:14px;padding:5px 10px}
.two-cols-form .form-wrapper .select-region-wrapper .dropdown-wrapper .dropdown.region-options li:last-child{border:0}
.two-cols-form .form-wrapper .select-region-wrapper .dropdown-wrapper .dropdown.region-options li:hover{background-color:#d2d2d2}
.two-cols-form .form-wrapper .textarea-wrapper{position:relative}
.two-cols-form .form-wrapper .textarea-wrapper textarea{resize:none}
.two-cols-form .form-wrapper .textarea-wrapper .char-counter{top:100%;right:0;position:absolute}
.two-cols-form .form-wrapper .verification-code-wrapper{display:flex}
.two-cols-form .form-wrapper .verification-code-wrapper input{margin-right:5px;max-width:180px;min-width:100px}
.two-cols-form .form-wrapper .verification-code-wrapper img{height:38px}
.two-cols-form .form-wrapper .verification-invalid{display:none}
.two-cols-form-check{margin-bottom:.75rem;font-size:14px;color:#2a2a2a;line-height:18px;display:flex}
.two-cols-form-check input{margin-top:2px;width:14px;height:14px;outline:0;border:1px solid rgba(0,0,0,0.15);border-radius:2px;-webkit-appearance:none;-moz-appearance:none;-ms-progress-appearance:none;appearance:none;flex:0 0 auto}
.two-cols-form-check input[type="checkbox"]:checked{background-image:url('../../../../etc/clientlibs/it/resources/icons/checkbox-checked.png');background-size:100% 100%;border:0}
.two-cols-form-check label{margin-bottom:0;margin-left:.5rem}
.two-cols-form-check label p{display:inline}
.two-cols-form-check .space{display:none}
@media(min-width:992px){.two-cols-form-check .space{display:block;flex:0 0 145px;margin-right:25px}
}
.two-cols-form-footer{display:flex;justify-content:center;padding:10px 0}
@media(min-width:992px){.two-cols-form-footer{justify-content:left}
}
.two-cols-form-footer .space{display:none}
@media(min-width:992px){.two-cols-form-footer .space{display:block;flex:0 0 145px;margin-right:25px}
}
.two-cols-form-submit,.two-cols-form-reset{height:2rem;border-radius:16px;padding:9px 20px;font-size:14px;text-align:center;line-height:14px;cursor:pointer;min-width:96px}
.two-cols-form-submit:focus,.two-cols-form-reset:focus{outline:0}
.two-cols-form-reset{border:1px solid #999;background-color:transparent;color:#333;margin-right:60px}
@media(min-width:992px){.two-cols-form-reset{margin-right:20px}
}
.two-cols-form-submit{border:0;background:#ca1d22;color:#fff;position:relative}
.two-cols-form-submit:disabled{color:#737373;opacity:.5;border:1px solid #505050;background:#fff;cursor:default}
.two-cols-form-submit img{position:absolute;top:50%;transform:translateY(-50%);right:8px;display:none}
.two-cols-form-submit.loading{padding-right:30px}
.two-cols-form-submit.loading img{display:block}
.two-cols-form-thanks-message,.two-cols-form-error-message{display:none;position:fixed;background:#fff;box-shadow:0 4px 12px 0 rgba(0,0,0,0.2);border-radius:8px;bottom:50%;right:50%;transform:translate(50%,50%);z-index:10001;padding:3rem 0;width:90%;max-width:450px}
.two-cols-form-thanks-message.active,.two-cols-form-error-message.active{display:block}
@media(min-width:992px){.two-cols-form-thanks-message,.two-cols-form-error-message{width:450px}
}
.two-cols-form-thanks-message-close,.two-cols-form-error-message-close{background-image:url('../../../../etc/clientlibs/it/resources/icons/text-grid-close.png');width:1.25rem;height:1.25rem;background-repeat:no-repeat;position:relative;top:-2.25rem;background-size:100% 100%;float:right;margin-right:.75rem;cursor:pointer}
.two-cols-form-thanks-message-image,.two-cols-form-error-message-image{text-align:center}
.two-cols-form-thanks-message-image img,.two-cols-form-error-message-image img{max-width:50px;max-height:50px}
.two-cols-form-thanks-message-image span,.two-cols-form-error-message-image span{font-size:24px;margin-left:10px;vertical-align:middle}
.two-cols-form-thanks-message-text,.two-cols-form-error-message-text{color:#333;font-size:17px;text-align:center}
.two-cols-form-thanks-message-image,.two-cols-form-error-message-image{margin-bottom:15px}
.two-cols-form-alert-bg{background:rgba(0,0,0,0.4);display:none;position:fixed;bottom:0;left:0;top:0;right:0;z-index:10000}
.two-cols-form-alert-bg.active{display:block}
.ai-campaign-mobile-wrapper{margin-top:10px;background:#fff;padding:0 15px}
.ai-campaign-mobile-wrapper.active .tab-open-close{transform:translateY(-50%) rotateX(180deg)}
.ai-campaign-mobile-wrapper.active .ai-campaign-mobile-list{display:flex}
.ai-campaign-mobile-wrapper.active .ai-campaign-mobile-CTA{display:block}
.ai-campaign-mobile-tab{padding:1.25rem 0;position:relative}
.ai-campaign-mobile-tab .ai-campaign-mobile-tab-icon{height:1.25rem;width:auto;display:inline-block}
.ai-campaign-mobile-tab .ai-campaign-mobile-tab-icon svg{color:#333;height:1.25rem}
.ai-campaign-mobile-tab span{font-size:1rem;color:#333;margin-left:1.25rem;font-weight:600}
.ai-campaign-mobile-tab .tab-open-close{height:7px;width:12px;position:absolute;right:0;top:50%;transform:translateY(-50%)}
.ai-campaign-mobile-list{display:none;flex-wrap:wrap;padding-bottom:15px}
.ai-campaign-mobile-item{display:flex;margin-top:15px;background:rgba(245,245,245,0.86);border-radius:10px;padding:1rem 0 1rem 1rem;position:relative}
.ai-campaign-mobile-item-container{flex:0 0 50%;text-align:center}
.ai-campaign-mobile-item-container:nth-child(2n){padding-left:7.5px}
.ai-campaign-mobile-item-container:nth-child(2n-1){padding-right:7.5px}
.ai-campaign-mobile-item-icon{flex:0 0 25%;text-align:right}
.ai-campaign-mobile-item-icon svg{height:2.25rem;position:relative;margin-right:.5rem;top:50%;transform:translateY(-55%);color:#d7150e}
.ai-campaign-mobile-item-text{flex:0 0 25%;height:100%;text-align:left;font-size:.75rem;color:#333;height:3.5rem;box-sizing:border-box;display:table}
.ai-campaign-mobile-item-text p{display:table-cell;vertical-align:middle}
.ai-campaign-mobile-item-text span{display:block;margin-left:.5rem;position:relative;top:50%;transform:translateY(-50%);font-weight:600}
.ai-campaign-mobile-CTA{display:none;padding:1.25rem 0;border-top:1px solid #f5f5f5;text-align:center}
.ai-campaign-mobile-CTA span{font-size:.875rem;color:#999}
.ai-campaign-mobile-CTA img{width:7px;height:12px;margin-left:7.5px}
.ai-campaign-bg{padding:75px 0;display:none}
.ai-campaign-title{text-align:center;position:relative;top:10px}
.ai-campaign-title span{position:relative;font-size:20px}
@media only screen and (min-width:768px){.ai-campaign-bg{display:block;background-repeat:no-repeat;background-position:center;background-size:cover}
}
.ai-campaign-content{max-width:81.875rem;margin:0 auto;padding:0 15px;display:none}
.ai-campaign-content-container{overflow:hidden;color:#eaeaea;padding-bottom:1.375rem;background-image:linear-gradient(-180deg,#292150 0,#101431 100%);box-shadow:inset 0 0 30px 0 rgba(125,70,238,0.38);border-radius:16px;padding-left:20px;padding-right:20px;box-sizing:border-box}
@media only screen and (max-width:768px){.ai-campaign-mobile-tab span{font-family:PingFangSC-Semibold;font-size:16px;color:#333}
.ai-campaign-mobile-item-text span{font-family:PingFangSC-Semibold;font-size:12px;color:#333}
.ai-campaign-mobile-item-icon{flex:0 0 25%}
}
@media only screen and (min-width:768px){.ai-campaign-content{display:block}
}
.ai-campaign-tab-wrapper{display:flex;flex-wrap:nowrap;position:relative;left:0;transition:all .5s}
.ai-campaign-tab-item{flex:0 0 25%;text-align:center;cursor:pointer;position:relative;color:#fff;background-image:url('../../../../etc/clientlibs/it/resources/images/default.png');background-repeat:no-repeat;height:3rem;line-height:3rem;background-size:100% 100%}
.ai-campaign-tab-item .ai-campaign-tab-icon{height:1.25rem;margin-right:1.375rem;display:inline-block}
.ai-campaign-tab-item .ai-campaign-tab-icon svg{height:1.25rem;color:#fff}
.ai-campaign-tab-item:first-child::after{z-index:-1}
.ai-campaign-tab-item.active,.ai-campaign-tab-item:hover{background-image:url('../../../../etc/clientlibs/it/resources/images/checked.png')}
.ai-campaign-tab-item:hover{text-decoration:underline;text-decoration-color:#fff}
.ai-campaign-tab-item.active::after,.ai-campaign-tab-item:hover::after{z-index:-1}
.ai-campaign-tab-item.active+div::after,.ai-campaign-tab-item:hover+div::after{z-index:-1}
.ai-campaign-list{display:flex;padding:0 15px 25px;flex-wrap:wrap;margin-top:8px}
.ai-campaign-item{background:rgba(216,216,216,0.08);border-radius:10px;padding:1.25rem 0;margin-top:2rem;text-align:center;cursor:pointer;display:block}
.ai-campaign-item-icon svg{height:2.625rem;color:#fff}
.ai-campaign-item-text{font-size:.875rem;color:#eaeaea;margin-top:1rem}
.ai-campaign-item.active{background:rgba(71,39,139,0.23);box-shadow:inset 0 0 22px 0 #5e49c4;border-radius:10px}
.ai-campaign-item:hover{background:rgba(71,39,139,0.23);box-shadow:inset 0 0 22px 0 #5e49c4;border-radius:10px}
.ai-campaign-item:hover .ai-campaign-item-text{text-decoration:underline;text-decoration-color:#fff}
.ai-campaign-CTA-list{padding-top:1.375rem;text-align:center}
.ai-campaign-CTA-item{font-size:1rem;color:#eaeaea;display:none}
.ai-campaign-CTA-item img{margin-left:1rem}
.ai-campaign-CTA-item:hover{color:#eaeaea}
.ai-campaign-CTA-item.active{display:block}
.ai-campaign-title{margin-top:1.31rem;text-align:center}
.ai-campaign-title span{position:relative}
.text-links-wrapper{display:flex;flex-wrap:wrap;justify-content:space-between;max-width:1370px;margin:0 auto;padding:20px 30px}
.text-link-a{font-size:16px;color:#333;letter-spacing:0;color:#094f9c !important;line-height:22px;font-weight:400}
.text-link-a:hover{text-decoration:underline !important}
.text-link-image{display:inline-block;width:20px;height:20px;margin-left:10px;margin-bottom:-3px}
.text-link-a.download .text-link-image{background:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-hyperlink-xiazai-5.svg') no-repeat center}
.text-link-a.video .text-link-image{background:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-hyperlinik-video.svg') no-repeat center;margin-bottom:-6px}
.text-links-wrapper .hyperlink-list-container{flex-shrink:0;flex-grow:0;flex-basis:calc((100% - 120px) / 2)}
.text-links-wrapper .hyperlink-list-container .text-hyperlink-list-content{margin-bottom:24px}
.text-links-wrapper .hyperlink-list-container .text-hyperlink-list-content.is-expand .text-links .view-more span::after{transform:rotate(180deg)}
.text-links-wrapper .hyperlink-list-container .section-title{line-height:28px;padding-bottom:10px;font-size:24px;font-weight:600;color:#2a2e2e;letter-spacing:0}
.text-links-wrapper .hyperlink-list-container .text-links{list-style:none;margin-bottom:0;padding:0}
.text-links-wrapper .hyperlink-list-container .text-links .text-link{padding:7px 0;font-size:1rem;letter-spacing:.08px;line-height:22px}
.text-links-wrapper .hyperlink-list-container .text-links .text-link.is-hide{display:none}
.text-links-wrapper .hyperlink-list-container .text-links .text-link a{color:#2a2e2e;text-decoration:none}
.text-links-wrapper .hyperlink-list-container .text-links .view-more{font-size:1rem;font-weight:600;letter-spacing:.08px;color:#d7150e;user-select:none}
@media screen and (max-width:768px){.text-links-wrapper{display:block;padding:10px 15px}
.text-links-wrapper .hyperlink-list-container .text-hyperlink-list-content{margin-bottom:20px}
.text-links-wrapper .hyperlink-list-container .text-links .text-link{font-size:14px}
.text-links-wrapper .hyperlink-list-container .text-links .view-more{font-size:.875rem}
.text-link-a{font-size:14px}
.text-links-wrapper .hyperlink-list-container .section-title{line-height:22px;padding:7px 0;font-size:16px;font-weight:700;color:#2a2e2e;letter-spacing:0}
}
.text-links-wrapper .hyperlink-list-container .text-links .view-more span{cursor:pointer;position:relative;display:inline-block}
.text-links-wrapper .hyperlink-list-container .text-links .view-more span::after{content:"";top:10px;right:-10px;position:absolute;width:6px;height:6px;background-repeat:no-repeat;background-position:center;background-size:contain;background-image:url("../../../../etc/clientlibs/it/resources/icons/icon-collapse-red.png")}
.form-wrapper form.vasp-inquiry-form{margin-bottom:0;position:relative}
.vasp-inquiry-form .form-title{font-size:24px;font-weight:700;margin-bottom:30px}
.form-wrapper .vasp-inquiry-form .form-container{padding:40px 6.8% 24px 6.8%}
.vasp-inquiry-result{max-width:81.875rem;margin:0 auto 1.5rem auto;background-color:#fff}
.vasp-inquiry-result .result-container{padding:24px 6.8% 40px 6.8%}
.vasp-inquiry-result .info-title{font-size:20px;letter-spacing:0;font-weight:600;margin-bottom:16px}
.vasp-inquiry-result .info-container{background:#f5f5f5;padding:22px 24px 6px 24px}
.vasp-inquiry-result .info-container .info{margin-bottom:16px}
.vasp-inquiry-result .info-container .topic{display:inline-block;min-width:136px;line-height:22px;font-size:16px;color:#666;letter-spacing:0}
.vasp-inquiry-result .info-container .value{display:inline-block;line-height:22px;font-size:16px;color:#333;font-weight:600;letter-spacing:0}
.vasp-inquiry-result .info-container .link{color:#1585ff;letter-spacing:0;font-weight:400}
.vasp-inquiry-form .invalid-popup{position:absolute;z-index:1;left:50%;top:50%;transform:translate(-50%,-50%);padding:30px;width:calc(100% - 30px);max-width:464px;box-shadow:0 4px 12px 0 rgba(0,0,0,0.16);background-color:#fff;text-align:center}
.vasp-inquiry-form .invalid-popup .text{font-size:16px;letter-spacing:0;padding-left:46px;position:relative;display:inline-block;text-align:left}
.vasp-inquiry-form .invalid-popup .text::before{content:'';position:absolute;width:30px;height:30px;top:calc(50% - 15px);left:0;background:center / contain url('../../../../etc/clientlibs/it/resources/icons/icon-form-warning.png')}
.vasp-inquiry-form .verification .help-block{display:block}
.vasp-inquiry-form .verification .form-control{text-indent:0 !important}
@media(max-width:767px){.form-wrapper .vasp-inquiry-form .form-container{padding:30px 15px 30px 15px}
.vasp-inquiry-form .space{display:none}
.vasp-inquiry-result{margin-bottom:0}
.vasp-inquiry-result .info-title{font-size:14px;padding-bottom:12px;border-bottom:1px solid #eaeaea;margin-bottom:15px}
.vasp-inquiry-result .info-container{padding:16px 15px 6px 15px}
.vasp-inquiry-result .info-container .topic{display:block;min-width:0;line-height:17px;font-size:12px;font-weight:600;margin-bottom:4px}
.vasp-inquiry-result .info-container .value{display:block;line-height:19px;font-size:14px;font-weight:400}
.vasp-inquiry-result .result-container{padding:0 4% 40px 4%}
.vasp-inquiry-form .invalid-popup{padding:20px}
}
.qa-query-tooltip{font-size:14px;letter-spacing:0}
.qa-query-tooltip p{margin-bottom:0;color:#999}
.form-wrapper.OA .form-container .form-submit-group{margin-top:15px;justify-content:center}
.form-wrapper.OA .form-container .form-submit-group .hiknow-submit{width:162px !important}
.form-wrapper.OA.outlined-wrapper form.outlined-form .form-container .form-info .form-group{height:56px}
.form-wrapper.OA .outlined input{height:56px}
.form-wrapper.OA .form-group.verification{display:none}
.certificate-result_box{margin-top:56px;height:154px;background:#f5f5f5;padding:20px;box-sizing:border-box;display:none}

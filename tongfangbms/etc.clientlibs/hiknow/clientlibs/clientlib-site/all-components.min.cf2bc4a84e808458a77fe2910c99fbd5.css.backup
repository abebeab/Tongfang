.marketing-material-list{background-color:#fff}
.marketing-material-list-comp{display:flex;max-width:1370px;padding:0 30px 40px 30px;position:relative;margin:0 auto;letter-spacing:0}
.marketing-material-list-comp .filter-container{flex:0 0 18.85%}
.marketing-material-list-comp .filter-container.list-sticky{position:fixed;top:20px;width:18.85%}
@media(min-width:1310px){.marketing-material-list-comp .filter-container.list-sticky{width:calc(1310px * 0.1885)}
}
.marketing-material-list-comp .filter-container .sticky-conatiner{max-height:100vh;overflow:auto;top:0;padding-top:40px}
.marketing-material-list-comp .filter-container .sticky-conatiner::-webkit-scrollbar-thumb{background-color:#ddd}
.marketing-material-list-comp .filter-container.list-sticky .sticky-conatiner{padding-top:0}
.marketing-material-list-comp .filter-container .container-title{font-size:20px;color:#505050;font-weight:600;padding-bottom:12px;border-bottom:1px solid #eaeaea;margin-bottom:12px}
.marketing-material-list-comp .filter-container .main-title{line-height:22px;font-size:16px;color:#333;font-weight:600;padding:20px 24px 5px 11px;position:relative}
.marketing-material-list-comp .filter-container .main-title::before{content:'';background-color:#d7150e;position:absolute;left:0;top:22px;height:16px;width:3px}
.marketing-material-list-comp .filter-container .main-item{cursor:pointer;position:relative;padding-bottom:7px;border-bottom:1px solid #eaeaea}
.marketing-material-list-comp .filter-container .sub-items{padding:8px 0}
.marketing-material-list-comp .filter-container .sub-item{font-size:14px;color:#666;padding:6px 12px;line-height:19px;cursor:pointer}
.marketing-material-list-comp .filter-container .sub-item:hover{background-color:#f5f5f5}
.marketing-material-list-comp .material-list-container{flex:1;color:#333;font-weight:600;padding-left:calc(3% - 22px)}
.marketing-material-list-comp .material-list-container.list-sticky{padding-left:calc(100% * 0.1885 + calc(3% - 22px))}
@media(min-width:1310px){.marketing-material-list-comp .material-list-container.list-sticky{padding-left:calc(1310px * 0.1885 + calc(3% - 22px))}
}
.marketing-material-list-comp .material-list-container .list-category-wrapper.group-last{padding-bottom:40px;position:relative}
.marketing-material-list-comp .material-list-container .list-category-wrapper.group-last::after{content:'';position:absolute;height:1px;background-color:#eaeaea;right:0;bottom:0;width:calc(100% - 24px)}
.marketing-material-list-comp .material-list-container .category-title{line-height:32px;font-size:24px;margin:0 0 0 22px;padding-top:40px}
.marketing-material-list-comp .material-list-container .card-section{display:flex;flex-wrap:wrap}
.marketing-material-list-comp .material-list-container .card-section .card-container{flex:0 0 33.333%}
.marketing-material-list-comp .material-list-container .card-section .card-item{margin:24px 0 0 22px;position:relative}
.marketing-material-list-comp .material-list-container .card-section .img-box{width:100%;padding-bottom:calc(100% * 9 / 16);background-repeat:no-repeat;background-size:cover;background-position:center;margin-bottom:16px;border-radius:4px}
.marketing-material-list-comp .material-list-container .card-section .download-wrapper{display:block;position:absolute;left:0;top:0;width:100%;padding-bottom:calc(100% * 9 / 16);cursor:pointer;z-index:1}
.marketing-material-list-comp .material-list-container .card-section .download-wrapper::before{content:'';display:none;background:center / contain no-repeat url("https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-download-white.svg");height:34px;width:40px;position:absolute;top:calc(50% - 17px);left:calc(50% - 20px)}
.marketing-material-list-comp .material-list-container .card-section .download-wrapper:hover{background-color:rgba(0,0,0,0.4)}
.marketing-material-list-comp .material-list-container .card-section .download-wrapper:hover::before{display:block}
.marketing-material-list-comp .material-list-container .card-section .desc{font-size:16px;letter-spacing:.08px;line-height:22px}
@media(max-width:991px){.marketing-material-placeholder{height:42px}
.marketing-material-list-comp{display:block;padding:0}
.marketing-material-list-comp .filter-container{overflow:hidden;height:43px;border-bottom:1px solid #eaeaea;position:fixed;background-color:#fff;width:100%;top:48px;z-index:101}
.marketing-material-list-comp .filter-container.list-sticky{top:0;width:100%}
.marketing-material-list-comp .filter-container .sticky-conatiner{padding-top:0}
.marketing-material-list-comp .filter-container .container-title,.marketing-material-list-comp .filter-container .sub-items{display:none}
.marketing-material-list-comp .filter-container .sub-item.active,.marketing-material-list-comp .filter-container .sub-item:hover{background-color:none;color:#d7150e;font-weight:400}
.marketing-material-list-comp .filter-container .categroy-wrapper{overflow-x:auto;white-space:nowrap;text-align:center}
.marketing-material-list-comp .material-list-container .card-section .download-wrapper:hover{background-color:transparent}
.marketing-material-list-comp .material-list-container .card-section .download-wrapper:hover::before{display:none}
.marketing-material-list-comp .filter-container .main-title{line-height:16px;font-size:15px;font-weight:400;padding:12px 0 14px 0;position:relative}
.marketing-material-list-comp .filter-container .main-title::before{display:none;top:auto;bottom:0;height:2px;width:100%}
.marketing-material-list-comp .filter-container .main-item{padding:0 26px;border-bottom:0}
.marketing-material-list-comp .filter-container .main-item::after{content:'';background-image:url(../../../../etc/clientlibs/it/resources/icons/icon-dropdown-grey.png);background-size:contain;background-repeat:no-repeat;height:5px;width:8px;position:absolute;top:19px;right:10px}
.marketing-material-list-comp .filter-container .main-item.active .main-title{background-color:transparent;font-weight:600;color:#d7150e}
.marketing-material-list-comp .filter-container .main-item.active .main-title::before{display:block}
.marketing-material-list-comp .filter-container .main-item:hover .main-title{background-color:transparent}
.marketing-material-list-comp .filter-container .categroy-section{display:inline-block}
.marketing-material-list-comp .filter-container .categroy-section.sub-expand .sub-items{background-color:#fff;display:block;text-align:left;position:fixed;width:100%;left:0;max-height:500px;min-height:150px;overflow:auto;padding:0 15px 20px 15px;z-index:1;margin-top:1px}
.marketing-material-list-comp .filter-container .categroy-section.sub-expand .sub-item{border-bottom:1px solid #eaeaea;font-size:14px;color:#333;padding:15px 0;line-height:20px}
.marketing-material-list-comp .filter-container .categroy-section.sub-expand .sub-item.active,.marketing-material-list-comp .filter-container .categroy-section.sub-expand .sub-item:hover{background-color:transparent;font-weight:400}
.marketing-material-list-comp .filter-container .categroy-section.hide-red-line .main-item.active .main-title::before{display:none}
.marketing-material-list-comp .material-list-container{padding:23px 15px 0 15px}
.marketing-material-list-comp .material-list-container.list-sticky{padding-left:15px}
.marketing-material-list-comp .material-list-container .list-category-wrapper.group-last{padding-bottom:1px;margin-bottom:20px}
.marketing-material-list-comp .material-list-container .list-category-wrapper.group-last::after{width:100%}
.marketing-material-list-comp .material-list-container .category-title{line-height:27px;font-size:20px;margin:0 0 16px 0;padding-top:0}
.marketing-material-list-comp .material-list-container .card-section{display:block}
.marketing-material-list-comp .material-list-container .card-section .card-item{margin:0 0 20px 0}
.marketing-material-list-comp .material-list-container .card-section .img-box{margin-bottom:12px}
.marketing-material-list-comp .material-list-container .card-section .desc{font-size:15px;line-height:20px}
#material-list-backdrop{background-color:rgba(0,0,0,0.4);position:fixed;left:0;right:0;bottom:0;top:0;z-index:100}
}
.back-to-top-comp{width:50px;height:50px;box-sizing:border-box;border-radius:8px;background-image:linear-gradient(180deg,#f8f8f8 0,#fff 51%,#f8f8f8 100%);border:2px solid rgba(255,255,255,1);opacity:.9;padding:10px;position:fixed;box-shadow:0 0 10px 0 rgba(0,0,0,0.12);right:8px;bottom:calc(30% - 58px);z-index:22;text-align:center;cursor:pointer}
.back-to-top-comp:hover{background-image:linear-gradient(179deg,#fff 0,#e4e4e4 0,#fff 51%,#efefef 100%)}
.back-to-top-comp .icon-box{text-align:center}
.back-to-top-comp .icon-box svg{vertical-align:baseline;width:22px;height:26px;font-size:24px}
.back-to-top-comp .content-text{display:none}
.rtl .back-to-top-comp{right:auto;left:8px}
@media only screen and (max-width:991px){.back-to-top-comp{width:44px;height:44px;right:4px;bottom:calc(30% - 48px);padding:10px 0 9px 0}
.back-to-top-comp .content-text{display:block;color:#d7150e;font-size:.75rem;margin-top:5px}
.back-to-top-comp .icon-box svg{width:19px;height:22px;font-size:18px}
.rtl .back-to-top-comp{right:auto;left:8px}
}
.apply-for-permission .form-wrapper .form-container .form-group label{height:auto}
.apply-for-permission .form-wrapper .form-container .form-group.half{flex-grow:0;flex-shrink:0;flex-basis:calc(50% - 75px)}

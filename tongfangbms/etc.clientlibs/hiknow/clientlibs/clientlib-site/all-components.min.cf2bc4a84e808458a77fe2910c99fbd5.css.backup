.ir-title-comp{margin-bottom:24px}
.ir-title-comp .title-container{padding-bottom:24px;border-bottom:1px solid #eaeaea}
.ir-title-comp .title{position:relative;padding-left:18px;padding-right:18px;font-size:24px;color:#414141;line-height:33px;font-weight:600}
.ir-title-comp .title::before{content:'';top:7px;left:0;position:absolute;width:6px;height:22px;background-color:#d7150e}
@media screen and (max-width:991px){.ir-title-comp{margin-bottom:15px;padding:0 15px}
.ir-title-comp .title-container{padding-bottom:20px}

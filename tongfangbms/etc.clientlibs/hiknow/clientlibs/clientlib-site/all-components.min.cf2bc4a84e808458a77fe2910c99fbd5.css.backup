.media-wrapper-wrapper .media-wrapper-img-wrap .media-img-item.big-media-size .media-wrapper-video{width:100%;position:unset}
.media-wrapper-wrapper .media-wrapper-img-wrap .media-img-item .item-desc,.media-wrapper-wrapper .media-wrapper-img-wrap .media-img-item .media-wrapper-video,.media-wrapper-wrapper .media-wrapper-img-wrap .media-img-item .media-wrapper-img{display:none}
.media-wrapper-wrapper .media-wrapper-img-wrap .media-img-item.active{background-color:#f5f5f5;border-radius:10px;border-bottom:0;padding-left:15px;margin-top:15px}

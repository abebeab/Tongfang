.solution-advanced-map-comp .marker .topic h3{font-size:inherit;font-size:inherit;font-weight:inherit;line-height:inherit;margin-bottom:inherit}
.solution-advanced-map-comp .marker.active,.solution-advanced-map-comp .marker:hover{background-color:rgba(215,21,14,0.8)}
.solution-advanced-map-comp .marker.active .text,.solution-advanced-map-comp .marker:hover .text{background-color:#fff;color:#d7150e}
.solution-advanced-map-comp .marker.active .topic,.solution-advanced-map-comp .marker:hover .topic{color:#fff}
.solution-advanced-map-comp .thumbnail-wrapper{opacity:0;position:fixed;transition:.8s all ease-in-out;pointer-events:none}
.solution-advanced-map-comp .thumbnail-wrapper.active{opacity:1;right:18px;top:20%;z-index:10000;pointer-events:initial}
.solution-advanced-map-comp .thumbnail-wrapper.fade{transition:.2s all ease-in-out;opacity:0}
.solution-advanced-map-comp .thumbnail-wrapper.fade-out-transition{transition:.2s all ease-in-out}
.solution-advanced-map-comp .thumbnail-wrapper .icon-thumbnail-box{background:#fff;cursor:pointer;height:68px;width:128px;padding:4px;box-shadow:0 1px 15px 0 rgba(0,0,0,0.20),0 12px 30px 0 rgba(0,0,0,0.12);border-radius:2px}
.solution-advanced-map-comp .thumbnail-wrapper .icon-thumbnail-box-mobile{display:none}
.solution-advanced-map-comp .thumbnail-wrapper .icon-thumbnail-box,.solution-advanced-map-comp .thumbnail-wrapper .icon-thumbnail-box .marker-box{transition:all .8s ease-in-out}
.solution-advanced-map-comp .thumbnail-wrapper.hover:hover .icon-thumbnail-box{height:300px !important;width:500px !important;padding:12px !important;transition:all .6s ease-in-out .2s}
.solution-advanced-map-comp .thumbnail-wrapper .icon-thumbnail-box .marker-box{opacity:0}
.solution-advanced-map-comp .thumbnail-wrapper.hover:hover .icon-thumbnail-box .marker-box{opacity:1}
.solution-advanced-map-comp .thumbnail-wrapper .icon-close{background:center / contain no-repeat url("https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-close-2.svg");cursor:pointer;height:56px;width:56px;position:absolute;top:-18px;right:0;z-index:1}
.solution-advanced-map-comp .thumbnail-wrapper .thumbnail-container{display:none;position:absolute;top:calc(100% + 20px);right:0}
.solution-advanced-map-comp .thumbnail-wrapper .thumbnail-container.active{display:block}
.solution-advanced-map-comp .thumbnail-wrapper .thumbnail-container.img-top-left{top:auto;bottom:calc(100% + 20px);right:0}
.solution-advanced-map-comp .thumbnail-wrapper .thumbnail-container.img-top-right{top:auto;right:auto;bottom:calc(100% + 20px);left:0}
.solution-advanced-map-comp .thumbnail-wrapper .thumbnail-container.img-bottom-right{right:auto;left:0}
.solution-advanced-map-comp .thumbnail-wrapper .map-container-small{position:relative}
.solution-advanced-map-comp .thumbnail-wrapper .map-container-small img{max-width:650px;min-width:550px}
.solution-advanced-map-comp .thumbnail-wrapper .marker .topic{display:none}
.solution-advanced-map-comp .thumbnail-wrapper .marker.active .topic,.solution-advanced-map-comp .thumbnail-wrapper .marker:hover .topic{display:block}
.solution-advanced-map-comp .thumbnail-wrapper .marker:hover{background-color:rgba(255,255,255,0.8)}
.solution-advanced-map-comp .thumbnail-wrapper .marker:hover .text{background-color:#d7150e;color:#fff}
.solution-advanced-map-comp .thumbnail-wrapper .marker:hover .topic{color:#333}
.solution-advanced-map-comp .solution-detail{display:none;max-width:100vw;position:relative}
.solution-advanced-map-comp .solution-detail.active{display:block}

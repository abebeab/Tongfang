.live-video-list-wrapper .live-video-list-content::-webkit-scrollbar-track{border-radius:10px;width:6px;background-color:transparent}
.live-video-list-wrapper-item{padding-left:10px;margin:1rem 0;position:relative;cursor:pointer}
.live-video-list-wrapper-item:hover::before,.live-video-list-wrapper-item.active::before{content:"";display:inline-block;position:absolute;border-right:10px solid #d7150e;border-bottom:6px solid transparent;border-top:6px solid transparent;left:0;top:50%;transform:translateY(-50%)}
.live-video-list-wrapper-bg{position:relative;width:100%;background-size:100% 100%;padding-top:calc(100% * 9 / 16);height:auto;overflow:hidden;border-radius:8px}
.live-video-list-wrapper-item.active .live-video-list-wrapper-inner,.live-video-list-wrapper-item:hover .live-video-list-wrapper-inner{background:rgba(0,0,0,0.4);border:3px solid #d7150e}
.live-video-list-wrapper-item.active .live-video-list-wrapper-inner-title,.live-video-list-wrapper-item:hover .live-video-list-wrapper-inner-title{top:10px;transition:all 1s}
.live-video-list-wrapper-item.active .live-video-list-wrapper-inner-date,.live-video-list-wrapper-item:hover .live-video-list-wrapper-inner-date{bottom:10px;transition:all 1s}
.live-video-list-wrapper-item.active .live-video-list-wrapper-inner-status,.live-video-list-wrapper-item:hover .live-video-list-wrapper-inner-status{bottom:10px;transition:all 1s}
.live-video-list-wrapper-inner{position:absolute;width:100%;height:100%;top:0;padding:0 .75rem;font-size:.75rem;color:#fff;letter-spacing:.06px;border-radius:8px}
.live-video-list-wrapper-inner-title{position:absolute;padding-right:.75rem;top:-100px}
.live-video-list-wrapper-inner-date{position:absolute;bottom:-30px}
.live-video-list-wrapper-inner-status{position:absolute;right:12px;bottom:-30px}
.live-video-list-wrapper-inner-status::before{content:"";display:inline-block;width:6px;height:6px;background:#d7150e;border-radius:3px;margin-right:1px}

.product-eol-wrapper{max-width:1370px;margin:0 auto !important;padding:0 30px !important}
.product-eol-wrapper .form{background:transparent !important;padding-top:20px !important;padding-bottom:20px !important}
.product-eol-wrapper .form-group .form-control{height:56px;font-size:16px !important}
.product-eol-wrapper .form-group.err .form-control:focus{border:1px solid #d7150e}
.product-eol-wrapper .form-container .form-group label{font-size:16px !important}
.product-eol-wrapper .form-submit-group{justify-content:center}
.product-eol-wrapper .no-result{text-align:center;display:flex;flex-direction:column;align-items:center}
.product-eol-wrapper .no-result img{width:316px}
.product-eol-wrapper .no-result .no-result-text{font-size:16px;display:flex;flex-direction:column;align-items:flex-start}
.product-eol-wrapper .no-result .no-result-text span{font-size:16px;display:flex;flex-direction:column;align-items:flex-start;margin-bottom:16px}
.product-eol-wrapper .no-result .no-result-text .text-bload{font-size:24px;font-weight:700;line-height:34px;font-family:"OpenSansBold","Microsoft YaHei","Helvetica Neue","PingFang SC","Hiragino Sans GB","WenQuanYi Micro Hei",sans-serif}
.product-eol-wrapper .form-submit-group .hiknow-submit{margin-bottom:50px;min-width:162px}
.product-eol-wrapper .product-eol-list .table th,.product-eol-wrapper .product-eol-list .table td{border-top:0;border-bottom:1px solid #eaeaea;color:#333}
.product-eol-wrapper .product-eol-list .table th{background-color:#f5f5f5}
.product-eol-wrapper .product-eol-list .table thead th{border-bottom:0;vertical-align:middle}
.product-eol-wrapper .product-eol-list .table-title{font-weight:600;padding-bottom:24px;border-bottom:1px solid #eaeaea;margin-bottom:25px}
.product-eol-wrapper .product-eol-list .bottom-tip{text-align:center;margin-top:26px;font-size:14px;color:#666}
.product-eol-wrapper .product-eol-list .download-td{text-align:center}
.product-eol-wrapper .product-eol-list .download-btn{display:inline-block;width:20px;height:16px;background:center / contain no-repeat url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/eol-product-download.svg')}
.product-eol-wrapper .product-eol-list .download-btn:hover{background:center / contain no-repeat url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/eol-product-download-hover.svg')}
.product-eol-wrapper .form-container .form-info .form-group.err .error-message{display:block;position:absolute}
@media(max-width:992px){.product-eol-wrapper{padding:0 15px !important;width:100%;margin-bottom:15px !important}
.product-eol-wrapper .no-result img{width:240px}
.product-eol-wrapper .no-result .no-result-text{text-align:start}
.product-eol-wrapper .no-result .no-result-text .text-bload{color:#333;margin-bottom:15px;font-size:16px;line-height:24px}
.product-eol-wrapper .no-result .no-result-text span{margin-bottom:12px;font-size:14px}
.product-eol-wrapper .product-eol-list .table-title{font-size:14px;padding-bottom:12px;margin-bottom:15px}
.product-eol-wrapper .product-eol-list .bottom-tip{margin-top:15px}
.product-eol-wrapper .product-eol-list .product-item{padding:15px;background-color:#f4f4f4;margin-bottom:16px}
.product-eol-wrapper .product-eol-list .product-item .title{font-size:12px;font-weight:600;display:block;margin-bottom:4px}
.product-eol-wrapper .product-eol-list .product-item .detial{font-size:14px;display:block;margin-bottom:16px}
.product-eol-wrapper .product-eol-list .product-item .download-btn-mob{margin-top:4px;padding:0 16px;display:inline-flex;justify-content:center;align-items:center;height:32px;border-radius:16px;border:1px solid #eaeaea;font-size:14px;font-weight:600;color:#333}
.product-eol-wrapper .product-eol-list .product-item .download-btn-mob img{margin-inline-end:8px;width:16px}
.product-eol-wrapper .form-submit-group .hiknow-submit{margin-bottom:0}
.product-eol-wrapper .error-message{font-size:12px}
}

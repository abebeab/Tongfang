.card-stream-wrapper .card-stream-list .card-stream-item .card-stream-img-wrap .card-stream-video.pause .card-video-button{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-video-stop-switching.svg')}
.card-stream-wrapper .card-stream-list .card-stream-item .card-stream-img-wrap .card-stream-video .card-video-button.pause{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-video-stop-switching.svg')}
.card-stream-wrapper .card-stream-list .card-stream-item .card-stream-img-wrap .card-stream-video.ended .card-video-button{background-image:url('https://www.tongfangbms.com/etc/clientlibs/it/resources/icons/icon-video-stop-switching.svg')}
.card-stream-wrapper .card-stream-list .card-stream-item .card-stream-img-wrap .card-stream-video.ended .video-image{opacity:1 !important;background-image:none}

.hiktools-list-comp .hiktools-items-container .detail-section .detail{font-size:0;flex:1;padding-left:12px}
.hiktools-list-comp .hiktools-items-container .detail-section .detail .hiktool-title{color:#333;font-size:16px;font-weight:600;line-height:22px;margin-bottom:8px;padding-right:20px}
.hiktools-list-comp .hiktools-items-container .detail-section .detail .info{color:#666;display:inline-block;position:relative;line-height:17px;font-size:12px;margin-right:16px}
.hiktools-list-comp .hiktools-items-container .detail-section .detail .info::after{content:'';background-color:#ddd;position:absolute;display:block;height:10px;width:1px;right:-8px;top:4px}
.hiktools-list-comp .hiktools-items-container .detail-section .detail .info:last-child::after{display:none}
.hiktools-list-comp .hiktools-items-container .description{color:#666;display:-webkit-box;line-height:20px;font-size:14px;max-height:100px;overflow:hidden;text-overflow:ellipsis;-webkit-line-clamp:5;-webkit-box-orient:vertical}
